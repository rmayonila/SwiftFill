@{
    ViewData["Title"] = "Watch Demo - SwiftFill";
}

<style>
    .demo-container {
        padding: 50px 0;
        text-align: center;
    }
    
    .video-mockup {
        background: #000;
        border: 1px solid var(--border-color);
        border-radius: 20px;
        width: 100%;
        max-width: 900px;
        margin: 40px auto;
        position: relative;
        overflow: hidden;
        aspect-ratio: 16/9;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-shadow: 0 20px 50px rgba(0,0,0,0.8);
    }
    
    .video-mockup::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle, transparent 20%, rgba(255,140,0,0.1) 120%);
    }

    .play-btn {
        background: var(--swift-orange);
        color: #000;
        width: 80px; height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center; justify-content: center;
        font-size: 2.5rem;
        cursor: pointer;
        z-index: 2;
        transition: all 0.3s ease;
        padding-left: 6px; /* offset for play triangle */
    }

    .play-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 0 30px var(--swift-orange-glow);
    }
    
    .demo-stats {
        margin-top: 60px;
    }
</style>

<div class="container demo-container animate-fade-up">
    <a href="/" class="text-secondary text-decoration-none mb-4 d-inline-block"><i class="bi bi-arrow-left"></i> Back to Home</a>
    
    <h1 class="display-4 fw-bold">See <span class="text-orange">SwiftFill</span> in Action</h1>
    <p class="text-secondary mx-auto mb-5" style="max-width: 600px;">
        Watch how our platform seamlessly integrates the Administrator dashboard, Warehouse mobile app, and Customer portal to eliminate fulfillment bottlenecks.
    </p>

    <!-- Video Player Mockup -->
    <div class="video-mockup">
        <div class="play-btn" onclick="alert('Demo video starting...')">
            <i class="bi bi-play-fill"></i>
        </div>
        <div class="text-white-50 mt-4 position-relative z-index-2">
            3-Minute Platform Overview
        </div>
    </div>

    <!-- Below Video Features -->
    <div class="row text-start demo-stats g-5">
        <div class="col-md-4">
            <h4 class="text-orange mb-3"><i class="bi bi-rocket"></i> Fast Onboarding</h4>
            <p class="text-secondary">Get your team trained and picking orders in less than 24 hours. No complex manual required.</p>
        </div>
        <div class="col-md-4">
            <h4 class="text-orange mb-3"><i class="bi bi-box-seam"></i> Intelligent Routing</h4>
            <p class="text-secondary">Our picking algorithms save warehouse staff miles of walking every week by optimizing pick paths.</p>
        </div>
        <div class="col-md-4">
            <h4 class="text-orange mb-3"><i class="bi bi-shield-check"></i> Zero Errors</h4>
            <p class="text-secondary">Built-in barcode scanning constraints prevent the wrong item from ever leaving your facility.</p>
        </div>
    </div>
</div>
