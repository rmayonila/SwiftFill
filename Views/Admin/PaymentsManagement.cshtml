@model IEnumerable<SwiftFill.Models.PaymentMethod>
@{
    ViewData["Title"] = "Payment Settings";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-wallet2 text-orange me-2"></i> Payment Methods</h2>
        <button type="button" class="btn btn-primary px-4" style="background:#FF8C00;" data-bs-toggle="modal" data-bs-target="#addMethodModal">
            <i class="bi bi-plus-lg me-2"></i> Add Method
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 border-success text-success border-0 mb-4 animate-fade-in">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="row g-4">
        @foreach (var method in Model)
        {
            <div class="col-md-4">
                <div class="glass-card p-4 border-0 h-100 d-flex flex-column" style="background: rgba(255, 255, 255, 0.02);">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="rounded-circle bg-dark p-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi @method.IconClass text-orange fs-4"></i>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-link text-secondary p-0" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end border-secondary border-opacity-25 shadow-lg" style="background: #0f0f0f;">
                                <li><a class="dropdown-item py-2" href="#" onclick="editMethod(@Json.Serialize(method))"><i class="bi bi-pencil me-2"></i> Edit</a></li>
                                <li><hr class="dropdown-divider border-white border-opacity-10"></li>
                                <li><form asp-action="DeletePaymentMethod" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@method.Id" />
                                    <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-trash me-2"></i> Delete</button>
                                </form></li>
                            </ul>
                        </div>
                    </div>
                    <h5 class="text-white fw-bold mb-1">@method.Name</h5>
                    <p class="text-secondary small mb-3 flex-grow-1">@method.Description</p>
                    
                    <div class="d-flex align-items-center gap-2 mt-auto">
                        <span class="badge border @(method.IsActive ? "border-success text-success" : "border-danger text-danger") bg-transparent px-2" style="font-size: 0.65rem;">
                            @(method.IsActive ? "ACTIVE" : "DISABLED")
                        </span>
                        @if (method.IsOnline)
                        {
                            <span class="badge border border-info text-info bg-transparent px-2" style="font-size: 0.65rem;">
                                ONLINE REQ
                            </span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addMethodModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: #0f0f0f; border-radius: 16px; border: 1px solid rgba(255,140,0,0.1) !important;">
            <div class="modal-header border-0">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-plus-circle text-orange me-2"></i> New Payment Method</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="AddPaymentMethod" method="post" id="addMethodForm">
                    <div class="mb-3">
                        <label class="text-secondary x-small mb-1">Method Name</label>
                        <input type="text" name="Name" class="minimal-input w-100" placeholder="e.g. GCash" required>
                    </div>
                    <div class="mb-3">
                        <label class="text-secondary x-small mb-1">Description</label>
                        <textarea name="Description" class="minimal-input w-100" rows="2" placeholder="Brief description..."></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-secondary x-small mb-1">Icon (Bootstrap Icon Class)</label>
                            <input type="text" name="IconClass" class="minimal-input w-100" placeholder="bi-wallet2" value="bi-wallet2">
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="IsOnline" value="true">
                                <label class="form-check-label text-secondary x-small">Online Required</label>
                            </div>
                        </div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked>
                        <label class="form-check-label text-secondary x-small">Set as Active</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="addMethodForm" class="btn btn-primary px-4 fw-bold" style="background:#FF8C00;">Add Method</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editMethodModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: #0f0f0f; border-radius: 16px; border: 1px solid rgba(255,140,0,0.1) !important;">
            <div class="modal-header border-0">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-pencil-square text-orange me-2"></i> Edit Payment Method</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="UpdatePaymentMethod" method="post" id="editMethodForm">
                    <input type="hidden" name="Id" id="editId" />
                    <div class="mb-3">
                        <label class="text-secondary x-small mb-1">Method Name</label>
                        <input type="text" name="Name" id="editName" class="minimal-input w-100" required>
                    </div>
                    <div class="mb-3">
                        <label class="text-secondary x-small mb-1">Description</label>
                        <textarea name="Description" id="editDescription" class="minimal-input w-100" rows="2"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-secondary x-small mb-1">Icon Class</label>
                            <input type="text" name="IconClass" id="editIcon" class="minimal-input w-100">
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="IsOnline" id="editIsOnline" value="true">
                                <label class="form-check-label text-secondary x-small">Online Required</label>
                            </div>
                        </div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" id="editIsActive" value="true">
                        <label class="form-check-label text-secondary x-small">Set as Active</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="editMethodForm" class="btn btn-primary px-4 fw-bold" style="background:#FF8C00;">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<script>
    function editMethod(method) {
        document.getElementById('editId').value = method.id;
        document.getElementById('editName').value = method.name;
        document.getElementById('editDescription').value = method.description;
        document.getElementById('editIcon').value = method.iconClass;
        document.getElementById('editIsOnline').checked = method.isOnline;
        document.getElementById('editIsActive').checked = method.isActive;
        
        new bootstrap.Modal(document.getElementById('editMethodModal')).show();
    }
</script>

<style>
    .x-small { font-size: 0.75rem; }
    .animate-fade-in { animation: fadeIn 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>
