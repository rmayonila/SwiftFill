@model IEnumerable<SwiftFill.Models.Order>
@{
    ViewData["Title"] = "Order Packing";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-box-seam me-3 text-orange"></i> Order Packing</h2>
        <div class="text-secondary small">Manage picking and packing for items received from customers.</div>
    </div>

    <!-- Integrated Filter Bar (Reference-Matched) -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px;">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           placeholder="Search Tracking ID or Receiver Name...">
                </div>
            </form>
        </div>

        <div class="d-flex align-items-center gap-4">
            <form method="get" class="d-flex align-items-center gap-3">
                <select name="status" class="minimal-input" style="width: 200px; background: transparent; border: none;" onchange="this.form.submit()">
                    <option value="All" selected='@(ViewBag.Status == "All")'>All Pending/Picked</option>
                    <option value="Pending" selected='@(ViewBag.Status == "Pending")'>Pending Only</option>
                    <option value="Picked" selected='@(ViewBag.Status == "Picked")'>Picked (Ready to Pack)</option>
                </select>
            </form>
            <button type="submit" form="filterForm" class="btn btn-primary px-4 py-2 shadow-sm border-0 d-flex align-items-center" 
                    style="background: #FF8C00; border-radius: 8px; font-weight: 600; font-size: 0.85rem;" onclick="this.closest('form').submit()">
                <i class="bi bi-search me-2"></i> Search
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-dark text-success border-success mb-4">@TempData["SuccessMessage"]</div>
    }

    <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr>
                        <th class="ps-4 py-3">Tracking ID</th>
                        <th class="py-3">Receiver</th>
                        <th class="py-3">Package Details</th>
                        <th class="py-3">Destination</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 pe-4 text-end">Action</th>
                    </tr>
                </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                        <td class="ps-4 py-3 fw-bold text-orange">#@order.TrackingId</td>
                        <td class="py-3">
                            <div class="fw-bold text-white">@order.ReceiverName</div>
                            <div class="x-small text-secondary">@order.ReceiverPhone</div>
                        </td>
                        <td class="py-3">
                            <div class="small text-white">@(order.ItemCategory ?? "General") &bull; @order.Weight kg</div>
                            @if (order.IsFragile)
                            {
                                <span class="badge bg-warning text-dark" style="font-size:0.6rem;"><i class="bi bi-exclamation-triangle-fill me-1"></i>FRAGILE</span>
                            }
                        </td>
                        <td class="py-3 text-white small">@order.DestinationRegion</td>
                        <td class="py-3">
                            <span class="badge border bg-transparent px-2 @(order.Status == "Picked" ? "border-info text-info" : "border-warning text-warning")" style="font-size: 0.65rem;">@order.Status</span>
                        </td>
                        <td class="py-3 pe-4 text-end">
                            <button class="btn btn-sm btn-outline-orange x-small fw-bold text-uppercase" onclick="openPackModal('@order.TrackingId')">
                                Update Packing
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-secondary">No orders pending for packing.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search&status=@ViewBag.Status">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search&status=@ViewBag.Status">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search&status=@ViewBag.Status">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Single Shared Packing Modal -->
<div class="modal fade" id="packModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-warning" style="border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-box-seam text-warning me-2"></i> Packing Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdatePacking" method="post" id="packForm">
                <div class="modal-body pt-3">
                    <input type="hidden" name="trackingId" id="packTrackingId" />
                    
                    <div class="mb-4 p-3 rounded bg-black bg-opacity-50 border border-secondary border-opacity-10">
                        <div class="text-secondary x-small text-uppercase mb-1">Target Shipment</div>
                        <div class="fw-bold text-white fs-5" id="displayTrackingId">#—</div>
                        <div class="text-secondary small" id="displayReceiver">—</div>
                        <div class="mt-2 d-flex align-items-center gap-2">
                            <span class="badge bg-secondary x-small" id="displayCategory">—</span>
                            <span class="badge x-small" id="displayFragile">—</span>
                            <span class="text-secondary x-small" id="displayWeight">—</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Final Measured Weight (kg)</label>
                        <input type="number" name="finalWeight" id="packFinalWeight" class="form-control bg-dark border-secondary text-white shadow-none" step="0.01" placeholder="Enter actual weighed kg">
                        <div class="form-text text-secondary x-small">Leave blank to keep the original estimated weight.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Service Required</label>
                        <div class="form-check p-0">
                            <div class="glass-card p-3 d-flex align-items-center gap-3" style="background: rgba(255,255,255,0.02); cursor:pointer;" onclick="document.getElementById('availPacking').click()">
                                <input class="form-check-input ms-0 mt-0" type="checkbox" name="availPacking" value="true" id="availPacking">
                                <label class="form-check-label text-white-50" for="availPacking" style="cursor:pointer;">
                                    Bubble Wrap / Box / Crating Required
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Packing Fee (₱)</label>
                        <input type="number" name="packingFee" id="packFee" class="form-control bg-dark border-secondary text-white shadow-none" value="0" step="0.01">
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Packing Location</label>
                        <select name="packingLocation" id="packLocation" class="form-select bg-dark border-secondary text-white shadow-none">
                            <option value="Store">In Front of Customer (Store)</option>
                            <option value="Warehouse">Warehouse (Large Cargo/Electric)</option>
                        </select>
                    </div>

                    <input type="hidden" name="sortingStatus" id="sortStatus" value="Pending" />
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-bold px-4">Complete Packing</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentTargetRow = null;

        function openPackModal(trackingId) {
            currentTargetRow = event.target.closest('tr');
            const modal = new bootstrap.Modal(document.getElementById('packModal'));

            // Reset fields while loading
            document.getElementById('displayTrackingId').textContent = '#' + trackingId;
            document.getElementById('packTrackingId').value = trackingId;
            document.getElementById('packFinalWeight').value = '';

            fetch(`/Admin/GetOrderJson?trackingId=${trackingId}`)
                .then(r => r.json())
                .then(order => {
                    document.getElementById('displayReceiver').textContent = order.receiverName;
                    document.getElementById('displayCategory').textContent = order.itemCategory || 'General';

                    const fragileEl = document.getElementById('displayFragile');
                    if (order.isFragile) {
                        fragileEl.textContent = '⚠ FRAGILE';
                        fragileEl.className = 'badge bg-warning text-dark x-small';
                    } else {
                        fragileEl.textContent = 'Non-Fragile';
                        fragileEl.className = 'badge bg-secondary x-small';
                    }

                    document.getElementById('displayWeight').textContent = `Est. ${order.weight} kg`;
                    document.getElementById('availPacking').checked = order.availPacking;
                    document.getElementById('packFee').value = order.packingFee;
                    document.getElementById('packLocation').value = order.packingLocation || 'Store';
                    
                    // Reset button state on open
                    const btn = document.querySelector('#packForm button[type="submit"]');
                    if (order.packingLocation === 'Warehouse') {
                        btn.textContent = 'Send to Warehouse';
                        btn.className = 'btn btn-info fw-bold px-4';
                    } else {
                        btn.textContent = 'Complete Packing';
                        btn.className = 'btn btn-warning fw-bold px-4';
                    }
                    
                    modal.show();
                });
        }

        document.getElementById('packLocation').addEventListener('change', function() {
            const btn = document.querySelector('#packForm button[type="submit"]');
            if (this.value === 'Warehouse') {
                btn.textContent = 'Send to Warehouse';
                btn.className = 'btn btn-info fw-bold px-4';
            } else {
                btn.textContent = 'Complete Packing';
                btn.className = 'btn btn-warning fw-bold px-4';
            }
        });

        document.getElementById('packForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = this;
            const btn = form.querySelector('button[type="submit"]');
            const originalBtnHtml = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Updating...';

            const formData = new FormData(form);
            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                const result = await response.json();
                
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('packModal')).hide();
                    if (currentTargetRow) {
                        const statusBadge = currentTargetRow.querySelector('.badge');
                        const packLocation = document.getElementById('packLocation').value;
                        const finalStatus = packLocation === 'Store' ? 'Packed in Store' : 'Sent to Warehouse Packing';
                        
                        statusBadge.className = packLocation === 'Store' ? 'badge bg-success' : 'badge bg-info';
                        statusBadge.textContent = finalStatus;
                        const actionCell = currentTargetRow.querySelector('td:last-child');
                        const actionText = packLocation === 'Store' ? `Packed ₱${(result.newTotal||0).toLocaleString('en-US', {minimumFractionDigits:2})}` : 'Forwarded to WH';
                        actionCell.innerHTML = `<span class="${packLocation === 'Store' ? 'text-success' : 'text-info'} small fw-bold"><i class="bi bi-check-circle me-1"></i>${actionText}</span>`;
                    }
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (err) {
                alert('System error occurred.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalBtnHtml;
            }
        });
    </script>
}

<style>
    .animate-fade-up { animation: fadeUp 0.3s ease-out forwards; }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .ls-1 { letter-spacing: 1px; }
</style>
