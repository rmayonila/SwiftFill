@model IEnumerable<SwiftFill.Models.Order>
@{
    ViewData["Title"] = "Order Packing";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-box-seam me-3 text-warning"></i> Order Packing</h1>
            <p class="text-secondary mt-1">Manage picking and packing for items received from customers.</p>
        </div>
    </div>

    <div class="card bg-dark border-secondary mb-4">
        <div class="card-body">
            <form method="get" class="row g-2">
                <div class="col-md-7">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control bg-transparent text-white border-secondary" placeholder="Search Tracking ID or Receiver Name...">
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select bg-transparent text-white border-secondary">
                        <option value="All" selected='@(ViewBag.Status == "All")'>All Pending/Picked</option>
                        <option value="Pending" selected='@(ViewBag.Status == "Pending")'>Pending Only</option>
                        <option value="Picked" selected='@(ViewBag.Status == "Picked")'>Picked (Ready to Pack)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Search</button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-dark text-success border-success mb-4">@TempData["SuccessMessage"]</div>
    }

    <div class="table-responsive">
        <table class="table table-dark table-hover border-secondary align-middle">
            <thead class="text-secondary small text-uppercase">
                <tr>
                    <th>Tracking ID</th>
                    <th>Receiver</th>
                    <th>Destination</th>
                    <th>Status</th>
                    <th>Packing Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold text-warning">#@order.TrackingId</td>
                        <td>
                            <div class="fw-bold">@order.ReceiverName</div>
                            <div class="small text-secondary">@order.ReceiverPhone</div>
                        </td>
                        <td>@order.DestinationRegion</td>
                        <td>
                            <span class="badge @(order.Status == "Picked" ? "bg-info" : "bg-secondary")">@order.Status</span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning" onclick="openPackModal('@order.TrackingId')">
                                Update Packing
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-secondary">No orders pending for packing.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link bg-dark border-secondary text-white" href="?search=@ViewBag.Search&page=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<!-- Single Shared Packing Modal -->
<div class="modal fade" id="packModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-warning" style="border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-box-seam text-warning me-2"></i> Packing Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdatePacking" method="post" id="packForm">
                <div class="modal-body pt-3">
                    <input type="hidden" name="trackingId" id="packTrackingId" />
                    
                    <div class="mb-4 p-3 rounded bg-black bg-opacity-50 border border-secondary border-opacity-10">
                        <div class="text-secondary x-small text-uppercase mb-1">Target Shipment</div>
                        <div class="fw-bold text-white fs-5" id="displayTrackingId">#—</div>
                        <div class="text-secondary small" id="displayReceiver">—</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Service Required</label>
                        <div class="form-check p-0">
                            <div class="glass-card p-3 d-flex align-items-center gap-3" style="background: rgba(255,255,255,0.02); cursor:pointer;" onclick="document.getElementById('availPacking').click()">
                                <input class="form-check-input ms-0 mt-0" type="checkbox" name="availPacking" value="true" id="availPacking">
                                <label class="form-check-label text-white-50" for="availPacking" style="cursor:pointer;">
                                    Bubble Wrap / Box / Crating Required
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Packing Fee (₱)</label>
                        <input type="number" name="packingFee" id="packFee" class="form-control bg-dark border-secondary text-white shadow-none" value="0" step="0.01">
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Packing Location</label>
                        <select name="packingLocation" id="packLocation" class="form-select bg-dark border-secondary text-white shadow-none">
                            <option value="Store">In Front of Customer (Store)</option>
                            <option value="Warehouse">Warehouse (Large Cargo/Electric)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase ls-1">Sorting Status</label>
                        <select name="sortingStatus" id="sortStatus" class="form-select bg-dark border-secondary text-white shadow-none">
                            <option value="Pending in Store">Pending in Store</option>
                            <option value="Sorted in Warehouse">Sorted in Warehouse</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-bold px-4">Complete Packing</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentTargetRow = null;

        function openPackModal(trackingId) {
            currentTargetRow = event.target.closest('tr');
            const modal = new bootstrap.Modal(document.getElementById('packModal'));
            
            // Reset fields while loading
            document.getElementById('displayTrackingId').textContent = '#' + trackingId;
            document.getElementById('packTrackingId').value = trackingId;
            
            fetch(`/Admin/GetOrderJson?trackingId=${trackingId}`)
                .then(r => r.json())
                .then(order => {
                    document.getElementById('displayReceiver').textContent = order.receiverName;
                    document.getElementById('availPacking').checked = order.availPacking;
                    document.getElementById('packFee').value = order.packingFee;
                    document.getElementById('packLocation').value = order.packingLocation || 'Store';
                    document.getElementById('sortStatus').value = order.sortingStatus || 'Pending in Store';
                    modal.show();
                });
        }

        document.getElementById('packForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = this;
            const btn = form.querySelector('button[type="submit"]');
            const originalBtnHtml = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Updating...';

            const formData = new FormData(form);
            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                const result = await response.json();
                
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('packModal')).hide();
                    if (currentTargetRow) {
                        const statusBadge = currentTargetRow.querySelector('.badge');
                        statusBadge.className = 'badge bg-success';
                        statusBadge.textContent = 'Packed';
                        const actionCell = currentTargetRow.querySelector('td:last-child');
                        actionCell.innerHTML = '<span class="text-success small fw-bold"><i class="bi bi-check-circle me-1"></i> Completed</span>';
                    }
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (err) {
                alert('System error occurred.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalBtnHtml;
            }
        });
    </script>
}

<style>
    .animate-fade-up { animation: fadeUp 0.3s ease-out forwards; }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .ls-1 { letter-spacing: 1px; }
</style>
