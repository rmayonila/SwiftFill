@model IEnumerable<SwiftFill.Models.Order>
@{
    ViewData["Title"] = "Archived Orders";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-secondary"><i class="bi bi-archive text-warning me-2"></i> Archived Orders</h2>
        <div>
            @if (TempData["SuccessMessage"] != null)
            {
                <span class="badge bg-success me-3 p-2">@TempData["SuccessMessage"]</span>
            }
        </div>
    </div>

    <!-- Integrated Filter Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px;">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           placeholder="Search Archived Orders...">
                </div>
            </form>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,255,255,0.03);">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase ls-1 x-small">Tracking ID</th>
                        <th class="py-3 text-secondary text-uppercase ls-1 x-small">Customer Details</th>
                        <th class="py-3 text-secondary text-uppercase ls-1 x-small">Original Status</th>
                        <th class="py-3 text-secondary text-uppercase ls-1 x-small">Archived Date</th>
                        <th class="py-3 pe-4 text-end text-secondary text-uppercase ls-1 x-small">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No archived records found.
                            </td>
                        </tr>
                    }
                    @foreach (var order in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.02); opacity: 0.8;">
                            <td class="ps-4 py-3">
                                <code class="text-secondary fw-bold">@order.TrackingId</code>
                            </td>
                            <td class="py-3">
                                <div class="text-white-50">@order.SenderName</div>
                                <div class="text-secondary x-small"><i class="bi bi-arrow-right me-1"></i> @order.ReceiverName</div>
                            </td>
                            <td class="py-3">
                                <span class="badge border bg-transparent px-3 py-1 border-secondary text-secondary" style="font-size: 0.65rem;">
                                    @order.Status
                                </span>
                            </td>
                            <td class="py-3">
                                <div class="x-small text-secondary mt-1">@order.UpdatedAt.ToString("MMM dd yyyy, HH:mm")</div>
                            </td>
                            <td class="py-3 pe-4 text-end">
                                <form asp-action="RestoreOrder" method="post" class="d-inline">
                                    <input type="hidden" name="trackingId" value="@order.TrackingId" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning border-0 p-1 px-3 rounded-pill fw-bold" onclick="return confirm('Restore this order to active shipments?')">
                                        <i class="bi bi-arrow-counterclockwise"></i> Restore
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0 text-white" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .bg-orange { background-color: #ff8c00 !important; }
    .ls-1 { letter-spacing: 1px; }
    .x-small { font-size: 0.75rem; }
    .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.03) !important;
        opacity: 1 !important;
    }
</style>
