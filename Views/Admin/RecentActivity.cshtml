@model IEnumerable<SwiftFill.Models.Order>
@{
    ViewData["Title"] = "Recent Activity";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-clock-history text-orange me-2"></i> Recent System Activity</h2>
    </div>

    <div class="glass-card p-0 overflow-hidden border-0" style="background: rgba(255, 255, 255, 0.01);">
        <ul class="list-group list-group-flush bg-transparent">
            @foreach (var order in Model)
            {
                <li class="list-group-item bg-transparent border-bottom border-dark py-3 px-4" style="border-color: rgba(255,255,255,0.02) !important;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 x-small mb-1">LOGISTICS EVENT</div>
                            <div class="text-white">Shipment <code class="text-orange">@order.TrackingId</code> received at Central Hub</div>
                            <div class="text-secondary x-small mt-1 opacity-50">Node: SF-TRANSIT-@(order.TrackingId.Substring(0,4))</div>
                        </div>
                        <div class="text-secondary x-small">@order.CreatedAt.ToString("MMM dd, HH:mm")</div>
                    </div>
                </li>
            }
            @if (!Model.Any())
            {
                <li class="list-group-item bg-transparent text-center py-5 text-secondary border-0"><i class="bi"></i>No recent activity found.</li>
            }
        </ul>
    </div>
</div>
