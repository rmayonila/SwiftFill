@using System
@using System.Linq
@model IEnumerable<SwiftFill.Models.Payment>
@{
    ViewData["Title"] = "Payment Records";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-cash-stack text-orange me-2"></i> Payment Settlements</h2>
        <div class="text-secondary small">Ledger Status: <span class="text-success">Verified</span></div>
    </div>

    <div class="minimal-filter-bar mb-4">
        <form method="get" class="d-flex w-100 gap-3 align-items-center">
            <div class="search-wrapper">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                       placeholder="Search Tracking ID or Transaction Hash...">
            </div>
            <button type="submit" class="btn btn-sm btn-primary px-4 py-2 border-0 shadow-sm" style="background: #FF8C00;">Verify Ledger</button>
            <a href="/Admin/Reconciliation" class="btn btn-sm btn-outline-secondary border-0 px-3 opacity-50"><i class="bi bi-arrow-clockwise"></i></a>
        </form>
    </div>

    <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr>
                        <th class="ps-4 py-3">Tracking ID</th>
                        <th class="py-3">Amount</th>
                        <th class="py-3">Method</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 pe-4 text-end">Settlement Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                            <td class="ps-4 py-3"><code class="text-orange">@payment.TrackingId</code></td>
                            <td class="py-3 fw-bold text-white">₱@payment.Amount.ToString("N2")</td>
                            <td class="py-3 text-secondary small">@payment.Method</td>
                            <td class="py-3">
                                <span class="badge border border-success text-success bg-transparent px-2">Settled</span>
                            </td>
                            <td class="py-3 pe-4 text-end text-secondary small">
                                @(payment.PaidAt?.ToString("MMM dd, yyyy") ?? "Pending")
                                <div class="x-small">@payment.PaidAt?.ToString("HH:mm")</div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary">No recorded settlements found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .bg-orange { background-color: #ff8c00 !important; }
    .x-small { font-size: 0.75rem; }
</style>
