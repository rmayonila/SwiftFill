@using System
@using System.Linq
@model IEnumerable<SwiftFill.Models.Payment>
@{
    ViewData["Title"] = "Payment Records";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-wallet2 text-orange me-2"></i> Transaction History</h2>
        <div class="text-secondary small">Comprehensive financial oversight for all shipment settlements.</div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 border-success text-success border-0 mb-4 animate-fade-in">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <!-- Integrated Filter Bar (Reference-Matched) -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px;">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           placeholder="Search Tracking ID or Receiver Name...">
                </div>
            </form>
        </div>

        <div class="d-flex align-items-center gap-4">
            <form method="get" class="d-flex align-items-center gap-3">
                <select name="status" class="minimal-input" style="width: 150px; background: transparent; border: none;" onchange="this.form.submit()">
                    <option value="">Status</option>
                    <option value="Paid" selected="@(ViewBag.Status == "Paid")">Settled / Paid</option>
                    <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending COD</option>
                </select>
            </form>
            <button type="submit" class="btn btn-primary px-4 py-2 shadow-sm border-0 d-flex align-items-center" 
                    style="background: #FF8C00; border-radius: 8px; font-weight: 600; font-size: 0.85rem;" onclick="this.closest('form').submit()">
                <i class="bi bi-search me-2"></i> Filter
            </button>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr>
                        <th class="ps-4 py-3">Tracking ID</th>
                        <th class="py-3">Customer</th>
                        <th class="py-3">Amount</th>
                        <th class="py-3">Method</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 pe-4 text-end">Action / Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                            <td class="ps-4 py-3">
                                <code class="text-orange fw-bold">@payment.TrackingId</code>
                            </td>
                            <td class="py-3">
                                <div class="text-white small">@(payment.Order?.ReceiverName ?? "External")</div>
                                <div class="text-secondary x-small">@(payment.Order?.DestinationRegion ?? "N/A")</div>
                            </td>
                            <td class="py-3 fw-bold text-white">₱@payment.Amount.ToString("N2")</td>
                            <td class="py-3">
                                <span class="badge border border-secondary border-opacity-50 text-secondary bg-transparent px-2" style="font-size: 0.65rem;">
                                    @payment.Method
                                </span>
                            </td>
                            <td class="py-3">
                                @if (payment.IsPaid)
                                {
                                    <span class="badge border border-success text-success bg-transparent px-2" style="font-size: 0.65rem;">
                                        <i class="bi bi-check-circle-fill me-1"></i> Settled
                                    </span>
                                }
                                else
                                {
                                    <span class="badge border border-warning text-warning bg-transparent px-2" style="font-size: 0.65rem;">
                                        <i class="bi bi-clock-history me-1"></i> Pending COD
                                    </span>
                                }
                            </td>
                            <td class="py-3 pe-4 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    @if (!payment.IsPaid && payment.Method == "COD")
                                    {
                                        <form asp-action="ConfirmPayment" method="post" class="m-0">
                                            <input type="hidden" name="paymentId" value="@payment.PaymentId" />
                                            <button type="submit" class="btn btn-sm btn-outline-orange x-small fw-bold text-uppercase">
                                                Settle Payment
                                            </button>
                                        </form>
                                    }
                                    else if (payment.IsPaid)
                                    {
                                        <div class="text-end me-2">
                                            <div class="text-secondary x-small">@payment.PaidAt?.ToString("MMM dd, yyyy HH:mm")</div>
                                            <div class="x-small opacity-50">Ref: SF-TRX-@payment.PaymentId</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-secondary x-small italic me-2">Awaiting Action</span>
                                    }
                                    
                                    <button type="button" class="btn btn-sm btn-outline-danger border-0 p-1 opacity-50" 
                                            onclick="confirmArchivePayment('@payment.TrackingId', @payment.PaymentId)" title="Archive Record">
                                        <i class="bi bi-archive"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary">No recorded settlements found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Archive Confirmation Modal -->
<div class="modal fade" id="archivePaymentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg" style="background: #0a0a0a; border-radius: 16px; border: 1px solid rgba(220,53,69,0.2) !important;">
            <div class="modal-body text-center p-4">
                <div class="display-4 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></div>
                <h5 class="text-white fw-bold mb-2">Archive Payment?</h5>
                <p class="text-secondary small mb-4">Are you sure you want to archive payment for <strong id="archiveTrackingId" class="text-white"></strong>? This will remove it from active management.</p>
                <form asp-action="ArchivePayment" method="post" id="archivePaymentForm">
                    <input type="hidden" name="paymentId" id="archivePaymentIdInput" />
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-dark flex-fill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger flex-fill fw-bold">Yes, Archive</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmArchivePayment(trackingId, paymentId) {
        document.getElementById('archiveTrackingId').innerText = trackingId;
        document.getElementById('archivePaymentIdInput').value = paymentId;
        const modal = new bootstrap.Modal(document.getElementById('archivePaymentModal'));
        modal.show();
    }
</script>

<style>
    .bg-orange { background-color: #ff8c00 !important; }
    .x-small { font-size: 0.75rem; }
</style>
