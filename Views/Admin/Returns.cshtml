@using System
@using System.Linq
@model IEnumerable<SwiftFill.Models.ReturnRequest>
@{
    ViewData["Title"] = "Return Requests";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-arrow-return-left text-orange me-2"></i> Return Management</h2>
        <div class="text-secondary small">Pending Reviews: <span class="text-orange">@(Model?.Count(r => r.Status == "Pending") ?? 0)</span></div>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-danger bg-dark border-danger text-danger">Unable to load return requests. Please try again later.</div>
    }
    else
    {
        <!-- Integrated Filter Bar (Reference-Matched) -->
        <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
            <div class="d-flex align-items-center flex-grow-1 gap-3">
                <form method="get" class="d-flex align-items-center flex-grow-1">
                    <div class="search-wrapper flex-grow-1" style="max-width: 400px;">
                        <i class="bi bi-search"></i>
                        <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                               placeholder="Search Tracking ID or Reason...">
                    </div>
                </form>
            </div>

            <div class="d-flex align-items-center gap-4">
                <form method="get" class="d-flex align-items-center gap-3">
                    <select name="status" class="minimal-input" style="width: 150px; background: transparent; border: none;" onchange="this.form.submit()">
                        <option value="All">All Statuses</option>
                        <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending Approval</option>
                        <option value="Approved" selected="@(ViewBag.Status == "Approved")">Approved</option>
                        <option value="Rejected" selected="@(ViewBag.Status == "Rejected")">Rejected</option>
                    </select>
                </form>
            </div>
        </div>

        <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead style="background: rgba(255,140,0,0.03);">
                        <tr>
                            <th class="ps-4 py-3">RMA/Tracking</th>
                            <th class="py-3">Address</th>
                            <th class="py-3">Reason</th>
                            <th class="py-3">Status</th>
                            <th class="py-3 pe-4 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                                <td class="ps-4 py-3">
                                    <code class="text-orange">@item.TrackingId</code>
                                    <div class="x-small text-secondary">@item.Order?.ReceiverName</div>
                                </td>
                                <td class="py-3">
                                    <div class="text-white small" style="max-width: 250px;">
                                        <i class="bi bi-geo-alt text-secondary me-1"></i>
                                        @(item.Order?.ReceiverAddress ?? "No Address Linked")
                                    </div>
                                    <div class="x-small text-secondary">@item.Order?.DestinationRegion</div>
                                </td>
                                <td class="py-3 text-white">@(item.Description ?? item.Reason)</td>
                                <td class="py-3">
                                    <span class="badge border @(item.Status == "Pending" ? "border-warning text-warning" : (item.Status == "Approved" ? "border-success text-success" : "border-danger text-danger")) bg-transparent px-2">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="py-3 pe-4 text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        @if (item.Status == "Pending")
                                        {
                                            <form asp-action="ProcessReturn" method="post" class="m-0">
                                                <input type="hidden" name="requestId" value="@item.RequestId" />
                                                <button type="submit" name="actionType" value="Notify" class="btn btn-sm btn-info border-0 px-2 fw-bold text-dark"><i class="bi bi-bell-fill"></i> Notify Sender</button>
                                            </form>
                                        }
                                        else if (item.Status == "Sender Notified")
                                        {
                                            <form asp-action="ProcessReturn" method="post" class="m-0">
                                                <input type="hidden" name="requestId" value="@item.RequestId" />
                                                <button type="submit" name="actionType" value="Approve" class="btn btn-sm btn-outline-success border-0 px-2 opacity-75">Approve (RTS)</button>
                                                <button type="submit" name="actionType" value="Reject" class="btn btn-sm btn-outline-danger border-0 px-2 opacity-75">Reject</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary border-0 px-2 opacity-50" onclick="viewReturnDetails('@item.TrackingId')">Details</button>
                                        }

                                        <button type="button" class="btn btn-sm btn-outline-danger border-0 p-1 opacity-50" 
                                                onclick="confirmArchiveReturn(@item.RequestId, '@item.TrackingId')" title="Archive Record">
                                            <i class="bi bi-archive"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-secondary">No recorded return requests.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search&status=@ViewBag.Status">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search&status=@ViewBag.Status">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search&status=@ViewBag.Status">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Return Details Modal -->
<div class="modal fade" id="returnDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: #0a0a0a; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05) !important;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-arrow-return-left text-orange me-2"></i> Return Information</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="returnDetailsContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-orange" role="status"></div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Archive Confirmation Modal -->
<div class="modal fade" id="archiveReturnModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg" style="background: #0a0a0a; border-radius: 16px; border: 1px solid rgba(220,53,69,0.2) !important;">
            <div class="modal-body text-center p-4">
                <div class="display-4 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></div>
                <h5 class="text-white fw-bold mb-2">Archive Return?</h5>
                <p class="text-secondary small mb-4">Are you sure you want to archive return request for <strong id="archiveTrackingId" class="text-white"></strong>? This will remove it from active management.</p>
                <form asp-action="ArchiveReturnRequest" method="post" id="archiveReturnForm">
                    <input type="hidden" name="requestId" id="archiveRequestIdInput" />
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-dark flex-fill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger flex-fill fw-bold">Yes, Archive</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function viewReturnDetails(trackingId) {
        const modal = new bootstrap.Modal(document.getElementById('returnDetailsModal'));
        const content = document.getElementById('returnDetailsContent');
        content.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-orange" role="status"></div></div>';
        modal.show();

        fetch(`/Admin/GetOrderJson?trackingId=${trackingId}`)
            .then(r => r.json())
            .then(order => {
                content.innerHTML = `
                    <div class="mb-4">
                        <label class="text-secondary x-small text-uppercase ls-1 d-block mb-2">Tracking ID</label>
                        <code class="text-orange fs-5">${order.trackingId}</code>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label class="text-secondary x-small text-uppercase ls-1 d-block mb-1">Sender</label>
                            <div class="text-white fw-bold">${order.senderName}</div>
                        </div>
                        <div class="col-6">
                            <label class="text-secondary x-small text-uppercase ls-1 d-block mb-1">Receiver</label>
                            <div class="text-white fw-bold">${order.receiverName}</div>
                        </div>
                    </div>
                    <div class="p-3 rounded bg-dark border border-secondary border-opacity-10 mb-4">
                        <label class="text-secondary x-small text-uppercase ls-1 d-block mb-2">Internal Notes / Reason</label>
                        <div class="text-white small">${order.notes || 'No detailed notes provided.'}</div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded bg-dark-soft border border-secondary border-opacity-10">
                        <div>
                            <div class="text-secondary x-small text-uppercase">Current Status</div>
                            <div class="fw-bold text-white">${order.status}</div>
                        </div>
                        <div class="text-end">
                            <div class="text-secondary x-small text-uppercase">Delivery Attempts</div>
                            <div class="fw-bold text-orange">${order.deliveryAttempts}</div>
                        </div>
                    </div>
                `;
            });
    }

    function confirmArchiveReturn(requestId, trackingId) {
        document.getElementById('archiveTrackingId').innerText = trackingId;
        document.getElementById('archiveRequestIdInput').value = requestId;
        const modal = new bootstrap.Modal(document.getElementById('archiveReturnModal'));
        modal.show();
    }
</script>

<style>
    .bg-orange { background-color: #ff8c00 !important; }
    .x-small { font-size: 0.75rem; }
</style>
