@using System
@using System.Linq
@model IEnumerable<SwiftFill.Models.Order>
@{
    ViewData["Title"] = "Order Management";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-geo-alt-fill text-orange me-2"></i> Order Management</h2>
        <div>
            @if (TempData["SuccessMessage"] != null)
            {
                <span class="badge bg-success me-3 p-2">@TempData["SuccessMessage"]</span>
            }
        </div>
    </div>

    <!-- Integrated Filter Bar (Reference-Matched) -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px;">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           placeholder="Search Tracking ID, Sender, or Receiver...">
                </div>
            </form>
        
        </div>

        <div class="d-flex align-items-center gap-4">
            <!-- Filter Dropdowns Grouped -->
            <form method="get" class="d-flex align-items-center gap-3">
                <select name="status" class="minimal-input" style="width: 150px; background: transparent; border: none;" onchange="this.form.submit()">
                    <option value="All">Status</option>
                    <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                    <option value="Transit" selected="@(ViewBag.Status == "Transit")">In Transit</option>
                    <option value="Delivered" selected="@(ViewBag.Status == "Delivered")">Delivered</option>
                </select>
                <select name="region" class="minimal-input" style="width: 130px; background: transparent; border: none;" onchange="this.form.submit()">
                    <option value="All">Region</option>
                    <option value="NCR" selected="@(ViewBag.Region == "NCR")">NCR</option>
                    <option value="Luzon" selected="@(ViewBag.Region == "Luzon")">Luzon</option>
                    <option value="Visayas" selected="@(ViewBag.Region == "Visayas")">Visayas</option>
                    <option value="Mindanao" selected="@(ViewBag.Region == "Mindanao")">Mindanao</option>
                </select>
            </form>
            <button type="button" class="btn btn-primary px-4 py-2 shadow-sm border-0 d-flex align-items-center" 
                    style="background: #FF8C00; border-radius: 8px; font-weight: 600; font-size: 0.85rem;" 
                    data-bs-toggle="modal" data-bs-target="#manualOrderModal">
                <i class="bi bi-plus-lg me-2"></i> Add Order
            </button>

        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr>
                        <th class="ps-4 py-3">Shipment Identity</th>
                        <th class="py-3">Logistics Detail</th>
                        <th class="py-3">Handling</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="me-3">
                                        <code class="text-orange fw-bold d-block">@order.TrackingId</code>
                                        <div class="text-white small">@order.SenderName</div>
                                    </div>
                                    <div class="border-start border-secondary border-opacity-25 ps-3">
                                        <div class="text-secondary x-small">To Receive By:</div>
                                        <div class="text-white small">@order.ReceiverName</div>
                                        <div class="text-secondary x-small"><i class="bi bi-geo-alt me-1"></i>@order.ReceiverAddress</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="text-white small">@order.DestinationRegion</div>
                                <div class="text-secondary x-small">@order.Weight kg | @(order.ItemCategory ?? "General")</div>
                                @if (order.IsFragile)
                                {
                                    <span class="badge bg-warning text-dark mt-1" style="font-size: 0.6rem;"><i class="bi bi-exclamation-triangle-fill me-1"></i>FRAGILE</span>
                                }
                                @if (order.Payment != null)
                                {
                                    <div class="mt-1">
                                        <span class="text-warning fw-bold" style="font-size: 0.7rem;">₱@order.Payment.Amount.ToString("N2")</span>
                                        <span class="text-secondary mx-1">•</span>
                                        <span class="x-small text-secondary">@order.Payment.Method</span>
                                    </div>
                                }
                            </td>
                            <td class="py-3">
                                <div class="d-flex flex-column gap-1">
                                    <span class="badge border bg-transparent x-small px-2 w-fit
                                        @(order.DeliveryType == "BranchPickup" ? "border-info text-info" : "border-warning text-warning")">
                                        <i class="bi @(order.DeliveryType == "BranchPickup" ? "bi-building" : "bi-truck") me-1"></i>
                                        @(order.DeliveryType == "BranchPickup" ? "Pickup" : "D2D")
                                    </span>
                                    <span class="text-secondary x-small"><i class="bi bi-geo-alt-fill me-1"></i> @order.CurrentLocation</span>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="badge border bg-transparent px-2 py-1 @(order.Status == "Delivered" ? "border-success text-success" : (order.Status.Contains("Arrived") ? "border-primary text-primary" : (order.Status.Contains("Transit") ? "border-info text-info" : "border-warning text-warning")))" style="font-size: 0.65rem;">
                                    @order.Status
                                </span>
                            </td>
                            <td class="py-3 pe-4 text-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <button type="button" class="btn btn-sm btn-outline-secondary border-0 p-1" onclick="viewOrderDetails('@order.TrackingId')">
                                        <i class="bi bi-file-earmark-text"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-warning border-0 p-1" onclick="editOrder('@order.TrackingId')">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger border-0 p-1" onclick="confirmArchive('@order.TrackingId')">
                                        <i class="bi bi-archive"></i>
                                    </button>
                                </div>
                                <div class="x-small text-secondary mt-1">@order.UpdatedAt.ToString("MMM dd HH:mm")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search&status=@ViewBag.Status&region=@ViewBag.Region">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search&status=@ViewBag.Status&region=@ViewBag.Region">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search&status=@ViewBag.Status&region=@ViewBag.Region">Next</a>
                </li>
            </ul>
        </div>
    }

<!-- View Order Details Modal -->
<div class="modal fade" id="orderDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: #0a0a0a; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05) !important;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-file-earmark-text text-warning me-2"></i> Shipment Waybill</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="orderDetailsContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-warning" role="status"></div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning fw-bold" onclick="window.print()">Print Waybill</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Order Modal -->
<div class="modal fade" id="editOrderModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: #0f0f0f; border-radius: 16px; border: 1px solid rgba(255,140,0,0.1) !important;">
            <div class="modal-header border-0">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-pencil-square text-orange me-2"></i> Update Shipment Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-0">
                <form asp-action="EditOrder" method="post" id="editOrderForm">
                    <input type="hidden" name="TrackingId" id="editTrackingId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <h6 class="text-secondary x-small text-uppercase mb-3">Sender Details</h6>
                            <input type="text" name="SenderName" id="editSenderName" class="minimal-input w-100 mb-2" placeholder="Full Name" required>
                            <input type="text" name="SenderPhone" id="editSenderPhone" class="minimal-input w-100 mb-2" placeholder="Phone Number" required maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);">
                            <textarea name="SenderAddress" id="editSenderAddress" class="minimal-input w-100" placeholder="Pickup Address" rows="2" required></textarea>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-secondary x-small text-uppercase mb-3">Receiver Details</h6>
                            <input type="text" name="ReceiverName" id="editReceiverName" class="minimal-input w-100 mb-2" placeholder="Full Name" required>
                            <input type="text" name="ReceiverPhone" id="editReceiverPhone" class="minimal-input w-100 mb-2" placeholder="Phone Number" required maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);">
                            <textarea name="ReceiverAddress" id="editReceiverAddress" class="minimal-input w-100" placeholder="Delivery Address" rows="2" required></textarea>
                        </div>
                        <div class="col-12"><hr class="border-white border-opacity-5"></div>
                        <div class="col-md-3">
                            <label class="text-secondary x-small mb-1">Weight (kg)</label>
                            <input type="number" name="Weight" id="editWeight" class="minimal-input w-100" step="0.1" required>
                        </div>
                        <div class="col-md-3">
                            <label class="text-secondary x-small mb-1">Category</label>
                            <select name="ItemCategory" id="editCategory" class="minimal-input w-100">
                                @foreach (var cat in (List<SwiftFill.Models.ItemCategory>)(ViewBag.ItemCategories ?? new List<SwiftFill.Models.ItemCategory>()))
                                {
                                    <option value="@cat.Name">@cat.Name</option>
                                }
                                @if (!(ViewBag.ItemCategories as List<SwiftFill.Models.ItemCategory>)?.Any() ?? true)
                                {
                                    <option value="General Merchandise">General Merchandise</option>
                                    <option value="Electronics">Electronics</option>
                                    <option value="Apparel">Apparel</option>
                                    <option value="Documents">Documents</option>
                                }
                            </select>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" name="IsFragile" id="editIsFragile" value="true">
                                <label class="form-check-label text-warning small" for="editIsFragile"><i class="bi bi-exclamation-triangle me-1"></i> Fragile Item</label>
                            </div>
                        </div>
                        @* Removed Value (PHP) as per request *@
                        <div class="col-md-3">
                            <label class="text-secondary x-small mb-1">Destination</label>
                            <select name="DestinationRegion" id="editRegion" class="minimal-input w-100" required onchange="calculateEditPrice()">
                                <option value="NCR">Metro Manila</option>
                                <option value="Luzon">Luzon</option>
                                <option value="Visayas">Visayas</option>
                                <option value="Mindanao">Mindanao</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="text-secondary x-small mb-1">Packing Services</label>
                            <div class="p-2 rounded bg-dark border border-secondary border-opacity-10">
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" name="AvailPacking" id="editAvailPacking" value="true" onchange="calculateEditPrice()">
                                    <label class="form-check-label text-white-50 x-small" for="editAvailPacking">Apply Packing</label>
                                </div>
                                <input type="number" name="PackingFee" id="editPackingFee" class="minimal-input text-end w-100 mt-2" style="font-size: 0.75rem;" value="0" oninput="calculateEditPrice()">
                            </div>
                        </div>
                        <div class="col-12 mt-4">
                            <div class="d-flex justify-content-between align-items-center p-3 rounded" style="background: rgba(255,140,0,0.05); border: 1px solid rgba(255,140,0,0.2);">
                                <div>
                                    <label class="text-secondary x-small mb-1 d-block">Calculated Shipping Fee</label>
                                    <div class="fw-bold text-orange fs-5" id="editCalculatedPrice">₱0.00</div>
                                </div>
                                <div style="width: 250px;">
                                    <label class="text-secondary x-small mb-1">Payment Mode</label>
                                    <select name="PaymentMethod" id="editPaymentMethod" class="minimal-input w-100 text-orange fw-bold">
                                        @foreach (var method in (List<SwiftFill.Models.PaymentMethod>)(ViewBag.PaymentMethods ?? new List<SwiftFill.Models.PaymentMethod>()))
                                        {
                                            <option value="@method.Name">@method.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="editOrderForm" class="btn btn-primary px-4 fw-bold" style="background:#FF8C00;">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Archive Confirmation Modal -->
<div class="modal fade" id="archiveModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg" style="background: #0a0a0a; border-radius: 16px; border: 1px solid rgba(220,53,69,0.2) !important;">
            <div class="modal-body text-center p-4">
                <div class="display-4 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></div>
                <h5 class="text-white fw-bold mb-2">Archive Shipment?</h5>
                <p class="text-secondary small mb-4">Are you sure you want to archive <strong id="archiveTrackingId" class="text-white"></strong>? This will remove it from active management.</p>
                <form asp-action="ArchiveOrder" method="post" id="archiveForm">
                    <input type="hidden" name="trackingId" id="archiveTrackingIdInput" />
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-dark flex-fill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger flex-fill fw-bold">Yes, Archive</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Manual Order Multi-Step Modal -->
<div class="modal fade" id="manualOrderModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="background: #0f0f0f; border-radius: 16px; border: 1px solid rgba(255,140,0,0.1) !important;">
            <div class="modal-header border-0 pb-0">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-orange d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-plus-lg text-black fs-5"></i>
                    </div>
                    <div>
                        <h5 class="modal-title text-white fw-bold mb-0">Create New Shipment</h5>
                        <p class="text-secondary x-small mb-0">Manual booking for walk-in customers</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Progress Stepper -->
                <div class="d-flex justify-content-center mb-4 gap-2">
                    <div id="dot1" class="step-dot active"></div>
                    <div id="dot2" class="step-dot"></div>
                    <div id="dot3" class="step-dot"></div>
                    <div id="dot4" class="step-dot"></div>
                </div>

                <form asp-action="CreateManualOrder" method="post" id="manualOrderForm">
                    <!-- Step 1: Core Specs -->
                    <div id="step1" class="animate-fade-in">
                        <h6 class="text-white mb-3"><i class="bi bi-1-circle text-orange me-2"></i> Logistics Core</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="text-secondary x-small mb-2 d-block">Origin Hub</label>
                                <input type="text" class="minimal-input w-100" value="Davao Hub" readonly style="background: rgba(255,255,255,0.03); cursor: not-allowed; border-color: rgba(255,140,0,0.2);">
                                <input type="hidden" name="originHub" value="Davao Hub">
                            </div>
                            <div class="col-md-6">
                                <label class="text-secondary x-small mb-2 d-block">Destination Region</label>
                                <select name="DestinationRegion" class="minimal-input w-100" required>
                                    <option value="NCR">Metro Manila (NCR)</option>
                                    <option value="Luzon">Luzon Region</option>
                                    <option value="Visayas">Visayas Region</option>
                                    <option value="Mindanao">Mindanao Region</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="text-secondary x-small mb-3 d-block">Delivery Mode</label>
                                <div class="row g-3">
                                    <div class="col-6">
                                        <input type="radio" class="btn-check" name="deliveryType" id="modeD2D" value="DoorToDoor" checked>
                                        <label class="btn btn-outline-secondary delivery-type-card p-3 w-100 text-start border-secondary border-opacity-10" for="modeD2D">
                                            <i class="bi bi-house-door text-orange fs-4 d-block mb-2"></i>
                                            <div class="text-white fw-bold small">Door-to-Door</div>
                                            <div class="text-secondary x-small">Delivery to receiver address</div>
                                        </label>
                                    </div>
                                    <div class="col-6">
                                        <input type="radio" class="btn-check" name="deliveryType" id="modePickup" value="BranchPickup">
                                        <label class="btn btn-outline-secondary delivery-type-card p-3 w-100 text-start border-secondary border-opacity-10" for="modePickup">
                                            <i class="bi bi-building text-orange fs-4 d-block mb-2"></i>
                                            <div class="text-white fw-bold small">Branch Pickup</div>
                                            <div class="text-secondary x-small">Claim at destination hub</div>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Sender -->
                    <div id="step2" class="d-none animate-fade-in">
                        <h6 class="text-white mb-3"><i class="bi bi-2-circle text-orange me-2"></i> Sender Information</h6>
                        <div class="v-group"><input type="text" name="SenderName" class="minimal-input w-100 mb-3" placeholder="Full Name" required></div>
                        <div class="v-group"><input type="text" name="SenderPhone" class="minimal-input w-100 mb-3" placeholder="09XXXXXXXXX" required maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);"></div>
                        <div class="v-group"><textarea name="SenderAddress" class="minimal-input w-100" placeholder="Street Address, Barangay, City" rows="3" required></textarea></div>
                    </div>

                    <!-- Step 3: Receiver -->
                    <div id="step3" class="d-none animate-fade-in">
                        <h6 class="text-white mb-3"><i class="bi bi-3-circle text-orange me-2"></i> Receiver Information</h6>
                        <div class="v-group"><input type="text" name="ReceiverName" class="minimal-input w-100 mb-3" placeholder="Full Name" required></div>
                        <div class="v-group"><input type="text" name="ReceiverPhone" class="minimal-input w-100 mb-3" placeholder="09XXXXXXXXX" required maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);"></div>
                        <div class="v-group"><textarea name="ReceiverAddress" class="minimal-input w-100 mb-3" placeholder="Complete Delivery Address" rows="3" required></textarea></div>
                        <div class="v-group"><input type="text" name="ReceiverLandmark" class="minimal-input w-100" placeholder="Landmark (e.g. Near City Hall)" required></div>
                    </div>

                    <!-- Step 4: Package & Payment -->
                    <div id="step4" class="d-none animate-fade-in">
                        <h6 class="text-white mb-3"><i class="bi bi-4-circle text-orange me-2"></i> Package & Payment</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="text-secondary x-small mb-1">Weight (kg)</label>
                                <input type="number" name="Weight" class="minimal-input w-100" step="0.1" value="1.0" required>
                            </div>
                            <div class="col-md-6">
                                <label class="text-secondary x-small mb-1">Item Category</label>
                                <select name="ItemCategory" class="minimal-input w-100" id="manCategorySelect">
                                    @foreach (var cat in (List<SwiftFill.Models.ItemCategory>)(ViewBag.ItemCategories ?? new List<SwiftFill.Models.ItemCategory>()))
                                    {
                                        <option value="@cat.Name">@cat.Name</option>
                                    }
                                    @if (!(ViewBag.ItemCategories as List<SwiftFill.Models.ItemCategory>)?.Any() ?? true)
                                    {
                                        <option value="General Merchandise">General Merchandise</option>
                                        <option value="Electronics">Electronics</option>
                                        <option value="Apparel">Apparel</option>
                                        <option value="Documents">Documents</option>
                                    }
                                </select>
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" name="isFragile" id="manIsFragile" value="true">
                                    <label class="form-check-label text-warning small" for="manIsFragile"><i class="bi bi-exclamation-triangle me-1"></i> Fragile Item</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="text-secondary x-small mb-1">Payment Method</label>
                                <select name="paymentMethod" class="minimal-input w-100 fw-bold text-orange">
                                    @foreach (var method in (List<SwiftFill.Models.PaymentMethod>)(ViewBag.PaymentMethods ?? new List<SwiftFill.Models.PaymentMethod>()))
                                    {
                                        <option value="@method.Name">@method.Name (@(method.Description ?? "No description"))</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <div class="p-3 rounded bg-dark border border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" name="availPacking" id="manAvailPacking" value="true">
                                        <label class="form-check-label text-white small" for="manAvailPacking">Apply Packing Services</label>
                                    </div>
                                    <input type="number" name="packingFee" id="manPackingFee" class="minimal-input text-end" style="width: 100px;" value="50" placeholder="Fee">
                                </div>
                            </div>
                            <div class="col-12" id="manPriceEstimator" style="display:none;">
                                <div class="p-3 rounded mt-2 border border-opacity-25" style="background: rgba(255,140,0,0.05); border-color: #ff8c00 !important;">
                                    <div class="text-secondary x-small text-uppercase mb-1">Estimated Total</div>
                                    <div class="fw-bold text-orange fs-5">₱<span id="manEstTotal">0.00</span></div>
                                    <div class="text-white-50 x-small">Base + Weight + Zone + Packing</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-dark px-4" id="prevBtn" style="display: none;">Back</button>
                <button type="button" class="btn btn-primary px-4 fw-bold" id="nextBtn" style="background:#FF8C00;">Continue</button>
                <button type="submit" form="manualOrderForm" class="btn btn-primary px-4 fw-bold" id="submitOrderBtn" style="background:#FF8C00; display: none;">Book Shipment</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Manual Order Stepper
        const nextBtn = document.getElementById('nextBtn');
        const prevBtn = document.getElementById('prevBtn');
        const submitBtn = document.getElementById('submitOrderBtn');
        const totalSteps = 4;
        let currentStep = 1;

        if (nextBtn) {
            nextBtn.addEventListener('click', () => {
                // Validation: Check if current step's required inputs are filled
                const currentStepDiv = document.getElementById(`step${currentStep}`);
                const inputs = currentStepDiv.querySelectorAll('input[required], select[required], textarea[required]');
                let isValid = true;

                // Clear existing error messages
                currentStepDiv.querySelectorAll('.error-tooltip-v2').forEach(el => el.remove());

                inputs.forEach(input => {
                    let fieldValid = true;
                    let title = "";
                    let subtitle = "";
                    const val = input.value.trim();

                    if (!val) {
                        fieldValid = false;
                        title = "Please fill out this field.";
                    } else if (input.name.toLowerCase().includes('phone')) {
                        const digits = val.replace(/\D/g, '');
                        if (digits.length !== 11) {
                            fieldValid = false;
                            title = "Please match the requested format.";
                            subtitle = "Phone number must be exactly 11 digits";
                        }
                    }

                    if (!fieldValid) {
                        isValid = false;
                        input.style.borderColor = '#FF8C00'; // Match theme orange
                        input.classList.add('animate-shake');
                        
                        // Create Tooltip Container
                        const tooltip = document.createElement('div');
                        tooltip.className = 'error-tooltip-v2';
                        tooltip.innerHTML = `
                            <div class="error-arrow"></div>
                            <div class="error-body">
                                <div class="error-icon-box">
                                    <i class="bi bi-exclamation-square-fill"></i>
                                </div>
                                <div class="error-text-box">
                                    <div class="error-title-v2">${title}</div>
                                    ${subtitle ? `<div class="error-subtitle-v2">${subtitle}</div>` : ''}
                                </div>
                            </div>
                        `;
                        
                        input.parentNode.appendChild(tooltip);
                        
                        setTimeout(() => input.classList.remove('animate-shake'), 500);
                    } else {
                        input.style.borderColor = ''; // Reset if valid
                    }
                });

                if (!isValid) {
                    // Optional: Show a small toast or message
                    return;
                }

                if (currentStep < totalSteps) {
                    document.getElementById(`step${currentStep}`).classList.add('d-none');
                    document.getElementById(`dot${currentStep}`).classList.remove('active');
                    currentStep++;
                    document.getElementById(`step${currentStep}`).classList.remove('d-none');
                    document.getElementById(`dot${currentStep}`).classList.add('active');
                }

                if (currentStep === totalSteps) {
                    nextBtn.style.display = 'none';
                    submitBtn.style.display = 'block';
                }
                prevBtn.style.display = 'block';
            });
        }

        if (prevBtn) {
            prevBtn.addEventListener('click', () => {
                if (currentStep > 1) {
                    document.getElementById(`step${currentStep}`).classList.add('d-none');
                    document.getElementById(`dot${currentStep}`).classList.remove('active');
                    currentStep--;
                    document.getElementById(`step${currentStep}`).classList.remove('d-none');
                    document.getElementById(`dot${currentStep}`).classList.add('active');
                }

                if (currentStep < totalSteps) {
                    nextBtn.style.display = 'block';
                    submitBtn.style.display = 'none';
                }
                if (currentStep === 1) {
                    prevBtn.style.display = 'none';
                }
            });
        }
    });

    function viewOrderDetails(trackingId) {
        const modal = new bootstrap.Modal(document.getElementById('orderDetailsModal'));
        const content = document.getElementById('orderDetailsContent');
        content.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-warning" role="status"></div></div>';
        modal.show();

        fetch(`/Admin/GetOrderJson?trackingId=${trackingId}`)
            .then(r => r.json())
            .then(order => {
                content.innerHTML = `
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="p-3 rounded bg-dark border border-secondary border-opacity-10">
                                <label class="text-secondary x-small text-uppercase ls-1 d-block mb-2">Sender</label>
                                <div class="fw-bold text-white fs-5">${order.senderName}</div>
                                <div class="text-secondary small mb-1">${order.senderAddress}</div>
                                <div class="text-warning small">${order.senderPhone}</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 rounded bg-dark border border-secondary border-opacity-10">
                                <label class="text-secondary x-small text-uppercase ls-1 d-block mb-2">Receiver</label>
                                <div class="fw-bold text-white fs-5">${order.receiverName}</div>
                                <div class="text-secondary small mb-1">${order.receiverAddress}</div>
                                <div class="text-warning small">${order.receiverPhone}</div>
                            </div>
                        </div>
                    </div>
                    <div class="p-3 rounded bg-dark border border-secondary border-opacity-10 mb-4">
                        <label class="text-secondary x-small text-uppercase ls-1 d-block mb-3">Package Telemetry</label>
                        <div class="row text-center">
                            <div class="col-4">
                                <div class="text-secondary x-small">Weight</div>
                                <div class="fw-bold text-white">${order.weight} kg</div>
                            </div>
                            <div class="col-4">
                                <div class="text-secondary x-small">Category</div>
                                <div class="fw-bold text-white">${order.itemCategory || 'General'}</div>
                            </div>
                            <div class="col-4">
                                <div class="text-secondary x-small">Hub Origin</div>
                                <div class="fw-bold text-white">${order.originHub}</div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded bg-dark-soft border border-warning border-opacity-20">
                        <div>
                            <div class="text-secondary x-small text-uppercase">Payment Amount</div>
                            <div class="fw-bold text-warning fs-4">₱${(order.payment?.amount || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</div>
                        </div>
                        <div class="text-end">
                            <div class="text-secondary x-small text-uppercase">Payment Method</div>
                            <div class="fw-bold text-white">${order.payment?.method || 'Unspecified'}</div>
                            <span class="badge ${order.payment?.isPaid ? 'bg-success' : 'bg-danger'} p-1 px-2" style="font-size:0.6rem">
                                ${order.payment?.isPaid ? 'PAID' : 'UNPAID'}
                            </span>
                        </div>
                    </div>
                    <div class="text-center mt-5">
                        <div class="barcode-sim mx-auto mb-2" style="height: 40px; width: 200px; background: repeating-linear-gradient(90deg, #fff, #fff 2px, #000 2px, #000 4px);"></div>
                        <code class="fs-4 text-white">${order.trackingId}</code>
                    </div>
                `;
            });
    }

    function editOrder(trackingId) {
        const modal = new bootstrap.Modal(document.getElementById('editOrderModal'));
        modal.show();

        fetch(`/Admin/GetOrderJson?trackingId=${trackingId}`)
            .then(r => r.json())
            .then(order => {
                document.getElementById('editTrackingId').value = order.trackingId;
                document.getElementById('editSenderName').value = order.senderName;
                document.getElementById('editSenderPhone').value = order.senderPhone;
                document.getElementById('editSenderAddress').value = order.senderAddress;
                document.getElementById('editReceiverName').value = order.receiverName;
                document.getElementById('editReceiverPhone').value = order.receiverPhone;
                document.getElementById('editReceiverAddress').value = order.receiverAddress;
                document.getElementById('editWeight').value = order.weight;
                document.getElementById('editCategory').value = order.itemCategory;
                document.getElementById('editIsFragile').checked = order.isFragile;
                document.getElementById('editAvailPacking').checked = order.availPacking;
                // document.getElementById('editValue').value = order.declaredValue;
                document.getElementById('editRegion').value = order.destinationRegion;
                 document.getElementById('editPaymentMethod').value = order.payment?.method || 'Pending Hub Verification';
                 document.getElementById('editPackingFee').value = order.packingFee || 0;
                 calculateEditPrice();
            });
    }

    let dbShippingRates = {};

    function loadShippingRates() {
        fetch('/Admin/GetShippingRatesJson')
            .then(r => r.json())
            .then(rates => {
                rates.forEach(r => {
                    dbShippingRates[r.destinationRegion] = {
                        base: r.baseRate,
                        perKg: r.pricePerKg,
                        zone: r.zoneSurcharge
                    };
                });
            });
    }

    function calculateEditPrice() {
        const weightEl = document.getElementById('editWeight');
        const regionEl = document.getElementById('editRegion');
        const priceEl = document.getElementById('editCalculatedPrice');
        const packingFeeEl = document.getElementById('editPackingFee');
        if (!weightEl || !regionEl || !priceEl || !packingFeeEl) return;

        const weight = parseFloat(weightEl.value) || 0;
        const region = regionEl.value;
        const isPackingChecked = document.getElementById('editAvailPacking').checked;
        const packingFee = isPackingChecked ? (parseFloat(packingFeeEl.value) || 0) : 0;
        const rate = dbShippingRates[region];
        
        if (rate) {
            const total = rate.base + (weight * rate.perKg) + rate.zone + packingFee;
            priceEl.textContent = '₱' + total.toLocaleString('en-US', { minimumFractionDigits: 2 });
        } else {
            // Fallback estimate if rates haven't loaded yet
            const fallback = 150 + (weight * 45) + packingFee;
            priceEl.textContent = '₱' + fallback.toLocaleString('en-US', { minimumFractionDigits: 2 });
        }
    }

    // Event listener moved to DOMContentLoaded block below

    function confirmArchive(trackingId) {
        const modal = new bootstrap.Modal(document.getElementById('archiveModal'));
        document.getElementById('archiveTrackingId').textContent = trackingId;
        document.getElementById('archiveTrackingIdInput').value = trackingId;
        modal.show();
    }

    // Item 4: Dynamic price estimator for the Add Order modal
    (function() {
        const regionBaseRates = { NCR: { base: 100, perKg: 45, zone: 50 }, Luzon: { base: 100, perKg: 45, zone: 100 }, Visayas: { base: 100, perKg: 45, zone: 150 }, Mindanao: { base: 100, perKg: 45, zone: 200 } };
        function calcManualOrder() {
            const regionEl = document.querySelector('#manualOrderForm select[name="DestinationRegion"]');
            const weightEl = document.querySelector('#manualOrderForm input[name="Weight"]');
            const packingEl = document.getElementById('manAvailPacking');
            const packFeeEl = document.getElementById('manPackingFee');
            const estimatorEl = document.getElementById('manPriceEstimator');
            const totalEl = document.getElementById('manEstTotal');
            if (!regionEl || !weightEl) return;
            const region = regionEl.value;
            const weight = parseFloat(weightEl.value) || 0;
            const packing = packingEl?.checked ? (parseFloat(packFeeEl?.value) || 0) : 0;
            const r = regionBaseRates[region];
            if (!r || weight <= 0) { estimatorEl.style.display = 'none'; return; }
            const total = r.base + (weight * r.perKg) + r.zone + packing;
            totalEl.textContent = total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            estimatorEl.style.display = 'block';
        }
        document.addEventListener('DOMContentLoaded', function() {
            loadShippingRates(); // Fetch actual rates from DB
            
            const form = document.getElementById('manualOrderForm');
            if (form) {
                form.addEventListener('input', calcManualOrder);
                form.addEventListener('change', calcManualOrder);
            }

            const editWeight = document.getElementById('editWeight');
            if (editWeight) {
                editWeight.addEventListener('input', calculateEditPrice);
            }
        });
    })();
</script>

<style>
    .bg-orange { background-color: #ff8c00 !important; }
    .ls-1 { letter-spacing: 1px; }
    .x-small { font-size: 0.75rem; }
    .delivery-type-card { transition: all 0.2s; }
    .btn-check:checked + .delivery-type-card {
        border-color: #ff8c00 !important;
        background: rgba(255,140,0,0.06) !important;
        box-shadow: 0 0 0 2px rgba(255,140,0,0.3);
    }
    .bg-dark-soft { background: rgba(255,255,255,0.02); }
    .ls-2 { letter-spacing: 2px; }
    
    .step-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.1); transition: all 0.3s; }
    .step-dot.active { background: #FF8C00; box-shadow: 0 0 10px rgba(255,140,0,0.5); width: 24px; border-radius: 4px; }
    .animate-fade-in { animation: fadeIn 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    
    .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; transform: translate3d(0, 0, 0); backface-visibility: hidden; perspective: 1000px; }
    @@keyframes shake { 10%, 90% { transform: translate3d(-1px, 0, 0); } 20%, 80% { transform: translate3d(2px, 0, 0); } 30%, 50%, 70% { transform: translate3d(-4px, 0, 0); } 40%, 60% { transform: translate3d(4px, 0, 0); } }

    .v-group { position: relative; width: 100%; }

    /* Premium Error Tooltip (V2) */
    .error-tooltip-v2 {
        position: absolute;
        bottom: 0px;
        left: 50%;
        transform: translate(-50%, 100%);
        margin-top: 5px;
        z-index: 1050;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.3));
        pointer-events: none;
        animation: tooltipIn 0.2s ease-out;
    }
    @@keyframes tooltipIn { from { opacity: 0; transform: translate(-50%, -5px); } to { opacity: 1; transform: translate(-50%, 0); } }

    .error-arrow {
        width: 0; height: 0;
        border-left: 8px solid transparent;
        border-right: 8px solid transparent;
        border-bottom: 8px solid #ffffff;
        margin: 0 auto;
    }

    .error-body {
        background: #ffffff;
        border-radius: 6px;
        padding: 8px 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 250px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .error-icon-box {
        color: #FF8C00;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
    }

    .error-text-box {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .error-title-v2 {
        color: #000000;
        font-size: 0.85rem;
        font-weight: 400;
        white-space: nowrap;
    }

    .error-subtitle-v2 {
        color: #666666;
        font-size: 0.75rem;
        font-weight: 400;
    }
    
    @@media print {
        body * { visibility: hidden; }
        #orderDetailsContent, #orderDetailsContent * { visibility: visible; }
        #orderDetailsContent { position: absolute; left: 0; top: 0; width: 100%; color: black !important; background: white !important; }
        #orderDetailsContent .bg-dark { background: white !important; border-color: #eee !important; color: black !important; }
        #orderDetailsContent .text-white { color: black !important; }
        #orderDetailsContent .text-secondary { color: #666 !important; }
        #orderDetailsContent .barcode-sim { background: repeating-linear-gradient(90deg, #000, #000 2px, #fff 2px, #fff 4px) !important; }
    }
</style>
