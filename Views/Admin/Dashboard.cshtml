@using System
@using System.Linq
@model SwiftFill.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-speedometer2 me-2"></i> System Overview</h1>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-6 col-md-3">
            <a asp-action="Shipments" class="text-decoration-none h-100 d-block hover-scale">
                <div class="glass-card active-border-orange p-4 h-100 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label text-orange fw-bold">TOTAL ORDERS</div>
                        <div class="stat-subtitle mt-1">Active Table</div>
                    </div>
                    <div class="stat-value text-white display-6 fw-bold mb-0">@Model.TotalOrders</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Pack" class="text-decoration-none h-100 d-block hover-scale">
                <div class="glass-card p-4 h-100 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label text-info fw-bold">ORDER PACKING</div>
                        <div class="stat-subtitle mt-1">In Processing</div>
                    </div>
                    <div class="stat-value text-white display-6 fw-bold mb-0">@Model.PackingCount</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Payments" class="text-decoration-none h-100 d-block hover-scale">
                <div class="glass-card p-4 h-100 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label text-success fw-bold">TOTAL REVENUE</div>
                        <div class="stat-subtitle mt-1">Settled Only</div>
                    </div>
                    <div class="stat-value text-white display-6 fw-bold mb-0">₱@Model.TotalRevenue.ToString("N0")</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Returns" class="text-decoration-none h-100 d-block hover-scale">
                <div class="glass-card p-4 h-100 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label text-danger fw-bold">RETURN ORDERS</div>
                        <div class="stat-subtitle mt-1">Pending Action</div>
                    </div>
                    <div class="stat-value text-white display-6 fw-bold mb-0">@Model.TotalReturns</div>
                </div>
            </a>
        </div>
    </div>

    <!-- Quick Actions -->
    <h6 class="text-uppercase text-secondary ls-1 mb-3">Quick Logistics Actions</h6>
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-3">
            <a asp-action="Shipments" class="glass-card p-3 d-flex flex-column flex-md-row align-items-center text-decoration-none hover-scale h-100" style="background: rgba(255,140,0,0.05); border: 1px solid rgba(255,140,0,0.2);">
                <div class="rounded-circle bg-orange p-2 mb-2 mb-md-0 me-md-3"><i class="bi bi-box-seam text-dark"></i></div>
                <div class="text-white fw-bold x-small text-center text-md-start">New Shipment</div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Payments" class="glass-card p-3 d-flex flex-column flex-md-row align-items-center text-decoration-none hover-scale h-100" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                <div class="rounded-circle bg-dark p-2 mb-2 mb-md-0 me-md-3"><i class="bi bi-receipt text-orange"></i></div>
                <div class="text-white fw-bold x-small text-center text-md-start">Audit Payments</div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Reports" class="glass-card p-3 d-flex flex-column flex-md-row align-items-center text-decoration-none hover-scale h-100" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                <div class="rounded-circle bg-dark p-2 mb-2 mb-md-0 me-md-3"><i class="bi bi-file-earmark-bar-graph text-orange"></i></div>
                <div class="text-white fw-bold x-small text-center text-md-start">Analytical Reports</div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Account" asp-action="Settings" class="glass-card p-3 d-flex flex-column flex-md-row align-items-center text-decoration-none hover-scale h-100" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                <div class="rounded-circle bg-dark p-2 mb-2 mb-md-0 me-md-3"><i class="bi bi-gear-fill text-orange"></i></div>
                <div class="text-white fw-bold x-small text-center text-md-start">Settings</div>
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- Main Chart -->
        <div class="col-md-8">
            <div class="glass-card p-4 border-0 h-100" style="background: rgba(255, 255, 255, 0.01);">
                <h6 class="text-uppercase text-secondary ls-1 mb-4">Volume Trends</h6>
                <canvas id="trendChart" style="max-height: 280px;"></canvas>
            </div>
        </div>
        <!-- Side Chart -->
        <div class="col-md-4">
            <div class="glass-card p-4 border-0 h-100" style="background: rgba(255, 255, 255, 0.01);">
                <h6 class="text-uppercase text-secondary ls-1 mb-4">Lifecycle State</h6>
                <canvas id="statusChart" style="max-height: 280px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Shipment Summary -->
    <div class="glass-card p-0 overflow-hidden border-0 mb-5" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05) !important;">
        <div class="d-flex justify-content-between align-items-center p-4 pb-3">
            <h6 class="text-uppercase text-secondary ls-1 mb-0">Track Shipment Summary</h6>
            <a asp-action="Shipments" class="text-orange text-decoration-none small">View All <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr class="text-secondary small text-uppercase">
                        <th class="border-0 ps-4 py-3">Tracking ID</th>
                        <th class="border-0 py-3">Destination</th>
                        <th class="border-0 py-3">Status</th>
                        <th class="border-0 text-end pe-4 py-3">Last Updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var shipment in Model.RecentShipments)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                            <td class="border-0 ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div>
                                        <code class="text-orange fw-bold d-block">@shipment.TrackingId</code>
                                        <div class="text-secondary x-small">@shipment.SenderName</div>
                                    </div>
                                </div>
                            </td>
                            <td class="border-0 py-3">
                                <div class="text-white small">@shipment.DestinationRegion</div>
                                <div class="text-secondary x-small">@shipment.ReceiverName</div>
                            </td>
                            <td class="border-0 py-3">
                                <span class="badge border bg-transparent px-3 @(shipment.Status == "Delivered" ? "border-success text-success" : (shipment.Status.Contains("Arrived") ? "border-primary text-primary" : (shipment.Status.Contains("Transit") ? "border-info text-info" : "border-warning text-warning")))" style="font-size: 0.65rem;">
                                    @shipment.Status
                                </span>
                            </td>
                            <td class="border-0 py-3 text-end pe-4">
                                <div class="text-white small">@shipment.CreatedAt.ToString("MMM dd")</div>
                                <div class="x-small text-secondary">@shipment.Weight kg</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .ls-1 { letter-spacing: 1px; }
    .x-small { font-size: 0.75rem; }
    .stat-subtitle { font-size: 0.8rem; color: #3b82f6 !important; font-weight: 500; }
    .stat-label { font-size: 0.7rem; letter-spacing: 0.5px; opacity: 0.9; }
    .hover-scale { transition: transform 0.2s; }
    .hover-scale:hover { transform: translateY(-3px); }
    
    .glass-card {
        background: #0d1117;
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        position: relative;
        overflow: hidden;
    }

    .active-border-orange::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: #ff8c00;
        border-radius: 16px 16px 0 0;
        box-shadow: 0 0 15px rgba(255,140,0,0.2);
    }

    .cursor-pointer { cursor: pointer; }
    .hover-white:hover { color: white !important; }
    .bg-dark-soft { background: rgba(255,255,255,0.02); }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data from ViewModel
        let trendData = @Html.Raw(Json.Serialize(Model.DailyTrend));
        let statusData = @Html.Raw(Json.Serialize(Model.StatusCounts));

        // Trend Chart
        const trendCtx = document.getElementById('trendChart');
        const trendChart = new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: trendData.map(d => d.date),
                datasets: [{
                    label: 'New Orders',
                    data: trendData.map(d => d.count),
                    borderColor: '#ff8c00',
                    backgroundColor: 'rgba(255, 140, 0, 0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 3
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#8b949e' } },
                    x: { grid: { display: false }, ticks: { color: '#8b949e' } }
                }
            }
        });

        // Status Chart
        const statusCtx = document.getElementById('statusChart');
        const statusChart = new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: statusData.map(d => d.status),
                datasets: [{
                    data: statusData.map(d => d.count),
                    backgroundColor: ['#ffc107', '#0dcaf0', '#198754', '#6c757d', '#dc3545', '#ff8c00', '#6f42c1'],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { color: '#8b949e', usePointStyle: true, padding: 20 } }
                },
                cutout: '70%'
            }
        });

        // Real-time updates polling
        async function refreshDashboard() {
            try {
                const response = await fetch('/Admin/GetDashboardStats');
                const data = await response.json();

                // Update Stat Cards
                // Update Stat Cards
                const statValues = document.querySelectorAll('.stat-value');
                statValues[0].textContent = data.totalOrders;
                statValues[1].textContent = data.packingCount;
                statValues[2].textContent = '₱' + data.totalRevenue.toLocaleString('en-US');
                statValues[3].textContent = data.totalReturns;

                // Update Charts
                trendChart.data.labels = data.dailyTrend.map(d => d.date);
                trendChart.data.datasets[0].data = data.dailyTrend.map(d => d.count);
                trendChart.update('none');

                statusChart.data.labels = data.statusCounts.map(d => d.status);
                statusChart.data.datasets[0].data = data.statusCounts.map(d => d.count);
                statusChart.update('none');

                // Update Recent Shipments Table
                const tbody = document.querySelector('table tbody');
                tbody.innerHTML = data.recentShipments.map(s => `
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                        <td class="border-0 ps-4 py-3">
                            <div>
                                <code class="text-orange fw-bold d-block">${s.trackingId}</code>
                                <div class="x-small text-secondary">${s.senderName}</div>
                            </div>
                        </td>
                        <td class="border-0 py-3">
                            <div class="text-white small">${s.destinationRegion}</div>
                            <div class="x-small text-secondary">${s.receiverName}</div>
                        </td>
                        <td class="border-0 py-3">
                            <span class="badge border bg-transparent px-3 ${s.status === 'Delivered' ? 'border-success text-success' : (s.status.includes('Arrived') ? 'border-primary text-primary' : (s.status.includes('Transit') ? 'border-info text-info' : 'border-warning text-warning'))}" style="font-size: 0.65rem;">
                                ${s.status}
                            </span>
                        </td>
                        <td class="border-0 py-3 text-end pe-4">
                            <div class="text-white small">${s.createdAt}</div>
                            <div class="x-small text-secondary">${s.weight} kg</div>
                        </td>
                    </tr>
                `).join('');

                // No longer updating Last Updated timestamp
            } catch (error) {
                console.error('Error refreshing dashboard:', error);
            }
        }

        // Poll every 10 seconds
        setInterval(refreshDashboard, 10000);
    </script>
}
