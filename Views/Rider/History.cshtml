@model IEnumerable<SwiftFill.Models.Order>
@{
    Layout = "_RiderLayout";
    ViewData["Title"] = "History";
}

<style>
    .history-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        transition: all 0.2s;
    }
    .history-card:hover { border-color: rgba(255, 140, 0, 0.2); }
</style>

<div class="animate-fade-up">
    <div class="mb-4">
        <h2 class="fw-bold text-white mb-1">Delivery Log</h2>
        <p class="text-secondary small">History of your completed assignments.</p>
    </div>

    <!-- Summary Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="glass-card p-3 text-center border-0" style="background: rgba(25, 135, 84, 0.05);">
                <div class="smaller text-success fw-bold text-uppercase">Delivered</div>
                <div class="h3 mb-0 fw-bold text-white">@Model.Count(o => o.Status == "Delivered")</div>
            </div>
        </div>
        <div class="col-6">
            <div class="glass-card p-3 text-center border-0" style="background: rgba(220, 53, 69, 0.05);">
                <div class="smaller text-danger fw-bold text-uppercase">Returned</div>
                <div class="h3 mb-0 fw-bold text-white">@Model.Count(o => o.Status == "Returned")</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var order in Model)
        {
            <div class="col-12">
                <div class="history-card p-3 d-flex align-items-center justify-content-between" onclick="viewOrderDetails('@order.TrackingId')" style="cursor: pointer;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" 
                             style="width: 45px; height: 45px; background: @(order.Status == "Delivered" ? "rgba(25, 135, 84, 0.1)" : "rgba(255, 255, 255, 0.05)");">
                            <i class="bi @(order.Status == "Delivered" ? "bi-check-lg text-success" : "bi-arrow-return-left text-secondary") fs-4"></i>
                        </div>
                        <div>
                            <div class="text-white fw-bold">#@order.TrackingId</div>
                            <div class="text-secondary smaller">@order.ReceiverName • @order.UpdatedAt.ToString("MMM dd")</div>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="text-white fw-bold">₱@order.Payment?.Amount.ToString("N0")</div>
                        <i class="bi bi-chevron-right text-secondary small"></i>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="orderDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary" style="border-radius: 20px;">
            <div class="modal-header border-0">
                <h5 class="modal-title text-white fw-bold">Receipt Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalContent">
                <!-- Data loaded via JS -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function viewOrderDetails(trackingId) {
            const modal = new bootstrap.Modal(document.getElementById('orderDetailModal'));
            modal.show();
            $('#modalContent').html('<div class="text-center py-4"><div class="spinner-border text-orange"></div></div>');

            $.get(`/Rider/GetOrderDetails?trackingId=${trackingId}`, function(data) {
                let statusBadge = data.status === "Delivered" ? "text-success" : "text-danger";
                let html = `
                    <div class="text-center mb-4">
                        <div class="text-orange fw-bold h4">#${data.trackingId}</div>
                        <div class="small ${statusBadge} text-uppercase fw-bold">${data.status}</div>
                    </div>
                    <div class="glass-card p-3 mb-3 border-0" style="background: rgba(255, 255, 255, 0.03);">
                        <div class="text-secondary smaller text-uppercase fw-bold mb-1">Customer</div>
                        <div class="text-white fw-bold">${data.receiverName}</div>
                        <div class="text-secondary small">${data.receiverAddress}</div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="glass-card p-2 text-center border-0" style="background: rgba(255, 255, 255, 0.03);">
                                <label class="text-secondary smaller d-block">Attempts</label>
                                <span class="text-white fw-bold">${data.attempts}</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="glass-card p-2 text-center border-0" style="background: rgba(255, 255, 255, 0.03);">
                                <label class="text-secondary smaller d-block">COD Amount</label>
                                <span class="text-orange fw-bold">₱${data.amount}</span>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="text-secondary smaller text-uppercase fw-bold mb-1">Proof Provided</label>
                        <div class="rounded-3 overflow-hidden border border-secondary border-opacity-10">
                            ${data.photo ? `<img src="${data.photo}" class="img-fluid w-100" />` : 
                            `<div class="p-4 text-center text-secondary small"><i class="bi bi-camera-slash-fill d-block fs-3 mb-2"></i> No photo found</div>`}
                        </div>
                    </div>
                `;
                $('#modalContent').html(html);
            });
        }
    </script>
}