@model IEnumerable<SwiftFill.Models.Payment>
@{
    ViewData["Title"] = "Cash Remittance";
    Layout = "_RiderLayout";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
    }
    .remittance-table {
        width: 100%;
        color: #fff;
        border-collapse: collapse;
    }
    .remittance-table thead {
        background: rgba(255, 140, 0, 0.03);
    }
    .remittance-table th {
        padding: 14px 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .remittance-table td {
        padding: 16px 20px;
        vertical-align: middle;
        border-bottom: 1px solid rgba(255,255,255,0.02);
    }
    .remittance-table tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }
</style>

<div class="animate-fade-up">
    <div class="mb-4 d-flex justify-content-between align-items-end">
        <div>
            <h2 class="fw-bold text-white mb-1">Cash Hub</h2>
            <p class="text-secondary small mb-0">Manage your COD collections and remittances.</p>
        </div>
        <div class="text-end">
            <div class="text-secondary smaller fw-bold text-uppercase ls-1">Cash on Hand</div>
            <div class="h3 fw-bold text-orange mb-0">₱@Model.Sum(p => p.Amount).ToString("N2")</div>
        </div>
    </div>

    <!-- Summary Feature -->
    <div class="glass-card p-4 text-center border-0 border-top border-orange border-4 mb-5" 
         style="background: linear-gradient(180deg, rgba(255, 140, 0, 0.05) 0%, rgba(0,0,0,0) 100%);">
        <div class="d-flex justify-content-around align-items-center mb-4">
            <div class="text-center">
                <div class="text-secondary x-small fw-bold text-uppercase">Collections</div>
                <div class="h4 fw-bold text-white mb-0">@Model.Count()</div>
            </div>
            <div class="text-center border-start border-end border-secondary border-opacity-10 px-5">
                <i class="bi bi-wallet2 text-orange fs-2 mb-2 d-block"></i>
                <button class="btn btn-orange px-4 fw-bold rounded-pill shadow-sm" onclick="alert('Proceed to Hub for Remittance Verification')">
                    <i class="bi bi-qr-code me-2"></i> REMIT CASH
                </button>
            </div>
            <div class="text-center">
                <div class="text-secondary x-small fw-bold text-uppercase">Status</div>
                <div class="h4 fw-bold text-success mb-0">Active</div>
            </div>
        </div>
    </div>

    <!-- Remittance Manifest Table -->
    <h5 class="text-white fw-bold mb-3 text-uppercase ls-1">
        <i class="bi bi-list-ul text-orange me-2"></i> CASH REMITTANCE MANIFEST
    </h5>
    
    <div class="glass-card p-0 overflow-hidden border-secondary border-opacity-10">
        <table class="remittance-table">
            <thead>
                <tr>
                    <th style="width: 25%">Tracking ID</th>
                    <th style="width: 25%">Customer</th>
                    <th style="width: 20%">Amount</th>
                    <th style="width: 15%">Paid At</th>
                    <th style="width: 15%" class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td>
                            <code class="text-orange fw-bold">#@payment.TrackingId</code>
                        </td>
                        <td>
                            <div class="text-white fw-bold">@payment.Order?.ReceiverName</div>
                            <div class="text-secondary x-small">COD Payment</div>
                        </td>
                        <td>
                            <div class="text-white fw-bold">₱@payment.Amount.ToString("N2")</div>
                        </td>
                        <td>
                            <div class="text-secondary small">@payment.PaidAt?.ToString("HH:mm")</div>
                            <div class="text-secondary x-small">Today</div>
                        </td>
                        <td class="text-end">
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
                                <i class="bi bi-check2-circle me-1"></i> COLLECTED
                            </span>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-secondary">
                            <i class="bi bi-cash-stack display-4 d-block mb-3 opacity-25"></i>
                            No COD collections found for today.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>