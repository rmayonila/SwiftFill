@model IEnumerable<SwiftFill.Models.Payment>
@{
    ViewData["Title"] = "Cash Remittance";
    Layout = "_RiderLayout";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
    }
    .remittance-table {
        width: 100%;
        color: #fff;
        border-collapse: collapse;
    }
    .remittance-table thead {
        background: rgba(255, 140, 0, 0.03);
    }
    .remittance-table th {
        padding: 14px 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .remittance-table td {
        padding: 16px 20px;
        vertical-align: middle;
        border-bottom: 1px solid rgba(255,255,255,0.02);
    }
    .remittance-table tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }
</style>

<div class="animate-fade-up">
    <!-- Dashboard Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white">
            <i class="bi bi-wallet2 text-orange me-2"></i> Cash Hub
        </h2>
        <div class="text-secondary small">Manage COD collections and remittances</div>
    </div>

    <!-- KPI Cards — Admin-style responsive grid -->
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-4">
            <div class="glass-card p-3 h-100 position-relative overflow-hidden" style="border-left: 3px solid #ff8c00;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-secondary x-small text-uppercase fw-bold ls-1 mb-1">Collections</div>
                        <div class="text-white fw-bold" style="font-size: 2rem; line-height: 1;">@Model.Count()</div>
                        <div class="text-secondary x-small mt-1">Total pending</div>
                    </div>
                    <div class="text-orange opacity-25" style="font-size: 2.5rem;"><i class="bi bi-receipt"></i></div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="glass-card p-3 h-100 position-relative overflow-hidden" style="border-left: 3px solid #17a2b8;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-secondary x-small text-uppercase fw-bold ls-1 mb-1">Cash on Hand</div>
                        <div class="text-white fw-bold" style="font-size: 1.6rem; line-height: 1;">₱@Model.Sum(p => p.Amount).ToString("N0")</div>
                        <div class="text-secondary x-small mt-1">To remit</div>
                    </div>
                    <div class="text-info opacity-25" style="font-size: 2.5rem;"><i class="bi bi-cash-stack"></i></div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="glass-card p-3 h-100 d-flex flex-column justify-content-center align-items-center text-center" style="border-left: 3px solid #6c757d;">
                @if (Model.Any())
                {
                    <form asp-action="MarkAsRemitted" method="post" class="w-100">
                        <button type="submit" class="btn btn-orange w-100 fw-bold rounded-pill shadow-sm py-2" onclick="return confirm('Confirm Remittance: Are you at the hub and have handed over the cash?')">
                            <i class="bi bi-qr-code me-2"></i> DONE REMIT
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary w-100 fw-bold rounded-pill shadow-sm py-2" disabled>
                        <i class="bi bi-check2-all me-2"></i> ALL REMITTED
                    </button>
                }
                <div class="text-secondary mt-2" style="font-size: 0.75rem;">Status: <span class="@(Model.Any() ? "text-success" : "text-secondary") fw-bold">@(Model.Any() ? "Active" : "Cleared")</span></div>
            </div>
        </div>
    </div>

    <!-- Remittance Manifest Table -->
    <h5 class="text-white fw-bold mb-3 text-uppercase ls-1">
        <i class="bi bi-list-ul text-orange me-2"></i> CASH REMITTANCE MANIFEST
    </h5>
    
    <div class="glass-card p-0 overflow-hidden border-secondary border-opacity-10">
        <table class="remittance-table">
            <thead>
                <tr>
                    <th style="width: 25%">Tracking ID</th>
                    <th style="width: 25%">Customer</th>
                    <th style="width: 20%">Amount</th>
                    <th style="width: 15%">Paid At</th>
                    <th style="width: 15%" class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td>
                            <code class="text-orange fw-bold">#@payment.TrackingId</code>
                        </td>
                        <td>
                            <div class="text-white fw-bold">@payment.Order?.ReceiverName</div>
                            <div class="text-secondary x-small">COD Payment</div>
                        </td>
                        <td>
                            <div class="text-white fw-bold">₱@payment.Amount.ToString("N2")</div>
                        </td>
                        <td>
                            <div class="text-secondary small">@payment.PaidAt?.ToString("hh:mm tt")</div>
                            <div class="text-secondary x-small">@payment.PaidAt?.ToString("MMM dd, yyyy")</div>
                        </td>
                        <td class="text-end">
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
                                <i class="bi bi-check2-circle me-1"></i> COLLECTED
                            </span>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-secondary">
                            <i class="bi bi-cash-stack display-4 d-block mb-3 opacity-25"></i>
                            No pending COD collections found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>