@model decimal
@{
    ViewData["Title"] = "Cash Remittance";
    Layout = "_RiderLayout"; // This MUST match the name of your shared layout file
}

<div class="animate-fade-up">
    <div class="mb-4">
        <h2 class="fw-bold text-white mb-1"><i class="bi bi-cash-stack text-orange me-2"></i> Cash Remittance</h2>
        <p class="text-secondary small">Track and remit your collected Cash on Delivery (COD) funds.</p>
    </div>

    <div class="glass-card p-5 text-center border-0 border-top border-orange border-4 mb-4" style="background: rgba(255, 140, 0, 0.05);">
        <div class="text-secondary small mb-2 text-uppercase fw-bold">Current Cash on Hand</div>
        <div class="display-3 fw-bold text-white mb-3">₱@Model.ToString("N2")</div>
        <p class="text-secondary small mb-4">This amount represents all COD collections for today. Please remit to the Davao Hub Cashier before 6:00 PM.</p>
        
        <button class="btn btn-warning px-5 py-3 fw-bold rounded-pill shadow-sm" style="background: #ff8c00; border: none; color: #000;">
            GENERATE REMITTANCE QR
        </button>
    </div>

    <!-- Added Module Features -->
    <div class="module-toolbar">
        <div class="search-container">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search past remittance history..." />
        </div>
        <div class="d-flex gap-2">
            <a href="#" class="filter-btn"><i class="bi bi-funnel"></i> Filter</a>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <table class="table table-dark table-hover mb-0">
            <thead class="bg-black text-secondary small text-uppercase">
                <tr>
                    <th class="ps-4 py-3">Remittance ID</th>
                    <th>Date</th>
                    <th>Amount Remitted</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Receipt</th>
                </tr>
            </thead>
            <tbody class="align-middle">
                <tr>
                    <td colspan="5" class="text-center py-4 text-secondary">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        No recorded remittance history yet
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-container mt-4">
        <div class="page-info">Showing 0 to 0 of 0 entries</div>
        <div class="btn-group">
            <button class="btn btn-sm btn-outline-secondary disabled">Previous</button>
            <button class="btn btn-sm btn-secondary disabled">1</button>
            <button class="btn btn-sm btn-outline-secondary disabled">Next</button>
        </div>
    </div>
</div>