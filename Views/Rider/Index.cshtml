@model IEnumerable<SwiftFill.Models.Order>
@{
    ViewData["Title"] = "My Tasks";
    Layout = "_RiderLayout"; // This connects to your new shared layout
}

<style>
    .delivery-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .delivery-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 140, 0, 0.2);
        transform: translateY(-2px);
    }
    .contact-btn, .map-btn {
        padding: 8px 12px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    .contact-btn {
        background: rgba(255, 140, 0, 0.1);
        color: #ff8c00;
        border: 1px solid rgba(255, 140, 0, 0.2);
    }
    .contact-btn:hover { background: #ff8c00; color: #000; }
    
    .map-btn {
        background: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
        border: 1px solid rgba(13, 110, 253, 0.2);
    }
    .map-btn:hover { background: #0d6efd; color: #fff; }

    .payment-tag {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 20px;
    }
    .cod-amount {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.25rem;
        font-weight: 700;
        color: #ff8c00;
    }
</style>

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-white mb-1"><i class="bi bi-list-task text-orange me-2"></i> Active Itinerary</h2>
            <p class="text-secondary small mb-0">Manage your specific route and delivery status.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-dark border border-success text-success px-3 py-2">
                <span class="spinner-grow spinner-grow-sm me-1" role="status"></span> LIVE ROUTE
            </span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 border-success border-opacity-25 text-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="glass-card p-3 h-100 border-0 border-start border-orange border-4" style="background: rgba(255, 140, 0, 0.05);">
                <div class="text-orange opacity-75 small fw-bold">Pending Drops</div>
                <div class="text-white h2 mb-0 fw-bold">@Model.Count()</div>
            </div>
        </div>
        <div class="col-md-9">
            <div class="glass-card p-3 h-100 d-flex align-items-center" style="background: rgba(255, 255, 255, 0.01);">
                <i class="bi bi-exclamation-triangle-fill text-orange me-3 fs-3"></i>
                <div class="text-secondary small">
                    <strong>Rider Notice:</strong> Verify COD amounts exactly as listed. Ensure customers sign the digital log (forthcoming) before completing delivery. Use built-in navigation for optimal routing.
                </div>
            </div>
        </div>
    </div>

    <div class="module-toolbar">
        <div class="search-container">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search tracking ID or target location..." />
        </div>
        <div class="d-flex gap-2">
            <a href="#" class="filter-btn"><i class="bi bi-funnel"></i> Filter</a>
        </div>
    </div>

    <div class="row g-4">
       @foreach (var order in Model)
{
    <div class="col-12">
        <div class="delivery-card p-4">
            <form asp-action="UpdateStatus" method="post" enctype="multipart/form-data">
                <input type="hidden" name="trackingId" value="@order.TrackingId" />
                
                <div class="row">
                    <div class="col-md-8">
                        <div class="mt-3">
                            <label class="text-secondary small d-block mb-2">Proof of Delivery / Return</label>
                            <div class="d-flex align-items-center gap-3">
                                <label for="file-@order.TrackingId" class="btn btn-dark border-secondary rounded-3 px-3 py-2">
                                    <i class="bi bi-camera-fill text-orange me-2"></i> Attach Photo
                                </label>
                                <input type="file" id="file-@order.TrackingId" name="proofPhoto" class="d-none" onchange="updateFileLabel('@order.TrackingId')">
                                <span id="label-@order.TrackingId" class="text-secondary smaller">No file chosen</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-4 text-end d-flex flex-column justify-content-between">
                        <div class="cod-amount">₱@order.Payment?.Amount.ToString("N2")</div>

                        <div class="mt-4">
                            <button type="submit" name="status" value="Delivered" class="btn btn-success w-100 py-2 fw-bold mb-2">
                                DELIVERED
                            </button>

                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-warning flex-fill py-2 fw-bold small" 
                                        onclick="showStatusModal('@order.TrackingId', 'Failed')">
                                    FAILED
                                </button>
                                
                                <button type="button" class="btn btn-outline-danger flex-fill py-2 fw-bold small" 
                                        onclick="showStatusModal('@order.TrackingId', 'Returned')">
                                    RETURN
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

<div class="modal fade" id="statusModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-0">
                <h5 class="modal-title text-white">Confirm <span id="modalStatusTitle"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateStatus" method="post">
                <div class="modal-body">
                    <input type="hidden" name="trackingId" id="statusTrackingId" />
                    <input type="hidden" name="status" id="statusValue" />
                    
                    <label class="text-secondary small mb-2">Reason for <span id="modalStatusLabel"></span>:</label>
                    <select name="failReason" class="form-select bg-black text-white border-secondary mb-3">
                        <option value="Customer Not Home">Customer Not Home</option>
                        <option value="Refused to Pay (COD)">Refused to Pay (COD)</option>
                        <option value="Incorrect Address">Incorrect Address</option>
                        <option value="Damaged Item">Item Damaged in Transit</option>
                        <option value="Customer Cancelled">Customer Cancelled on Arrival</option>
                    </select>
                    
                    <p class="smaller text-warning" id="attemptWarning">
                        Note: Failed deliveries will stay in your list until 3 attempts are reached.
                    </p>
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" class="btn btn-orange w-100 py-2">Confirm Action</button>
                </div>
            </form>
        </div>
    </div>
</div>
        }

        <div class="col-12 mt-4">
            <div class="pagination-container">
                <div class="page-info">Showing 1 to @Model.Count() of @Model.Count() entries</div>
                <div class="btn-group">
                    <button class="btn btn-sm btn-outline-secondary disabled">Previous</button>
                    <button class="btn btn-sm btn-secondary">1</button>
                    <button class="btn btn-sm btn-outline-secondary disabled">Next</button>
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-check-all text-success display-1 opacity-25 mb-3"></i>
                <h3 class="text-white">All Clear!</h3>
                <p class="text-secondary">No active deliveries assigned to you right now.</p>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="failReasonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary" style="border-radius: 16px;">
            <div class="modal-header border-0">
                <h5 class="modal-title text-white">Select Failure Reason</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateStatus" method="post">
                <div class="modal-body">
                    <input type="hidden" name="trackingId" id="modalTrackingId" />
                    <input type="hidden" name="status" value="Failed" />
                    <div class="mb-3">
                        <label class="text-secondary small mb-2">Why could this not be delivered?</label>
                        <select name="failReason" class="form-select bg-black text-white border-secondary">
                            <option value="Customer Not Home">Customer Not Home</option>
                            <option value="Refused to Pay (COD)">Refused to Pay (COD)</option>
                            <option value="Incorrect Address">Incorrect Address</option>
                            <option value="Customer Unreachable">Customer Unreachable</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" class="btn btn-danger w-100 py-2 fw-bold">Confirm Failure</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showFailModal(id) {
            document.getElementById('modalTrackingId').value = id;
            var myModal = new bootstrap.Modal(document.getElementById('failReasonModal'));
            myModal.show();
        }

        function updateFileLabel(id) {
        const fileName = document.getElementById('file-' + id).files[0].name;
        document.getElementById('label-' + id).innerText = fileName;
        document.getElementById('label-' + id).classList.replace('text-secondary', 'text-success');
    }

    function showStatusModal(id, status) {
        document.getElementById('statusTrackingId').value = id;
        document.getElementById('statusValue').value = status;
        document.getElementById('modalStatusTitle').innerText = status;
        document.getElementById('modalStatusLabel').innerText = status;
        
        // Hide warning if it's a direct Return
        const warning = document.getElementById('attemptWarning');
        warning.style.display = (status === 'Returned') ? 'none' : 'block';

        new bootstrap.Modal(document.getElementById('statusModal')).show();
    }
    </script>
}