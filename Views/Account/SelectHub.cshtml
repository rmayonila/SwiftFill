@{
    ViewData["Title"] = "Hub Verification — SwiftFill";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hub Verification — SwiftFill</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            background: #0d1117;
            font-family: 'Inter', sans-serif;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image:
                radial-gradient(ellipse at 50% -10%, rgba(255,140,0,0.12) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 80%, rgba(255,140,0,0.04) 0%, transparent 40%);
        }
        .verify-card {
            background: rgba(18, 22, 30, 0.97);
            border: 1px solid rgba(255, 140, 0, 0.2);
            border-radius: 20px;
            padding: 48px 44px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,140,0,0.08);
            animation: fadeUp 0.35s ease;
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .logo-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 36px;
        }
        .logo-row img { height: 38px; }
        .logo-row span { font-size: 1.4rem; font-weight: 800; }

        .verify-title {
            font-size: 1.5rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 6px;
        }
        .verify-sub {
            text-align: center;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.38);
            margin-bottom: 36px;
            line-height: 1.6;
        }

        .code-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: rgba(255,140,0,0.7);
            margin-bottom: 8px;
            display: block;
        }
        .code-input {
            width: 100%;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,140,0,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #ff8c00;
            font-family: 'Inter', monospace;
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: 6px;
            text-align: center;
            text-transform: uppercase;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            caret-color: #ff8c00;
        }
        .code-input:focus {
            border-color: #ff8c00;
            box-shadow: 0 0 0 3px rgba(255,140,0,0.12);
        }
        .code-input.error {
            border-color: #dc3545;
            color: #dc3545;
            box-shadow: 0 0 0 3px rgba(220,53,69,0.12);
            animation: shake 0.4s ease;
        }
        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-6px); }
            60%       { transform: translateX(6px); }
        }

        .verify-btn {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, #ff8c00, #e07000);
            color: #000;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.2s;
        }
        .verify-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,140,0,0.35); }
        .verify-btn:active { transform: translateY(0); }

        .error-msg {
            background: rgba(220,53,69,0.08);
            border: 1px solid rgba(220,53,69,0.3);
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.85rem;
            color: #f87171;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .info-footer {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.06);
            text-align: center;
            font-size: 0.78rem;
            color: rgba(255,255,255,0.22);
        }
        .key-icon {
            width: 64px; height: 64px;
            border-radius: 50%;
            background: rgba(255,140,0,0.08);
            border: 1px solid rgba(255,140,0,0.2);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
            font-size: 1.8rem;
            color: #ff8c00;
        }
    </style>
</head>
<body>
    <div class="verify-card">
        <div class="logo-row">
            <img src="~/images/logo.png" alt="SwiftFill" />
            <span>SwiftFill</span>
        </div>

        <div class="key-icon"><i class="bi bi-key-fill"></i></div>
        <div class="verify-title">Hub Verification</div>
        <p class="verify-sub">
            Enter the unique access code assigned to your hub branch by the Super Admin.
            All staff at the same location share one code.
        </p>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="error-msg">
                <i class="bi bi-shield-exclamation" style="font-size:1.1rem; flex-shrink:0;"></i>
                @TempData["ErrorMessage"]
            </div>
        }

        <form method="post" asp-action="SelectHub" asp-controller="Account">
            <label class="code-label">
                <i class="bi bi-lock-fill me-1"></i>Hub Access Code
            </label>
            <input
                type="text"
                name="code"
                id="codeInput"
                class="code-input @(TempData["ErrorMessage"] != null ? "error" : "")"
                placeholder="• • • • • • • •"
                maxlength="16"
                autocomplete="off"
                autofocus
                required />
            <button type="submit" class="verify-btn">
                <i class="bi bi-shield-check me-2"></i>Verify &amp; Enter Hub
            </button>
        </form>

        <div class="info-footer">
            <i class="bi bi-info-circle me-1"></i>
            Don't have a code? Contact your Super Admin. &nbsp;·&nbsp;
            <a href="/Account/Logout" style="color: rgba(255,255,255,0.3); text-decoration:none;">Sign Out</a>
        </div>
    </div>
    <script>
        // Auto-uppercase
        const inp = document.getElementById('codeInput');
        inp.addEventListener('input', () => { inp.value = inp.value.toUpperCase(); });
    </script>
</body>
</html>
