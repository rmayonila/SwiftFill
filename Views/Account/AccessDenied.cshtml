@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5 text-center">
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> Access Denied</h4>
        <p>You do not have permission to access this resource or perform this action.</p>
        <hr>
        <p class="mb-0">
            If you believe this is an error, please contact your system administrator. 
            <a href="javascript:history.back()" class="alert-link">Click here to go back</a>.
        </p>
    </div>
</div>
