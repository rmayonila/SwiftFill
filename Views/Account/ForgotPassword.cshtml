@{
    ViewData["Title"] = "Forgot Password - SwiftFill";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background-color: #0d1117;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            color: #ffffff;
        }

        .login-wrapper {
            width: 100%;
            max-width: 450px;
            padding: 20px;
        }

        .brand-logo {
            text-align: center;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 1.8rem;
            font-weight: 800;
            color: #ffffff;
        }

        .brand-logo i {
            background: #ff8c00;
            color: #000;
            padding: 5px 8px;
            border-radius: 8px;
            font-size: 1.5rem;
        }

        .login-card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .form-label {
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .input-group-text {
            background: #0d1117;
            border: 1px solid #30363d;
            border-right: none;
            color: #8b949e;
        }

        .form-control {
            background: #0d1117;
            border: 1px solid #30363d;
            border-left: none;
            color: #ffffff;
            font-size: 0.95rem;
            padding: 12px 15px 12px 0;
        }

        .form-control:focus {
            background: #0d1117;
            color: #ffffff;
            box-shadow: none;
            border-color: #ff8c00;
        }

        .input-group:focus-within .input-group-text,
        .input-group:focus-within .form-control {
            border-color: #ff8c00;
        }

        .btn-signin {
            background: #ff8c00;
            color: #000;
            font-weight: 600;
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: none;
            margin-top: 20px;
            transition: 0.2s;
        }

        .btn-signin:hover {
            background: #fc9417;
            transform: translateY(-1px);
        }

        .back-link {
            color: #8b949e;
            text-decoration: none;
            font-size: 0.9rem;
            display: block;
            text-align: center;
            margin-top: 30px;
            transition: 0.2s;
        }

        .back-link:hover {
            color: #ffffff;
        }
    </style>
</head>
<body>

    <div class="login-wrapper animate-fade-up">
        <div class="brand-logo">
            <img src="~/images/logo.png" class="auth-logo" alt="SwiftFill Logo" />
        </div>

        <div class="login-card">
            <div class="text-center mb-4">
                <i class="bi bi-envelope-check text-orange" style="font-size: 3rem; color: #ff8c00;"></i>
                <h3 class="fw-bold mt-2 mb-2">Forgot Password</h3>
                <p class="text-secondary" style="font-size:0.95rem;">Enter your email and we'll send you a password reset link.</p>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger" style="background:#2d1b1e; color:#ff6b6b; border:1px solid #4a2121; text-align:center;">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
                </div>
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" style="background:#1b2d1e; color:#6bff72; border:1px solid #214a21; text-align:center;">
                    <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
                </div>
            }

            <form method="post" action="/Account/ForgotPasswordAction">
                
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input type="email" name="email" class="form-control" placeholder="you@company.com" required>
                    </div>
                </div>

                <button type="submit" class="btn-signin">Send Reset Link</button>
            </form>

        </div>

        <a href="/Account/Login" class="back-link">&larr; Back to login</a>
    </div>

</body>
</html>
