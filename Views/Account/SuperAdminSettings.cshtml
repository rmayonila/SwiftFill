@model SwiftFill.Models.SettingsViewModel
@{
    ViewData["Title"] = "SuperAdmin Account Settings";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-person-gear text-orange me-3"></i>ACCOUNT SETTINGS SUPERADMIN</h2>
            <p class="text-secondary mt-1">Manage your super administrator profile information and security preferences.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 border-success border-opacity-25 text-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-25 text-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card premium-card border-0 shadow-lg" style="background: rgba(22, 27, 34, 0.9); backdrop-filter: blur(14px); border-radius: 12px; border: 1px solid #30363d !important;">
                <div class="card-header bg-transparent border-bottom border-dark py-3 px-4">
                    <h6 class="mb-0 fw-bold text-white">Profile Information</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Settings" method="post">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label text-secondary small"></label>
                                <input asp-for="FirstName" class="form-control bg-dark border-secondary text-white shadow-none" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label text-secondary small"></label>
                                <input asp-for="LastName" class="form-control bg-dark border-secondary text-white shadow-none" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label text-secondary small"></label>
                            <input asp-for="Email" class="form-control bg-dark border-secondary text-secondary shadow-none" readonly />
                            <div class="form-text text-muted smaller">Email cannot be changed. Contact support if needed.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label text-secondary small"></label>
                            <input asp-for="PhoneNumber" class="form-control bg-dark border-secondary text-white shadow-none" placeholder="+63 9XX XXX XXXX" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <hr class="border-dark my-5" />

                        <h6 class="mb-4 fw-bold text-white"><i class="bi bi-shield-lock me-2 text-warning"></i>Security & Password</h6>
                        
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label text-secondary small"></label>
                            <input asp-for="CurrentPassword" class="form-control bg-dark border-secondary text-white shadow-none" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="NewPassword" class="form-label text-secondary small"></label>
                                <input asp-for="NewPassword" class="form-control bg-dark border-secondary text-white shadow-none" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConfirmPassword" class="form-label text-secondary small"></label>
                                <input asp-for="ConfirmPassword" class="form-control bg-dark border-secondary text-white shadow-none" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-5">
                            <button type="submit" class="btn btn-warning px-5 fw-bold" style="border-radius: 8px; color: #000;">
                                <i class="bi bi-save me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card premium-card border-0 shadow-sm" style="background: rgba(255, 140, 0, 0.05); border: 1px solid rgba(255, 140, 0, 0.1) !important; border-radius: 12px;">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3 fw-bold shadow-lg" style="width: 80px; height: 80px; background: #ff8c00; color: #000; font-size: 2rem;">
                        @((User.Identity?.Name ?? "U").Substring(0,1).ToUpper())
                    </div>
                    <h5 class="text-white fw-bold mb-1">@User.Identity?.Name</h5>
                    <p class="text-secondary small mb-3">
                        <span class="badge bg-danger">Super Administrator</span>
                    </p>
                    <div class="text-start mt-4">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-shield-check text-orange me-2"></i>
                            <span class="text-secondary small">Access Level: <strong>SuperAdmin</strong></span>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-calendar-check text-orange me-2"></i>
                            <span class="text-secondary small">Member since: <strong>2024</strong></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .text-orange { color: #ff8c00; }
    .bg-orange { background-color: #ff8c00; color: #000; }
    .premium-card { transition: all 0.3s ease; }
    .form-control:focus {
        background-color: #1a1f26 !important;
        border-color: #ff8c00 !important;
        color: #fff !important;
    }
</style>
