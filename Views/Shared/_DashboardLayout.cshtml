<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SwiftFill</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Sora:wght@700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm fixed-top shadow-sm" style="background:#0d1117; border-bottom: 1px solid #30363d;">
            <div class="container">
                <a class="navbar-brand text-white fw-bold d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" class="brand-logo-img" alt="SwiftFill" />
                    <span class="brand-text ms-2">SwiftFill</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-4 text-secondary" style="font-size:0.9rem;">
                                <i class="bi bi-clock"></i> Local Time: @DateTime.Now.ToString("h:mm tt")
                            </li>
                            <li class="nav-item me-3">
                                <a asp-controller="Account" asp-action="Settings" class="nav-link fw-bold text-white d-flex align-items-center text-decoration-none">
                                    <div class="rounded-circle d-flex justify-content-center align-items-center me-2 fw-bold" style="width: 28px; height: 28px; background: rgba(255,140,0,0.2); color: #ff8c00; font-size: 0.8rem;">
                                        @((User.Identity?.Name ?? "U").Substring(0,1).ToUpper())
                                    </div>
                                    @User.Identity?.Name
                                </a>
                            </li>
                            <li class="nav-item">
                                <form method="post" action="/Account/Logout" class="d-inline">
                                    <button type="submit" class="btn btn-sm" style="background:transparent; color:#ff6b6b; border:1px solid #4a2121; border-radius: 6px;"><i class="bi bi-box-arrow-right"></i> Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="content-wrapper" style="padding-top:80px; min-height:100vh;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
