@model ErrorViewModel
@{
    ViewData["Title"] = "Something Went Wrong";
    Layout = "_Layout";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-card p-5 animate-fade-in" style="background: rgba(22, 27, 34, 0.8); border: 1px solid #30363d; border-radius: 20px; backdrop-filter: blur(10px);">
                <div class="error-icon mb-4">
                    <i class="bi bi-exclamation-triangle-fill text-orange" style="font-size: 5rem;"></i>
                </div>
                
                <h1 class="display-4 fw-bold text-white mb-3">Oops! Something went wrong.</h1>
                <p class="lead text-secondary mb-4">
                    We encountered an unexpected error while processing your request. Our team has been notified and we're working to fix it.
                </p>

                <div class="alert alert-dark border-secondary bg-dark bg-opacity-25 text-start mb-4" style="font-family: monospace; font-size: 0.9rem;">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary">Request ID:</span>
                        <code class="text-orange">@Model.RequestId</code>
                    </div>
                </div>

                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a href="/" class="btn btn-primary btn-lg px-5" style="background: #ff8c00; border: none; font-weight: 600;">
                        <i class="bi bi-house-door me-2"></i>Back to Home
                    </a>
                    <button onclick="location.reload()" class="btn btn-outline-light btn-lg px-5">
                        <i class="bi bi-arrow-clockwise me-2"></i>Try Again
                    </button>
                </div>
            </div>

            <div class="mt-5 text-secondary">
                <p>If the problem persists, please <a href="/#contact" class="text-orange text-decoration-none">contact our support team</a>.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .text-orange { color: #ff8c00 !important; }
    .btn-primary:hover { background: #fc9417 !important; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255, 140, 0, 0.3); }
    .error-card { transition: transform 0.3s ease; }
    .error-card:hover { transform: translateY(-5px); }
</style>
