<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Super Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        :root {
            --brand-primary: #ff8c00;
            --brand-bg: #000000;
            --sidebar-bg: #050505;
        }

        /* ===== GLOBAL SIDEBAR LAYOUT ===== */
        body { background-color: var(--brand-bg); color: #ffffff; font-family: 'Inter', sans-serif; }

        .sidebar {
            width: 260px;
            position: fixed;
            top: 0; left: 0;
            height: 100vh;
            background: var(--sidebar-bg);
            border-right: 1px solid rgba(255,140,0,0.15);
            padding-top: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Scrollable nav list keeps sidebar stable even with many items */
        .sidebar .nav-sidebar-wrap {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding-bottom: 16px;
        }
        .sidebar .nav-sidebar-wrap::-webkit-scrollbar { width: 4px; }
        .sidebar .nav-sidebar-wrap::-webkit-scrollbar-thumb { background: rgba(255,140,0,0.25); border-radius: 4px; }

        .main-content {
            margin-left: 260px;
            padding: 20px 36px;
            min-height: 100vh;
            background: #000000;
        }

        /* Brand / Logo */
        .sidebar-brand {
            display: flex;
            align-items: center;
            padding: 20px 22px 16px;
            text-decoration: none;
            border-bottom: 1px solid rgba(255,140,0,0.1);
            flex-shrink: 0;
        }
        .sidebar-brand .brand-text {
            font-size: 1.25rem;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: 0.5px;
        }

        /* Role label */
        .sidebar-role-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1.2px;
            color: rgba(255,140,0,0.6);
            padding: 14px 22px 6px;
            flex-shrink: 0;
        }

        /* ALL nav-links — SAME height/padding regardless of role */
        .nav-sidebar .nav-link {
            color: rgba(255,255,255,0.5);
            padding: 12px 22px;
            min-height: 50px; /* Ensures uniform height across all role-based modules */
            font-size: 0.88rem;
            font-weight: 500;
            line-height: 1.4;
            transition: background 0.2s, color 0.2s, border-color 0.2s;
            border-left: 3px solid transparent;
            display: flex;
            align-items: center;
            white-space: nowrap;
        }

        .nav-sidebar .nav-link:hover,
        .nav-sidebar .nav-link.active {
            color: #ffffff;
            background: rgba(255, 140, 0, 0.08);
            border-left: 3px solid var(--brand-primary);
        }
        .nav-sidebar .nav-link.active {
            color: var(--brand-primary);
            background: rgba(255,140,0,0.12);
            box-shadow: inset 4px 0 10px rgba(255,140,0,0.1);
        }

        .nav-sidebar .nav-link i {
            margin-right: 11px;
            font-size: 1rem;
            flex-shrink: 0;
        }

        /* Logout area */
        .sidebar-logout {
            padding: 16px 22px;
            border-top: 1px solid rgba(255,140,0,0.1);
            flex-shrink: 0;
        }
    </style>
</head>
<body>
    <!-- Left Sidebar -->
    <div class="sidebar">
        <a href="/" class="sidebar-brand">
            <img src="~/images/logo.png" style="height:40px;" alt="SwiftFill" />
            <span class="brand-text ms-2">SwiftFill</span>
        </a>

        <!-- Sidebar header/branding only -->

        <div class="nav-sidebar-wrap">
            <ul class="nav flex-column nav-sidebar">
                <li class="nav-item">
                    <div class="px-4 mt-3 mb-2 text-secondary text-uppercase x-small ls-1">Main Menu</div>
                </li>
                
                @if (User.IsInRole("SuperAdmin"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SuperAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="SuperAdmin" asp-action="Index">
                            <i class="bi bi-gear-fill"></i> System Configuration
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")" asp-controller="SuperAdmin" asp-action="Users">
                            <i class="bi bi-people-fill"></i> User Accounts
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Warehouses" ? "active" : "")" asp-controller="SuperAdmin" asp-action="Warehouses">
                            <i class="bi bi-geo-alt-fill mt-1"></i> Hub Locations
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SecurityLogs" ? "active" : "")" asp-controller="SuperAdmin" asp-action="SecurityLogs">
                            <i class="bi bi-shield-lock-fill mt-1"></i> Security Logs
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SystemLogs" ? "active" : "")" asp-controller="SuperAdmin" asp-action="SystemLogs">
                            <i class="bi bi-cpu mt-1"></i> System Logs
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Branding" ? "active" : "")" asp-controller="SuperAdmin" asp-action="Branding">
                            <i class="bi bi-palette mt-1"></i> Manage Branding
                        </a>
                    </li>
@* Archived Hubs removed as per request *@
                }
                
                @if (User.IsInRole("Admin"))
                {
                    
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">
                            <i class="bi bi-grid-1x2-fill"></i> Dashboard Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Shipments" ? "active" : "")" asp-controller="Admin" asp-action="Shipments">
                            <i class="bi bi-activity"></i> Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Pack" ? "active" : "")" asp-controller="Admin" asp-action="Pack">
                            <i class="bi bi-box-seam"></i> Order Packing
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payments" ? "active" : "")" asp-controller="Admin" asp-action="Payments">
                            <i class="bi bi-wallet2"></i> Payments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Returns" ? "active" : "")" asp-controller="Admin" asp-action="Returns">
                            <i class="bi bi-arrow-return-left"></i> Return Requests
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ShippingRates" ? "active" : "")" asp-controller="Admin" asp-action="ShippingRates">
                            <i class="bi bi-tags-fill mt-1"></i> Shipping Rates
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ItemCategories" ? "active" : "")" asp-controller="Admin" asp-action="ItemCategories">
                            <i class="bi bi-card-checklist mt-1"></i> Accepted Items
                        </a>
                    </li>
    
                }

                @if (User.IsInRole("WarehouseStaff") || User.IsInRole("WarehouseOperator"))
                {
                    var currentHub = Context.Session.GetString("UserHub") ?? "Davao Hub";
                    
                    <div class="px-4 mt-3 mb-2 text-secondary text-uppercase x-small ls-1">Warehouse Staff Operations</div>
                    
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Warehouse" asp-action="Dashboard">
                            <i class="bi bi-grid-fill"></i> Operations Overview
                        </a>
                    </li>

                    @if (currentHub == "Davao Hub")
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "PackingLine" ? "active" : "")" asp-controller="Warehouse" asp-action="PackingLine">
                                <i class="bi bi-box-seam"></i> Packing & Crating
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "HubTransfers" ? "active" : "")" asp-controller="Warehouse" asp-action="HubTransfers">
                                <i class="bi bi-arrow-left-right"></i> Sorting & Staging
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "TruckTracking" ? "active" : "")" asp-controller="Warehouse" asp-action="TruckTracking">
                                <i class="bi bi-truck"></i> Truck Tracking
                            </a>
                        </li>
                    }
                    else
                    {
                        @* Other hubs hide Picking and Packing as requested *@
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "WarehouseQueue" ? "active" : "")" asp-controller="Warehouse" asp-action="WarehouseQueue">
                                <i class="bi bi-list-ul"></i> Shipment Queue
                            </a>
                        </li>
                    }
                }

                @if (User.IsInRole("DeliveryRider"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rider" ? "active" : "")" asp-controller="Rider" asp-action="Index">
                            <i class="bi bi-list-task"></i> My Tasks
                        </a>
                    </li>
                }

                @if (User.IsInRole("Customer"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Customer" asp-action="Index">
                            <i class="bi bi-box-seam"></i> Order History
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Book" ? "active" : "")" asp-controller="Customer" asp-action="Book">
                            <i class="bi bi-plus-circle"></i> New Shipment
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <div class="px-4 mt-4 mb-2 text-secondary text-uppercase x-small ls-1">Insights</div>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "RecentActivity" ? "active" : "")" asp-controller="Admin" asp-action="RecentActivity">
                            <i class="bi bi-clock-history"></i> Recent Activity
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")" asp-controller="Admin" asp-action="Reports">
                            <i class="bi bi-bar-chart-fill"></i> Analytical Reports
                        </a>
                    </li>

@* Archived Records removed as per request *@
                }

                <div class="px-4 mt-4 mb-2 text-secondary text-uppercase x-small ls-1">Account</div>
                <li class="nav-item">
                    @{
                        string viewMode = "admin";
                        if (User.IsInRole("SuperAdmin")) viewMode = "superadmin";
                    }
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")" 
                       asp-controller="Account" asp-action="Settings" asp-route-view="@viewMode">
                        <i class="bi bi-gear-fill"></i> Account Settings
                    </a>
                </li>
            </ul>
        </div>

        <!-- Pinned logout footer -->
        <div class="sidebar-logout">
            <form method="post" action="/Account/Logout">
                <button type="submit" class="btn w-100 fw-bold"
                    style="border:1px solid rgba(220,53,69,0.4);color:rgba(220,53,69,0.8);background:rgba(220,53,69,0.05);border-radius:8px;font-size:0.85rem;padding:10px;">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="main-content">
        <!-- Dashboard Top Header -->
        <div class="d-flex justify-content-end align-items-center mb-4 pb-3">
            @{
                string topViewMode = "admin";
                if (User.IsInRole("SuperAdmin")) topViewMode = "superadmin";
            }
            <a asp-controller="Account" asp-action="Settings" asp-route-view="@topViewMode" class="d-flex align-items-center text-decoration-none" title="Account Settings">
                <div class="rounded-circle d-flex justify-content-center align-items-center fw-bold shadow-sm" style="width: 35px; height: 35px; background: var(--brand-primary); color: #000;">
                    @((User.Identity?.Name ?? "U").Substring(0,1).ToUpper())
                </div>
                <span class="ms-2 fw-semibold text-white">@User.Identity?.Name</span>
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show bg-dark text-success border-success mb-4 mx-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show bg-dark text-danger border-danger mb-4 mx-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // ── Sidebar scroll persistence ──
        // Saves the sidebar scroll position before nav and restores it on load.
        // This prevents the sidebar from jumping to the top when clicking a menu item.
        (function () {
            var wrap = document.querySelector('.nav-sidebar-wrap');
            if (!wrap) return;

            // Restore position on page load
            var saved = sessionStorage.getItem('sidebarScroll');
            if (saved) wrap.scrollTop = parseInt(saved, 10);

            // Highlight the active link and scroll it into view
            var activeLink = wrap.querySelector('.nav-link.active');
            if (activeLink) {
                var linkTop = activeLink.offsetTop;
                var wrapHeight = wrap.clientHeight;
                // Only scroll if the active link is not visible
                if (linkTop < wrap.scrollTop || linkTop > wrap.scrollTop + wrapHeight - 50) {
                    wrap.scrollTop = linkTop - wrapHeight / 3;
                }
            }

            // Save position before navigating away
            wrap.addEventListener('scroll', function () {
                sessionStorage.setItem('sidebarScroll', wrap.scrollTop);
            });
        })();
    </script>
</body>
</html>
