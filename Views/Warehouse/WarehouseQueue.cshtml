@model IEnumerable<SwiftFill.Models.Order>
@using SwiftFill.Models
@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Warehouse Queue";
    var currentHub = ViewBag.CurrentHub as string ?? "Hub";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-boxes text-orange me-2"></i> Warehouse Queue</h2>
        <div class="text-secondary small">Hub: <span class="text-orange fw-bold">@currentHub</span></div>
    </div>

    <!-- Integrated Filter Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px; position: relative;">
                    <i class="bi bi-search" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #6c757d;"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           style="background: #111; border: 1px solid #222; border-radius: 8px; padding: 10px 15px 10px 40px; color: #fff; outline: none;"
                           placeholder="Search Tracking ID, Receiver...">
                </div>
            </form>
        </div>
        <div class="d-flex align-items-center gap-3">
             <span class="badge bg-warning text-dark px-3 py-2 fw-bold">@Model.Count() PARCELS</span>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr class="text-secondary small text-uppercase">
                        <th class="ps-4 py-3">Shipment Identity</th>
                        <th class="py-3">Logistics Detail</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var destHub = HubRegistry.ResolveDestinationHub(item.DestinationRegion);
                        var isFinalDest = destHub == currentHub;
                        var isSorted = item.Status == "Sorted for Transfer";
                        var isAssigned = item.AssignedRiderId != null || item.ManualRiderId != null;
                        var manualRiders = ViewBag.ManualRiders as IEnumerable<SwiftFill.Models.ManualRider> ?? new List<SwiftFill.Models.ManualRider>();
                        var userRiders = ViewBag.AvailableRiders as IEnumerable<SwiftFill.Models.ApplicationUser> ?? new List<SwiftFill.Models.ApplicationUser>();

                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                            <td class="ps-4 py-3">
                                <code class="text-orange fw-bold d-block">#@item.TrackingId</code>
                                <div class="text-white small">@item.ReceiverName</div>
                                <div class="text-secondary x-small"><i class="bi bi-geo-alt me-1"></i>@item.ReceiverAddress</div>
                            </td>
                            <td class="py-3">
                                <div class="text-white small">@item.DestinationRegion Hub</div>
                                <div class="text-secondary x-small">@item.Weight kg | @(item.ItemCategory ?? "General")</div>
                                @if (item.IsFragile)
                                {
                                    <span class="badge border border-warning text-warning mt-1" style="font-size: 0.6rem;"><i class="bi bi-exclamation-triangle-fill me-1"></i>FRAGILE</span>
                                }
                            </td>
                            <td class="py-3">
                                @{
                                    var statusClass = item.Status == "Returning to Sender" ? "border-danger text-danger" :
                                                     (item.Status == "Sorted for Transfer" ? "border-info text-info" :
                                                     (item.Status == "Out for Delivery" ? "border-warning text-warning" :
                                                     (item.Status.StartsWith("Arrived at") ? "border-primary text-primary" : "border-success text-success")));
                                }
                                <span class="badge border bg-transparent px-2 py-1 @statusClass" style="font-size: 0.65rem;">
                                    @item.Status
                                </span>
                            </td>
                            <td class="py-3 pe-4 text-end">
                                <div class="d-flex justify-content-end align-items-center gap-3">
                                    @if (isAssigned)
                                    {
                                        string riderName = item.AssignedRider != null 
                                            ? $"{item.AssignedRider.FirstName} {item.AssignedRider.LastName}" 
                                            : item.ManualRider?.Name ?? "Assigned";
                                        <div class="text-success x-small fw-bold border-end border-secondary border-opacity-25 pe-3 d-none d-md-block">
                                            <i class="bi bi-truck me-1"></i>@riderName
                                        </div>
                                    }
                                    
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-link text-info p-0 action-icon" onclick="openLogisticsModal('@item.TrackingId', '@item.Status', '@destHub', @((!isSorted && !isFinalDest).ToString().ToLower()), @((isSorted && !isFinalDest).ToString().ToLower()), '@(item.Status == "Returning to Sender" ? "true" : "false")')" title="Logistics Control">
                                            <i class="bi bi-lightning-charge-fill"></i>
                                        </button>
                                        <button class="btn btn-link text-warning p-0 action-icon" onclick="openAssignModal('@item.TrackingId')" title="Assign Rider">
                                            <i class="bi bi-person-badge-fill"></i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-secondary border-0">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                No parcels found in the queue.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search">Next</a>
                </li>
            </ul>
        </div>
    }
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        function openLogisticsModal(trackingId, status, destHub, showSort, showDispatch, isReturning) {
            const modal = new bootstrap.Modal(document.getElementById('logisticsModal'));
            document.getElementById('logTrackingId').textContent = '#' + trackingId;
            document.getElementById('logSortTrackingId').value = trackingId;
            document.getElementById('logDispatchTrackingId').value = trackingId;
            document.getElementById('logReturnTrackingId').value = trackingId;
            
            document.getElementById('logSortBtn').textContent = 'Sort to ' + destHub.replace(' Hub', '');
            document.getElementById('logSortSection').style.display = showSort ? 'block' : 'none';
            document.getElementById('logDispatchSection').style.display = showDispatch ? 'block' : 'none';
            document.getElementById('logReturnSection').style.display = (isReturning === 'true') ? 'block' : 'none';
            
            modal.show();
        }

        function openAssignModal(trackingId) {
            const modal = new bootstrap.Modal(document.getElementById('assignModal'));
            document.getElementById('assignTrackingId').textContent = '#' + trackingId;
            document.getElementById('assignFormTrackingId').value = trackingId;
            modal.show();
        }

        function assignRider() {
            const riderId = document.getElementById('assignRiderSelect').value;
            if (!riderId) {
                alert('Please select a rider first');
                return;
            }
            document.getElementById('assignRiderForm').submit();
        }
    </script>
}

<style>
    .text-orange { color: #ff8c00; }
    .bg-orange { background-color: #ff8c00; color: #000; }
    .x-small { font-size: 0.75rem; }
    .action-icon { font-size: 1.25rem; transition: transform 0.2s; }
    .action-icon:hover { transform: scale(1.2); }
    .square-modal .modal-content {
        background: #0f0f0f;
        border: 1px solid rgba(255,140,0,0.2) !important;
        border-radius: 20px;
        max-width: 320px;
        margin: auto;
    }
    .minimal-btn {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        color: #fff;
        padding: 12px;
        border-radius: 12px;
        width: 100%;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.2s;
    }
    .minimal-btn:hover {
        background: rgba(255,140,0,0.1);
        border-color: #ff8c00;
        color: #ff8c00;
    }
</style>

<!-- Logistics Control Modal -->
<div class="modal fade" id="logisticsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered square-modal">
        <div class="modal-content">
            <div class="modal-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <div class="text-secondary x-small text-uppercase ls-1">Parcel Control</div>
                        <div class="fw-bold text-white fs-5" id="logTrackingId">#—</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div id="logSortSection" class="mb-2">
                    <form asp-action="MarkSortedForDestination" method="post">
                        <input type="hidden" name="trackingId" id="logSortTrackingId" />
                        <button type="submit" class="minimal-btn">
                            <i class="bi bi-shuffle text-info"></i>
                            <span id="logSortBtn">Sort for Transfer</span>
                        </button>
                    </form>
                </div>

                <div id="logDispatchSection" class="mb-2">
                    <a asp-action="HubTransfers" class="minimal-btn">
                        <i class="bi bi-send-fill text-success"></i>
                        <span>Dispatch to Hub</span>
                    </a>
                    <input type="hidden" id="logDispatchTrackingId" />
                </div>

                <div id="logReturnSection" class="mb-2">
                    <form asp-action="ShipBackToOrigin" method="post">
                        <input type="hidden" name="trackingId" id="logReturnTrackingId" />
                        <button type="submit" class="minimal-btn text-danger">
                            <i class="bi bi-arrow-left-right"></i>
                            <span>Return to Origin</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Assign Rider Modal -->
<div class="modal fade" id="assignModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered square-modal">
        <div class="modal-content">
            <div class="modal-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <div class="text-secondary x-small text-uppercase ls-1">Assign Delivery</div>
                        <div class="fw-bold text-white fs-5" id="assignTrackingId">#—</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <form asp-action="AssignRider" method="post" id="assignRiderForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="trackingId" id="assignFormTrackingId" />
                    <div class="mb-3">
                        <label class="text-secondary x-small mb-2 d-block">Select Available Rider</label>
                        <select name="riderId" id="assignRiderSelect" class="form-select bg-dark text-white border-secondary border-opacity-25" style="border-radius: 10px;">
                            <option value="">Choose Rider...</option>
                            <optgroup label="System User Riders">
                                @foreach (var r in (ViewBag.AvailableRiders as IEnumerable<ApplicationUser> ?? new List<ApplicationUser>())) {
                                    <option value="user_@r.Id">@r.FirstName @r.LastName</option>
                                }
                            </optgroup>
                            <optgroup label="Manual Riders">
                                @foreach (var r in (ViewBag.ManualRiders as IEnumerable<ManualRider> ?? new List<ManualRider>())) {
                                    <option value="manual_@r.Id">@r.Name</option>
                                }
                            </optgroup>
                        </select>
                    </div>
                    <button type="button" class="btn btn-warning w-100 fw-bold py-3" style="border-radius: 12px;" onclick="assignRider()">
                        <i class="bi bi-person-check-fill me-2"></i> Assign Now
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>