@model IEnumerable<SwiftFill.Models.Order>
@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Packing Line";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="dashboard-title text-success"><i class="bi bi-box-seam-fill me-3"></i> Packing Line</h1>
</div>

<div class="module-toolbar">
    <div class="search-container">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Search Packing Queue..." />
    </div>
    <div class="d-flex gap-2">
        <a href="#" class="filter-btn"><i class="bi bi-funnel"></i> Filter</a>
    </div>
</div>

<div class="table-container border-top border-success border-3">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tracking ID</th>
                <th>Items</th>
                <th>Packing Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td class="text-success fw-bold">#@item.TrackingId</td>
                    <td>@item.ItemCategory</td>
                    <td><span class="badge bg-success bg-opacity-10 text-success border border-success">Ready for Box</span></td>
                    <td>
                        <form asp-action="MarkPacked" method="post">
                            <input type="hidden" name="trackingId" value="@item.TrackingId" />
                            <button type="submit" class="btn btn-sm btn-success fw-bold px-4">Seal & Pack</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="pagination-container">
        <div class="page-info">Showing 1 to @Model.Count() of @Model.Count() entries</div>
        <div class="btn-group">
            <button class="btn btn-sm btn-outline-secondary disabled">Previous</button>
            <button class="btn btn-sm btn-secondary">1</button>
            <button class="btn btn-sm btn-outline-secondary disabled">Next</button>
        </div>
    </div>
</div>