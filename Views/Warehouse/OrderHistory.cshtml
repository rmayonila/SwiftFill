@model IEnumerable<SwiftFill.Models.Order>
@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Order History";
    var currentHub = ViewBag.CurrentHub as string ?? "Hub";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-clock-history text-orange me-2"></i> Order History</h2>
        <div class="text-secondary small">Hub: <span class="text-orange fw-bold">@currentHub</span></div>
    </div>

    <!-- Integrated Filter Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px; position: relative;">
                    <i class="bi bi-search" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #6c757d;"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           style="background: #111; border: 1px solid #222; border-radius: 8px; padding: 10px 15px 10px 40px; color: #fff; outline: none;"
                           placeholder="Search Tracking ID, Receiver...">
                </div>
            </form>
        </div>
        <div class="d-flex align-items-center gap-3">
             <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 fw-bold border border-success border-opacity-10">@Model.Count() COMPLETED</span>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr class="text-secondary small text-uppercase">
                        <th class="ps-4 py-3">Shipment Identity</th>
                        <th class="py-3">Completion Details</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                            <td class="ps-4 py-3">
                                <code class="text-orange fw-bold d-block">#@item.TrackingId</code>
                                <div class="text-white small">@item.ReceiverName</div>
                                <div class="text-secondary x-small"><i class="bi bi-geo-alt me-1"></i>@item.ReceiverAddress</div>
                            </td>
                            <td class="py-3">
                                <div class="text-white small">
                                    <i class="bi bi-calendar-check me-1"></i> @item.UpdatedAt.ToString("MMM dd, yyyy HH:mm")
                                </div>
                                <div class="text-secondary x-small">
                                    Attempts: @item.DeliveryAttempts • @(item.ItemCategory ?? "General")
                                </div>
                            </td>
                            <td class="py-3">
                                @{
                                    var statusClass = item.Status == "Delivered" ? "border-success text-success" : "border-danger text-danger";
                                }
                                <span class="badge border bg-transparent px-2 py-1 @statusClass" style="font-size: 0.65rem;">
                                    @item.Status.ToUpper()
                                </span>
                            </td>
                            <td class="py-3 pe-4 text-end">
                                    <button class="btn btn-link text-info p-0 action-icon" onclick="viewDetails('@item.TrackingId')" title="View Details">
                                        <i class="bi bi-info-circle-fill"></i>
                                    </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-secondary border-0">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                No completed shipments found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link @(ViewBag.CurrentPage == i ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?page=@i&search=@ViewBag.Search">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search">Next</a>
                </li>
            </ul>
        </div>
    }
</div>

<!-- POD Modal -->
<div class="modal fade" id="podModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #0f0f0f; border: 1px solid rgba(25, 135, 84, 0.2); border-radius: 20px;">
            <div class="modal-body p-4 text-center">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="text-start">
                        <div class="text-success x-small text-uppercase ls-1">Proof of Delivery</div>
                        <div class="fw-bold text-white fs-5" id="podTrackingId">#—</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <img id="podImage" src="" class="img-fluid rounded-3 shadow-lg" style="max-height: 500px; width: 100%; object-fit: cover; border: 1px solid rgba(255,255,255,0.05);" />
            </div>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #0f0f0f; border: 1px solid rgba(255,140,0,0.2); border-radius: 20px;">
            <div class="modal-body p-4" id="detailsContent">
                <div class="text-center py-4">
                    <div class="spinner-border text-orange" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function viewPOD(url, tid) {
            document.getElementById('podImage').src = url;
            document.getElementById('podTrackingId').textContent = '#' + tid;
            new bootstrap.Modal(document.getElementById('podModal')).show();
        }

        function viewDetails(tid) {
            const modal = new bootstrap.Modal(document.getElementById('detailsModal'));
            document.getElementById('detailsContent').innerHTML = '<div class="text-center py-4"><div class="spinner-border text-orange" role="status"></div></div>';
            modal.show();
            
            fetch('/Warehouse/GetOrderDetails?trackingId=' + tid)
                .then(r => r.text())
                .then(html => {
                    document.getElementById('detailsContent').innerHTML = html;
                });
        }
    </script>
}

<style>
    .bg-orange { background-color: #ff8c00; color: #000; }
    .x-small { font-size: 0.75rem; }
    .action-icon { font-size: 1.25rem; transition: transform 0.2s; }
    .action-icon:hover { transform: scale(1.2); }
    .minimal-input { background: #111; border: 1px solid #222; border-radius: 8px; padding: 10px 15px; color: #fff; outline: none; }
</style>
