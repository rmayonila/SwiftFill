@model SwiftFill.Models.AdminDashboardViewModel
@using SwiftFill.Models
@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Warehouse Dispatch";
    var currentHub = Model.CurrentHub;
    var hubInfo = HubRegistry.All.FirstOrDefault(h => h.Name == currentHub);
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-speedometer2 me-2"></i> Warehouse Dispatch</h1>
        <div class="text-secondary small">Hub: <span class="text-orange fw-bold">@currentHub</span></div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="glass-card p-3 border-0 border-start border-warning border-4 d-flex justify-content-between align-items-center" style="background: rgba(255, 255, 255, 0.02);">
                <div>
                    <div class="stat-label text-orange">Inbound Volume</div>
                    <div class="text-secondary x-small">Awaiting Arrival</div>
                </div>
                <div class="stat-value text-white h2 mb-0">@Model.InTransit</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-3 border-0 border-start border-info border-4 d-flex justify-content-between align-items-center" style="background: rgba(255, 255, 255, 0.02);">
                <div>
                    <div class="stat-label text-info">In Processing</div>
                    <div class="text-secondary x-small">Hub Sorting</div>
                </div>
                <div class="stat-value text-white h2 mb-0">@(Model.PendingPickOrders.Count + Model.PickedOrders.Count)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-3 border-0 border-start border-success border-4 d-flex justify-content-between align-items-center" style="background: rgba(255, 255, 255, 0.02);">
                <div>
                    <div class="stat-label text-success">Outbound Ready</div>
                    <div class="text-secondary x-small">Sorted for Dispatch</div>
                </div>
                <div class="stat-value text-white h2 mb-0">@Model.PackedOrders.Count</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-3 border-0 border-start border-danger border-4 d-flex justify-content-between align-items-center" style="background: rgba(255, 255, 255, 0.02);">
                <div>
                    <div class="stat-label text-danger">Active Returns</div>
                    <div class="text-secondary x-small">Returning to Sender</div>
                </div>
                <div class="stat-value text-white h2 mb-0">@Model.ReturningOrders.Count</div>
            </div>
        </div>
    </div>
</div>

<div class="glass-card p-0 overflow-hidden border-0 mb-5" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05) !important;">
    <div class="d-flex justify-content-between align-items-center p-4 pb-3">
        <h6 class="text-uppercase text-secondary ls-1 mb-0">Recent Hub Activity — @currentHub</h6>
        <a asp-action="HubTransfers" class="text-orange text-decoration-none small">View All <i class="bi bi-arrow-right ms-1"></i></a>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead style="background: rgba(255,140,0,0.03);">
                <tr class="text-secondary small text-uppercase">
                    <th class="border-0 ps-4 py-3">Tracking ID</th>
                    <th class="border-0 py-3">Package & Info</th>
                    <th class="border-0 py-3">Destination</th>
                    <th class="border-0 py-3">Status</th>
                    <th class="border-0 text-end pe-4 py-3">Last Updated</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.RecentShipments.Take(8))
                {
                    var destHub = HubRegistry.ResolveDestinationHub(item.DestinationRegion);
                    string targetAction = "WarehouseQueue";
                    string targetController = "Warehouse";
                    
                    if (item.Status.Contains("In Transit to " + currentHub)) {
                        targetAction = "HubTransfers";
                    } else if (item.Status.Contains("Arrived at " + currentHub) || item.Status == "Out for Delivery") {
                        if (destHub == currentHub) {
                            targetAction = "Index";
                            targetController = "RiderInfo";
                        } else {
                            targetAction = "HubTransfers";
                        }
                    } else if (item.Status == "Sorted for Transfer") {
                        targetAction = "HubTransfers";
                    } else if (item.Status == "Delivered" || item.Status == "Returned") {
                        targetAction = "OrderHistory";
                    }

                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                        <td class="border-0 ps-4 py-3">
                            <code class="text-orange fw-bold d-block">#@item.TrackingId</code>
                            <div class="text-secondary x-small">@item.ReceiverName</div>
                        </td>
                        <td class="border-0 py-3">
                            <div class="text-white small">@(item.ItemCategory ?? "General") • @item.Weight kg</div>
                            @if (item.IsFragile)
                            {
                                <span class="badge border border-warning text-warning x-small" style="font-size: 0.6rem;">FRAGILE</span>
                            }
                        </td>
                        <td class="border-0 py-3">
                            <div class="text-white small">@item.DestinationRegion</div>
                            <div class="text-secondary x-small">→ @destHub</div>
                        </td>
                        <td class="border-0 py-3">
                            @{
                                var statusClass = item.Status == "Delivered" ? "border-success text-success" : 
                                                 (item.Status.Contains("Arrived") ? "border-primary text-primary" : 
                                                 (item.Status.Contains("Transit") ? "border-info text-info" : 
                                                 (item.Status == "Returning to Sender" ? "border-danger text-danger" : "border-warning text-warning")));
                            }
                            <span class="badge border bg-transparent px-3 @statusClass" style="font-size: 0.65rem;">
                                @item.Status
                            </span>
                        </td>
                        <td class="border-0 py-3 text-end pe-4">
                            <div class="text-white small">@item.UpdatedAt.ToString("MMM dd")</div>
                            <div class="x-small text-secondary">@item.UpdatedAt.ToString("HH:mm")</div>
                        </td>
                    </tr>
                }
                @if (!Model.RecentShipments.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-secondary border-0">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            No recent activity in this hub.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        function assignRider(trackingId) {
            const riderId = document.getElementById('rider-' + trackingId).value;
            if (!riderId) {
                alert('Please select a rider first');
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Warehouse/AssignRider';

            const tid = document.createElement('input');
            tid.type = 'hidden';
            tid.name = 'trackingId';
            tid.value = trackingId;

            const rid = document.createElement('input');
            rid.type = 'hidden';
            rid.name = 'riderId';
            rid.value = riderId;

            const rvt = document.createElement('input');
            rvt.type = 'hidden';
            rvt.name = '__RequestVerificationToken';
            rvt.value = token;

            form.appendChild(tid);
            form.appendChild(rid);
            form.appendChild(rvt);
            document.body.appendChild(form);
            form.submit();
        }

        function filterTable(query) {
            const q = query.toLowerCase();
            document.querySelectorAll('#queueTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
}