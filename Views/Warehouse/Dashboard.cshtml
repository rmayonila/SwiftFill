@model SwiftFill.Models.AdminDashboardViewModel
@using SwiftFill.Models
@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Warehouse Dispatch";
    var currentHub = Model.CurrentHub;
    var hubInfo = HubRegistry.All.FirstOrDefault(h => h.Name == currentHub);
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h1 class="dashboard-title">
        <i class="bi bi-building-gear me-3"></i> Warehouse Dispatch
    </h1>
    <div class="d-flex align-items-center gap-3 flex-wrap">
        <div style="background: rgba(255,140,0,0.08); border: 1px solid rgba(255,140,0,0.25); border-radius: 10px; padding: 8px 16px;">
            <div style="font-size: 0.65rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px;">Your Hub</div>
            <div style="font-size: 0.9rem; font-weight: 700; color: #ff8c00;">
                <i class="bi bi-geo-alt-fill me-1"></i>@currentHub
            </div>
            @if (hubInfo != null)
            {
                <div style="font-size: 0.7rem; color: rgba(255,255,255,0.35);">@hubInfo.Region · @hubInfo.Island</div>
            }
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="stat-card yellow">
            <div class="stat-label">Pending Pick</div>
            <div class="stat-value">@Model.PendingPickOrders.Count</div>
            <div class="stat-subtext">Awaiting Warehouse Staff</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card blue">
            <div class="stat-label">In Packing</div>
            <div class="stat-value">@Model.PickedOrders.Count</div>
            <div class="stat-subtext">Currently at Packing Table</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card green">
            <div class="stat-label">Ready to Ship</div>
            <div class="stat-value">@Model.PackedOrders.Count</div>
            <div class="stat-subtext">Packed & Sealed</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card red">
            <div class="stat-label">Inbound</div>
            <div class="stat-value">@Model.RecentShipments.Count(s => s.Status.Contains($"Transit to {currentHub}"))</div>
            <div class="stat-subtext">Arriving at @currentHub</div>
        </div>
    </div>
</div>

<div class="module-toolbar">
    <div class="d-flex gap-2 align-items-center w-100 flex-wrap">
        <div class="search-container flex-grow-1">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Search Tracking ID, Receiver..." oninput="filterTable(this.value)" />
        </div>
        <form asp-action="QuickReceive" method="post" class="d-flex gap-2">
            <div class="search-container" style="max-width: 250px;">
                <i class="bi bi-qr-code-scan"></i>
                <input type="text" name="trackingId" placeholder="Scan to Receive..." required autocomplete="off" />
            </div>
            <button type="submit" class="btn btn-primary fw-bold" style="border-radius: 8px;">Receive</button>
        </form>
    </div>
</div>

<div class="table-container">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h5 class="m-0 fw-bold">Queue — @currentHub</h5>
        <span class="badge bg-dark border border-secondary text-secondary">@Model.RecentShipments.Count parcels</span>
    </div>

    @*
        LEGEND — Action logic per parcel (no fixed "Origin Hub"):
        • CurrentLocation == currentHub + Status "Pending"  → PICK
        • CurrentLocation == currentHub + Status "Picked"   → PACK
        • CurrentLocation == currentHub + Status "Packed"   → SHIP (dispatch to next hub)
        • Status contains "In Transit to currentHub"        → RECEIVE (staff at destination hub)
        • Status starts with "Arrived at currentHub"
             + DeliveryType "DoorToDoor"                    → ASSIGN RIDER
             + DeliveryType "BranchPickup"                  → READY FOR PICKUP
    *@

    <table class="table" id="queueTable">
        <thead>
            <tr>
                <th>Tracking ID</th>
                <th>Receiver</th>
                <th>Destination</th>
                <th>Delivery Type</th>
                <th>Status / Location</th>
                <th>Assign Rider</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.RecentShipments)
            {
                @* Determine what action this hub can do for this parcel *@
                var isLocal    = item.CurrentLocation == currentHub;
                var isInbound  = item.Status.Contains($"Transit to {currentHub}");
                var isArrived  = item.Status.StartsWith($"Arrived at {currentHub}");
                var canPick    = isLocal && item.Status == "Pending";
                var canPack    = isLocal && item.Status == "Picked";
                var canShip    = isLocal && (item.Status == "Packed" || item.Status == "Sorted for Transfer");
                var canReceive = isInbound;
                var isFinalDest = HubRegistry.ResolveDestinationHub(item.DestinationRegion) == currentHub;
                var canSort    = isArrived && !item.Status.Contains("Sorted") && !isFinalDest;
                var canRider   = isArrived && item.DeliveryType == "DoorToDoor" && !canSort;
                var isPickup   = isArrived && item.DeliveryType == "BranchPickup" && !canSort;

                <tr>
                    <td class="text-warning fw-bold">#@item.TrackingId</td>
                    <td>
                        <div class="fw-semibold text-white">@item.ReceiverName</div>
                        <div class="small text-secondary">@item.ReceiverAddress</div>
                    </td>
                    <td>@item.DestinationRegion</td>
                    <td>
                        @if (item.DeliveryType == "BranchPickup")
                        {
                            <span class="badge" style="background:rgba(13,202,240,0.1);color:#0dcaf0;border:1px solid rgba(13,202,240,0.3);">
                                <i class="bi bi-building me-1"></i>Branch Pickup
                            </span>
                        }
                        else
                        {
                            <span class="badge" style="background:rgba(255,140,0,0.1);color:#ff8c00;border:1px solid rgba(255,140,0,0.3);">
                                <i class="bi bi-truck me-1"></i>Door-to-Door
                            </span>
                        }
                    </td>
                    <td>
                        <div>
                            <span class="badge bg-secondary p-2" style="font-size:0.7rem;">@item.Status</span>
                        </div>
                        <div class="small text-secondary mt-1">
                            <i class="bi bi-geo-alt me-1"></i>@item.CurrentLocation
                        </div>
                    </td>
                    <td>
                        @if (canRider)
                        {
                            <select class="form-select form-select-sm bg-dark text-white border-secondary rider-select" id="rider-@item.TrackingId" data-address="@item.ReceiverAddress">
                                <option value="">Select Rider</option>
                                @foreach (var rider in Model.AvailableRiders)
                                {
                                    <option value="@rider.Id">@rider.FirstName @rider.LastName</option>
                                }
                                @foreach (var rider in Model.ManualRiders.Where(r => item.ReceiverAddress.Contains(r.Route, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <option value="@rider.Id">@rider.Name (@rider.Route)</option>
                                }
                            </select>
                        }
                        else if (isPickup)
                        {
                            <span class="text-info small">No rider needed</span>
                        }
                        else
                        {
                            <span class="text-secondary small">—</span>
                        }
                    </td>
                    <td>
                        <div class="btn-group">
                            @if (canPick)
                            {
                                <form asp-action="MarkPicked" method="post">
                                    <input type="hidden" name="trackingId" value="@item.TrackingId" />
                                    <button type="submit" class="btn btn-sm btn-warning">
                                        <i class="bi bi-box2-heart me-1"></i>Pick
                                    </button>
                                </form>
                            }
                            else if (canPack)
                            {
                                <form asp-action="MarkPacked" method="post">
                                    <input type="hidden" name="trackingId" value="@item.TrackingId" />
                                    <button type="submit" class="btn btn-sm btn-info text-white">
                                        <i class="bi bi-box-seam me-1"></i>Pack
                                    </button>
                                </form>
                            }
                            else if (canShip)
                            {
                                <form asp-action="MarkShipped" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="trackingId" value="@item.TrackingId" />
                                    <select name="targetHub" class="form-select form-select-sm bg-dark text-white border-secondary" style="width: 130px;" required>
                                        <option value="">Next Hub</option>
                                        @foreach(var h in Model.Hubs.Where(x => x != currentHub))
                                        {
                                            <option value="@h">@h</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-send-fill"></i>
                                    </button>
                                </form>
                            }
                            else if (canSort)
                            {
                                <form asp-action="MarkSorted" method="post">
                                    <input type="hidden" name="trackingId" value="@item.TrackingId" />
                                    <button type="submit" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-filter-circle me-1"></i>Sort for Transfer
                                    </button>
                                </form>
                            }
                            else if (canReceive)
                            {
                                <form asp-action="MarkReceived" method="post">
                                    <input type="hidden" name="trackingId" value="@item.TrackingId" />
                                    <button type="submit" class="btn btn-sm btn-primary">
                                        <i class="bi bi-check2-circle me-1"></i>Receive
                                    </button>
                                </form>
                            }
                            else if (canRider)
                            {
                                <button class="btn btn-sm btn-success" onclick="assignRider('@item.TrackingId')">
                                    <i class="bi bi-scooter me-1"></i>Assign Rider
                                </button>
                            }
                            else if (isPickup)
                            {
                                <span class="badge py-2 px-3" style="background:rgba(13,202,240,0.1);color:#0dcaf0;border:1px solid rgba(13,202,240,0.3);">
                                    Ready for Pickup
                                </span>
                            }
                            else
                            {
                                <span class="text-secondary small">@item.Status</span>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.RecentShipments.Any())
            {
                <tr>
                    <td colspan="7" class="text-center py-5 text-secondary">
                        <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
                        No parcels found for <strong>@currentHub</strong>.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function assignRider(trackingId) {
            const select = document.getElementById(`rider-${trackingId}`);
            if (!select || !select.value) {
                alert("Please select a rider first!");
                return;
            }
            fetch('/Warehouse/AssignRider', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `trackingId=${encodeURIComponent(trackingId)}&riderId=${encodeURIComponent(select.value)}`
            }).then(() => location.reload());
        }

        function filterTable(query) {
            const q = query.toLowerCase();
            document.querySelectorAll('#queueTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
}