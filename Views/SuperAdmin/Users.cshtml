@model IEnumerable<SwiftFill.Models.UserManagementViewModel>

@{
    ViewData["Title"] = "Users & Roles - SwiftFill";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Top Header Profile Area -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h2 class="fw-bold fs-3 mt-2 mb-0 text-white">Users & Roles</h2>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Manage system access, identities, and permissions.</p>
        </div>
        <div>
            <button class="btn btn-warning" style="border-radius: 8px; padding: 8px 16px; font-weight: 600; color: #000;" data-bs-toggle="modal" data-bs-target="#registerUserModal">
                <i class="bi bi-person-plus-fill me-2"></i> Register New User
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 border-success border-opacity-25 text-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-25 text-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search & Filter Bar -->
    <div class="minimal-filter-bar mb-4 p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <form method="get" class="d-flex w-100 gap-3 align-items-center">
            <div class="search-wrapper flex-grow-1">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                       placeholder="Search email, first name, or last name...">
            </div>
            <select name="role" class="minimal-input" style="width: 150px; background: transparent; border: none;" onchange="this.form.submit()">
                <option value="">All Roles</option>
                <option value="Admin" selected="@(ViewBag.Role == "Admin")">Admin</option>
                <option value="WarehouseStaff" selected="@(ViewBag.Role == "WarehouseStaff")">Warehouse Staff</option>
                <option value="DeliveryRider" selected="@(ViewBag.Role == "DeliveryRider")">Delivery Rider</option>
                <option value="SuperAdmin" selected="@(ViewBag.Role == "SuperAdmin")">SuperAdmin</option>
            </select>
            <button type="submit" class="btn btn-sm btn-warning px-4 py-2 border-0 shadow-sm text-dark fw-bold">Filter</button>
        </form>
    </div>

    <!-- User Management Table -->
    <div class="card premium-card border-0 shadow-lg" style="background: rgba(22, 27, 34, 0.9); backdrop-filter: blur(14px); border-radius: 12px; border: 1px solid #30363d !important; overflow: hidden;">
        <div class="card-header bg-transparent border-bottom border-dark py-3 px-4 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold d-flex align-items-center text-white">
                <i class="bi bi-people-fill text-orange me-3" style="font-size: 1.2rem;"></i> 
                All System Users
            </h6>
        </div>
        
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <thead style="background: rgba(0,0,0,0.3);">
                        <tr>
                            <th class="ps-4 py-3 text-secondary fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">User Identity</th>
                            <th class="py-3 text-secondary fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Username</th>
                            <th class="py-3 text-secondary fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Role & Permissions</th>
                            <th class="py-3 text-secondary fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Hub Assignment</th>
                            <th class="py-3 text-secondary fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Status</th>
                            <th class="pe-4 py-3 text-secondary fw-semibold text-uppercase text-end" style="font-size: 0.75rem; letter-spacing: 1px;">Controls</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var user = item.User;
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle d-flex justify-content-center align-items-center me-3 flex-shrink-0" style="width: 35px; height: 35px; background: rgba(255, 140, 0, 0.15); color: #ff8c00; font-weight:bold;">
                                            @((!string.IsNullOrEmpty(user.FirstName) ? user.FirstName.Substring(0,1).ToUpper() : "U"))
                                        </div>
                                        <div>
                                            <div class="fw-bold text-white mb-1" style="font-size: 0.95rem;">@user.FirstName @user.LastName</div>
                                            <div class="text-secondary" style="font-size: 0.75rem;">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                
                                <td class="py-3">
                                    <code class="text-orange">@user.UserName</code>
                                </td>
                                
                                <td class="py-3">
                                    <span class="badge bg-orange text-dark mb-1">@item.Role</span>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach(var claim in item.Claims)
                                        {
                                            <span class="text-secondary" style="font-size: 0.65rem; border: 1px solid #30363d; padding: 1px 4px; border-radius: 4px;">@claim</span>
                                        }
                                        @if(!item.Claims.Any()){ <span class="text-muted smaller">No specific claims</span> }
                                    </div>
                                </td>

                                <td class="py-3">
                                    <div class="d-flex align-items-center text-white-50 small">
                                        <i class="bi bi-geo-alt-fill text-orange me-2"></i>
                                        @(user.Hub ?? "No Hub Assigned")
                                    </div>
                                </td>
                                
                                <td class="py-3">
                                    @if(user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow) 
                                    { 
                                        <span class="badge" style="background: rgba(220, 53, 69, 0.2); color:#ff6b6b; border: 1px solid rgba(220, 53, 69, 0.4); padding: 5px 10px;">
                                            <i class="bi bi-person-x-fill me-1"></i> Suspended
                                        </span> 
                                    }
                                    else if(user.EmailConfirmed) 
                                    { 
                                        <span class="badge" style="background: rgba(46, 160, 67, 0.2); color:#6bff72; border: 1px solid rgba(46, 160, 67, 0.4); padding: 5px 10px;">
                                            <i class="bi bi-check-circle-fill me-1"></i> Active
                                        </span> 
                                    }
                                    else 
                                    { 
                                        <span class="badge" style="background: rgba(210, 153, 34, 0.2); color:#e3b341; border: 1px solid rgba(210, 153, 34, 0.4); padding: 5px 10px;">
                                            <i class="bi bi-exclamation-circle-fill me-1"></i> Pending
                                        </span> 
                                    }
                                </td>
                                
                                <td class="pe-4 py-3 text-end">
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-dark border-secondary text-secondary hover-white" title="Manage Roles" 
                                                onclick="openManageRolesModal('@user.Id', '@user.FirstName @user.LastName', '@item.Role', '@string.Join(",", item.Claims)', '@(user.Hub ?? "None")')">
                                            <i class="bi bi-shield-lock"></i>
                                        </button>
                                        <button class="btn btn-sm btn-dark border-secondary text-secondary hover-white" title="Edit Profile" 
                                                onclick="openEditProfileModal('@user.Id', '@user.UserName', '@user.FirstName', '@user.LastName', '@user.PhoneNumber', '@user.Hub')">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <form asp-action="SuspendUser" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-dark border-danger text-danger hover-white" title="@(user.LockoutEnd > DateTimeOffset.UtcNow ? "Reactivate" : "Suspend")">
                                                <i class="bi @(user.LockoutEnd > DateTimeOffset.UtcNow ? "bi-person-check-fill" : "bi-person-x-fill")"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        
                        @if(!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    No underlying users found securely in the database.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-transparent border-top border-dark py-3">
                <div class="d-flex justify-content-center">
                    <nav>
                        <ul class="pagination pagination-sm m-0" style="--bs-pagination-bg: transparent; --bs-pagination-border-color: rgba(255,255,255,0.1); --bs-pagination-color: #fff; --bs-pagination-hover-bg: rgba(255,255,255,0.1); --bs-pagination-hover-color: #fff; --bs-pagination-active-bg: #ff8c00; --bs-pagination-active-border-color: #ff8c00;">
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="?search=@ViewBag.Search&role=@ViewBag.Role&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                            </li>
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="?search=@ViewBag.Search&role=@ViewBag.Role&page=@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?search=@ViewBag.Search&role=@ViewBag.Role&page=@(ViewBag.CurrentPage + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>
</div>

<!-- Register New User Modal -->
<div class="modal fade" id="registerUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white" style="background: rgba(22, 27, 34, 0.95); backdrop-filter: blur(10px); border: 1px solid #30363d; border-radius: 12px;">
            <div class="modal-header border-dark">
                <h5 class="modal-title fw-bold"><i class="bi bi-person-plus-fill text-warning me-2"></i> Register New User</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="RegisterUser" method="post">
                <div class="modal-body">
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label text-secondary small">First Name</label>
                            <input type="text" name="FirstName" class="form-control bg-dark border-secondary text-white shadow-none" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-secondary small">Last Name</label>
                            <input type="text" name="LastName" class="form-control bg-dark border-secondary text-white shadow-none" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Username</label>
                        <input type="text" name="UserName" class="form-control bg-dark border-secondary text-white shadow-none" placeholder="Enter username" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Email Address</label>
                        <input type="email" name="Email" class="form-control bg-dark border-secondary text-white shadow-none" placeholder="Enter email" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Password</label>
                        <input type="password" name="Password" class="form-control bg-dark border-secondary text-white shadow-none" placeholder="Enter password" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Assign Primary Role</label>
                        <select name="Role" id="reg_role" class="form-select bg-dark border-secondary text-white shadow-none" onchange="updateDefaultPermissions(this.value)">
                            <option value="">Select Role</option>
                            <option value="Admin">In-store Manager</option>
                            <option value="WarehouseStaff">Warehouse Staff Account</option>
                            <option value="DeliveryRider">Delivery Rider</option>
                            <option value="Customer">Customer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">ASSIGN HUB</label>
                        <select name="Hub" class="form-select bg-dark border-secondary text-white shadow-none">
                            <option value="">No Hub Assignment</option>
                            @foreach(var hub in (ViewBag.AllHubNames as List<string>) ?? SwiftFill.Models.HubRegistry.Names) {
                                <option value="@hub">@hub</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-secondary small d-block mb-3">Module Access Rights (Granular RBAC)</label>
                        
                        <div class="row g-3">
                            <!-- Shipments -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-warning small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Shipments</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Shipments.View" id="p_s_v">
                                            <label class="form-check-label text-secondary" for="p_s_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Shipments.Edit" id="p_s_e">
                                            <label class="form-check-label text-secondary" for="p_s_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Inventory -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-info small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Inventory</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Inventory.View" id="p_i_v">
                                            <label class="form-check-label text-secondary" for="p_i_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Inventory.Edit" id="p_i_e">
                                            <label class="form-check-label text-secondary" for="p_i_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Finance -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-success small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Finance & Billing</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Finance.View" id="p_f_v">
                                            <label class="form-check-label text-secondary" for="p_f_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Finance.Edit" id="p_f_e">
                                            <label class="form-check-label text-secondary" for="p_f_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Delivery -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-primary small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Delivery Operations</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Delivery.View" id="p_d_v">
                                            <label class="form-check-label text-secondary" for="p_d_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Delivery.Edit" id="p_d_e">
                                            <label class="form-check-label text-secondary" for="p_d_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Settings -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-danger small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">System Admin</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Users.Edit" id="p_u_e">
                                            <label class="form-check-label text-secondary" for="p_u_e">Users</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="Permissions" value="@Permissions.Hubs.Edit" id="p_h_e">
                                            <label class="form-check-label text-secondary" for="p_h_e">Hubs</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-dark">
                    <button type="button" class="btn btn-dark border-secondary text-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-bold text-dark">Create Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Manage Roles & Claims Modal -->
<div class="modal fade" id="manageRolesModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white" style="background: rgba(22, 27, 34, 0.95); border: 1px solid #30363d; border-radius: 12px;">
            <div class="modal-header border-dark">
                <h5 class="modal-title fw-bold"><i class="bi bi-shield-lock text-info me-2"></i> Manage Permissions</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateRoles" method="post">
                <div class="modal-body text-center py-4">
                    <input type="hidden" name="userId" id="manage_userId" />
                    <div class="mb-4">
                        <p class="mb-1">Adjusting permissions for <strong id="manage_userName" class="text-warning">User</strong></p>
                        <p class="small text-secondary mb-0">Managing Access for Hub: <span id="manage_hubDisplay" class="text-info fw-bold">None</span></p>
                    </div>
                    
                    <div class="text-start px-4">
                        <label class="form-label text-secondary small">Primary Role</label>
                        <select name="role" id="manage_role" class="form-select bg-dark border-secondary text-white mb-3">
                            <option value="SuperAdmin">SuperAdmin</option>
                            <option value="Admin">In-store Manager</option>
                            <option value="WarehouseStaff">Warehouse Staff Account</option>
                            <option value="DeliveryRider">Delivery Rider</option>
                            <option value="Customer">Customer</option>
                        </select>

                        <label class="form-label text-secondary small d-block mb-3">Module Access Rights (Granular RBAC)</label>
                        <div class="row g-3">
                            <!-- Shipments -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-warning small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Shipments</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Shipments.View" id="e_s_v">
                                            <label class="form-check-label text-secondary" for="e_s_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Shipments.Edit" id="e_s_e">
                                            <label class="form-check-label text-secondary" for="e_s_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Inventory -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-info small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Inventory</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Inventory.View" id="e_i_v">
                                            <label class="form-check-label text-secondary" for="e_i_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Inventory.Edit" id="e_i_e">
                                            <label class="form-check-label text-secondary" for="e_i_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Finance -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-success small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Finance</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Finance.View" id="e_f_v">
                                            <label class="form-check-label text-secondary" for="e_f_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Finance.Edit" id="e_f_e">
                                            <label class="form-check-label text-secondary" for="e_f_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Delivery -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-primary small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">Delivery Operations</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Delivery.View" id="e_d_v">
                                            <label class="form-check-label text-secondary" for="e_d_v">View</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Delivery.Edit" id="e_d_e">
                                            <label class="form-check-label text-secondary" for="e_d_e">Edit</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Admin -->
                            <div class="col-md-6">
                                <div class="p-2 rounded border border-dark bg-black bg-opacity-50">
                                    <div class="text-danger small fw-bold mb-2 text-uppercase" style="font-size:0.65rem;">System</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Users.Edit" id="e_u_e">
                                            <label class="form-check-label text-secondary" for="e_u_e">Users</label>
                                        </div>
                                        <div class="form-check small">
                                            <input class="form-check-input" type="checkbox" name="permissions" value="@Permissions.Hubs.Edit" id="e_h_e">
                                            <label class="form-check-label text-secondary" for="e_h_e">Hubs</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-dark">
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info text-dark fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white" style="background: rgba(22, 27, 34, 0.95); border: 1px solid #30363d; border-radius: 12px;">
            <div class="modal-header border-dark">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square text-success me-2"></i> Edit Profile</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateProfile" method="post">
                <div class="modal-body py-4">
                    <input type="hidden" name="userId" id="edit_userId" />
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label text-secondary small">First Name</label>
                            <input type="text" name="firstName" id="edit_firstName" class="form-control bg-dark border-secondary text-white" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-secondary small">Last Name</label>
                            <input type="text" name="lastName" id="edit_lastName" class="form-control bg-dark border-secondary text-white" required>
                        </div>
                    </div>
                    <label class="form-label text-secondary small">Username</label>
                    <input type="text" name="userName" id="edit_userName" class="form-control bg-dark border-secondary text-white mb-3" required>
                    
                    <label class="form-label text-secondary small">Phone Number</label>
                    <input type="text" name="phoneNumber" id="edit_phoneNumber" class="form-control bg-dark border-secondary text-white mb-3" placeholder="+63 9XX XXX XXXX">
                    
                    <label class="form-label text-secondary small">ASSIGN HUB</label>
                    <select name="hub" id="edit_hub" class="form-select bg-dark border-secondary text-white">
                        <option value="">None</option>
                        @foreach(var hub in (ViewBag.AllHubNames as List<string>) ?? SwiftFill.Models.HubRegistry.Names)
                        {
                            <option value="@hub">@hub</option>
                        }
                    </select>

                    <div class="mt-4 pt-3 border-top border-dark">
                        <label class="form-label text-secondary small">Current Password (Encrypted)</label>
                        <input type="text" class="form-control bg-dark border-secondary text-secondary mb-3" value="********" readonly>
                        
                        <label class="form-label text-warning small fw-bold">NEW PASSWORD</label>
                        <input type="password" name="newPassword" class="form-control bg-dark border-warning text-white" placeholder="Enter new password to reset">
                        <div class="form-text text-muted smaller">Leave blank to keep existing password.</div>
                    </div>
                </div>
                <div class="modal-footer border-dark">
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .hover-white:hover {
        color: #ffffff !important;
        background: #30363d !important;
    }
    .fs-xs { font-size: 0.8rem; }
    .bg-orange { background-color: #ff8c00; }
    
    .btn-check:checked + .btn-outline-secondary {
        background-color: #ff8c00;
        border-color: #ff8c00;
        color: #000;
        font-weight: 600;
    }
</style>

<script>
    function updateDefaultPermissions(role) {
        // Reset all checkboxes in the registration modal
        const ids = ['p_s_v', 'p_s_e', 'p_i_v', 'p_i_e', 'p_f_v', 'p_f_e', 'p_u_e', 'p_h_e', 'p_d_v', 'p_d_e'];
        ids.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.checked = false;
        });

        // Define default permissions per role
        const mapping = {
            'Admin': ['Permissions.Shipments.View', 'Permissions.Shipments.Edit', 'Permissions.Shipments.Create', 'Permissions.Inventory.View', 'Permissions.Inventory.Edit', 'Permissions.Finance.View'],
            'WarehouseStaff': ['Permissions.Shipments.View', 'Permissions.Shipments.Edit', 'Permissions.Inventory.View', 'Permissions.Inventory.Edit'],
            'DeliveryRider': ['Permissions.Shipments.View', 'Permissions.Delivery.View', 'Permissions.Delivery.Edit'],
            'Customer': []
        };

        const perms = mapping[role] || [];
        ids.forEach(id => {
            const el = document.getElementById(id);
            if (el && perms.includes(el.value)) {
                el.checked = true;
            }
        });
    }

    function openManageRolesModal(id, name, role, claims, hub) {
        document.getElementById('manage_userId').value = id;
        document.getElementById('manage_userName').textContent = name;
        document.getElementById('manage_role').value = role;
        document.getElementById('manage_hubDisplay').textContent = hub || 'None';
        
        // Reset all granular checkboxes
        const perms = claims.split(',');
        const checkboxIds = ['e_s_v', 'e_s_e', 'e_i_v', 'e_i_e', 'e_f_v', 'e_f_e', 'e_u_e', 'e_h_e', 'e_d_v', 'e_d_e'];
        
        checkboxIds.forEach(id => {
            const checkbox = document.getElementById(id);
            if (checkbox) {
                checkbox.checked = perms.includes(checkbox.value);
            }
        });
        
        new bootstrap.Modal(document.getElementById('manageRolesModal')).show();
    }

    function openEditProfileModal(id, username, first, last, phone, hub) {
        document.getElementById('edit_userId').value = id;
        document.getElementById('edit_userName').value = username;
        document.getElementById('edit_firstName').value = first;
        document.getElementById('edit_lastName').value = last;
        document.getElementById('edit_phoneNumber').value = phone;
        document.getElementById('edit_hub').value = hub;
        
        new bootstrap.Modal(document.getElementById('editProfileModal')).show();
    }
</script>
