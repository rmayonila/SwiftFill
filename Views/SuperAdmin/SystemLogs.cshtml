@{
    ViewData["Title"] = "System Logs";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-cpu text-success me-3"></i> System Logs</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Track application errors, background job executions, and infrastructure events.</p>
        </div>
        <div>
            <button class="btn btn-outline-secondary px-4 border-secondary text-white hover-white" title="Export Trace" onclick="alert('Exporting system logs to CSV...')"><i class="bi bi-download me-2"></i>Export Logs</button>
        </div>
    </div>

    <!-- Log Table Mockup -->
    <div class="card premium-card border-0 shadow-sm" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; overflow: hidden;">
        <div class="card-header bg-transparent border-bottom border-dark py-3 px-4">
            <h6 class="mb-0 fw-bold text-white d-flex align-items-center"><i class="bi bi-cpu-fill text-success me-2"></i> Active System Trace</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead style="background: rgba(0,0,0,0.3);">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Timestamp</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Process ID</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Description</th>
                        <th class="pe-4 py-3 text-secondary text-uppercase fw-semibold text-end" style="font-size: 0.75rem; letter-spacing: 1px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <td class="ps-4 py-3"><div class="text-white small">@DateTime.Now.ToString("g")</div></td>
                        <td class="py-3"><div class="fw-bold text-warning small">SRV-01-WORKER</div></td>
                        <td class="py-3"><div class="text-secondary small">Cache synchronization completed.</div></td>
                        <td class="py-3 text-end pe-4"><span class="badge" style="background: rgba(46, 160, 67, 0.2); color:#6bff72; border: 1px solid rgba(46, 160, 67, 0.4);">Success</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .hover-white:hover {
        color: #ffffff !important;
        background: #30363d !important;
    }
</style>
