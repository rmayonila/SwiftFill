@model IEnumerable<SwiftFill.Models.ApplicationUser>
@{
    ViewData["Title"] = "System Configuration";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-gear-fill me-3 text-warning"></i> System Configuration</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Architectural controls and global system modules.</p>
        </div>
        <div>
            <span class="badge border border-secondary text-secondary px-3 py-2 fs-6 rounded-pill">App Version 1.0.4</span>
        </div>
    </div>
    
    <!-- Top Stats -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card premium-card border-0 shadow-sm h-100" style="background: linear-gradient(145deg, rgba(22,27,34,0.9) 0%, rgba(10,12,16,0.9) 100%); border: 1px solid #30363d !important; border-radius: 12px;">
                <div class="card-body p-4 border-start border-success border-4 rounded-start">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        <span class="text-success fw-bold text-uppercase x-small ls-1">System Status</span>
                    </div>
                    <h3 class="text-white mb-1 fw-bold">Online</h3>
                    <div class="text-secondary small">All services running smoothly</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card premium-card border-0 shadow-sm h-100" style="background: linear-gradient(145deg, rgba(22,27,34,0.9) 0%, rgba(10,12,16,0.9) 100%); border: 1px solid #30363d !important; border-radius: 12px;">
                <div class="card-body p-4 border-start border-info border-4 rounded-start">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-box-seam-fill text-info me-2"></i>
                        <span class="text-info fw-bold text-uppercase x-small ls-1">Total Orders</span>
                    </div>
                    <h3 class="text-white mb-1 fw-bold">@ViewBag.OrderCount</h3>
                    <div class="text-secondary small">Recorded in database</div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card premium-card border-0 shadow-sm h-100" style="background: rgba(22, 27, 34, 0.5); border: 1px solid #30363d !important; border-radius: 12px;">
                <div class="card-body p-4">
                    <h6 class="text-white mb-3 fw-bold">Quick System Actions</h6>
                    <div class="d-flex gap-3 h-100 align-items-center">
                        <button class="btn btn-outline-secondary border-secondary flex-fill py-2 rounded-3 hover-white" title="Clear Temporary Files" onclick="triggerSystemAction('Clear Memory')">
                            <i class="bi bi-trash me-2"></i> Clear Memory
                        </button>
                        <button class="btn btn-outline-secondary border-secondary flex-fill py-2 rounded-3 hover-white" title="Apply Database Updates" onclick="triggerSystemAction('Update Database')">
                            <i class="bi bi-database-up me-2"></i> Update Database
                        </button>
                        <button class="btn btn-outline-warning border-warning text-warning flex-fill py-2 rounded-3" title="Enable Advanced Testing" onclick="triggerSystemAction('Test Mode')">
                            <i class="bi bi-bug me-2"></i> Test Mode
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Super Admin Capabilities Grid -->
    <h5 class="text-white fw-bold mb-4">Super Admin Modules</h5>
    <div class="row g-4 mb-5">
        <!-- 1 -->
        <div class="col-md-4">
            <a href="/SuperAdmin/Users" class="text-decoration-none">
                <div class="card premium-card border-0 h-100 module-card" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; transition: all 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <div class="icon-circle mx-auto mb-3" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(255,140,0,0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-people-fill text-orange fs-3"></i>
                        </div>
                        <h5 class="text-white fw-bold">Manage Users & Roles</h5>
                        <p class="text-secondary small mb-0 mt-2">Create, edit, and deactivate staff accounts (Admins, Warehouse, Riders) and manage access.</p>
                    </div>
                </div>
            </a>
        </div>
        <!-- 2 -->
        <div class="col-md-4">
            <a href="/SuperAdmin/Warehouses" class="text-decoration-none">
                <div class="card premium-card border-0 h-100 module-card" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; cursor: pointer; transition: all 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <div class="icon-circle mx-auto mb-3" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(13, 110, 253, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-buildings text-primary fs-3"></i>
                        </div>
                        <h5 class="text-white fw-bold">System & Hub Configuration</h5>
                        <p class="text-secondary small mb-0 mt-2">Define the shipping network by adding and managing physical Hub locations across regions.</p>
                    </div>
                </div>
            </a>
        </div>
        <!-- 3 -->
        <div class="col-md-4">
            <a href="/SuperAdmin/SecurityLogs" class="text-decoration-none">
                <div class="card premium-card border-0 h-100 module-card" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; cursor: pointer; transition: all 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <div class="icon-circle mx-auto mb-3" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(220, 53, 69, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-shield-lock-fill text-danger fs-3"></i>
                        </div>
                        <h5 class="text-white fw-bold">Security Logs</h5>
                        <p class="text-secondary small mb-0 mt-2">Monitor access attempts, policy changes, and security events to ensure data integrity.</p>
                    </div>
                </div>
            </a>
        </div>
        <!-- 4 -->
        <div class="col-md-4">
            <a href="/SuperAdmin/SystemLogs" class="text-decoration-none">
                <div class="card premium-card border-0 h-100 module-card" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; cursor: pointer; transition: all 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <div class="icon-circle mx-auto mb-3" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(25, 135, 84, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-cpu text-success fs-3"></i>
                        </div>
                        <h5 class="text-white fw-bold">System Logs</h5>
                        <p class="text-secondary small mb-0 mt-2">Track application errors, background job executions, and infrastructure events.</p>
                    </div>
                </div>
            </a>
        </div>
        <!-- 5 -->
        <div class="col-md-4">
            <a href="/SuperAdmin/Branding" class="text-decoration-none">
                <div class="card premium-card border-0 h-100 module-card" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; cursor: pointer; transition: all 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <div class="icon-circle mx-auto mb-3" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(214, 51, 132, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-palette text-pink" style="color: #d63384; font-size: 1.8rem;"></i>
                        </div>
                        <h5 class="text-white fw-bold">Manage Branding</h5>
                        <p class="text-secondary small mb-0 mt-2">Edit color themes and redesign the system logo to match your company's identity.</p>
                    </div>
                </div>
            </a>
        </div>
        <!-- 6 -->
        <div class="col-md-4">
            <a href="/Admin/Dashboard" class="text-decoration-none">
                <div class="card premium-card border-0 h-100 module-card" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; cursor: pointer; transition: all 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <div class="icon-circle mx-auto mb-3" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(255, 255, 255, 0.05); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-grid-fill text-light fs-3"></i>
                        </div>
                        <h5 class="text-white fw-bold">All Modules Access</h5>
                        <p class="text-secondary small mb-0 mt-2">Full visibility into every part of the shipping life-cycle, available in the main menu.</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .module-card:hover {
        background: rgba(30, 36, 45, 0.95) !important;
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.4) !important;
        border-color: #ff8c00 !important;
    }
    .hover-white:hover {
        color: #ffffff !important;
        background: #30363d !important;
    }
</style>

<script>
    function triggerSystemAction(action) {
        if(confirm('Are you sure you want to execute: ' + action + '?')) {
            alert(action + ' initiated successfully.');
        }
    }
</script>
