@model IEnumerable<SwiftFill.Services.AuditLogEntry>
@{
    ViewData["Title"] = "Archived Logs";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-archive-fill text-secondary me-3"></i> Archived Logs</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Historical audit trail for system and security events.</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge border border-secondary text-secondary px-3 py-2 fs-6 rounded-pill">Archive Module</span>
        </div>
    </div>

    <!-- Search & Filter Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px;">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           placeholder="Search archives...">
                </div>
            </form>
        </div>

        <div class="d-flex align-items-center gap-4">
            <form method="get" class="d-flex align-items-center gap-3">
                <select name="type" class="minimal-input" style="width: 150px; background: transparent; border: none;" onchange="this.form.submit()">
                    <option value="">All Types</option>
                    <option value="Security" selected="@(ViewBag.Type == "Security")">Security</option>
                    <option value="System" selected="@(ViewBag.Type == "System")">System</option>
                </select>
            </form>
        </div>
    </div>

    <!-- Archive Table -->
    <div class="glass-card p-0 overflow-hidden mb-4" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="card-header bg-transparent border-bottom border-dark py-3 px-4">
            <h6 class="mb-0 fw-bold text-white d-flex align-items-center">
                <i class="bi bi-archive text-secondary me-2"></i> Historical Data
            </h6>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px; width: 170px;">Timestamp</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px; width: 160px;">Actor</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px; width: 150px;">Type / Action</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Details</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-secondary">
                                <i class="bi bi-inbox" style="font-size: 2.5rem; display:block; margin-bottom: 10px; opacity: 0.3;"></i>
                                No archived logs found.
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                            <td class="ps-4 py-3">
                                <div class="text-white small fw-semibold">@log.Timestamp.ToString("MMM dd, yyyy")</div>
                                <div class="text-secondary" style="font-size: 0.72rem;">@log.Timestamp.ToString("HH:mm:ss")</div>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-warning small">@log.Actor</div>
                                <div class="text-secondary" style="font-size: 0.7rem;">@log.Role</div>
                            </td>
                            <td class="py-3">
                                <div class="small fw-bold" style="color: @log.BadgeTextColor">@log.Type</div>
                                <div class="text-secondary small">@log.Action</div>
                            </td>
                            <td class="py-3">
                                <div class="text-secondary small">@log.Detail</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?search=@ViewBag.Search&type=@ViewBag.Type&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link @(i == ViewBag.CurrentPage ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?search=@ViewBag.Search&type=@ViewBag.Type&page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?search=@ViewBag.Search&type=@ViewBag.Type&page=@(ViewBag.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </div>
    }
</div>
