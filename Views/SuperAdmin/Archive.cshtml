@model IEnumerable<SwiftFill.Models.Warehouse>
@{
    ViewData["Title"] = "Archived Hubs - SwiftFill";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-archive me-3 text-secondary"></i> Archived Hubs</h1>
            <p class="text-secondary mt-1">Inactive fulfillment centers preserved for record-keeping.</p>
        </div>
        <a asp-action="Warehouses" class="btn btn-outline-secondary fw-bold" style="border-radius: 8px;">
            <i class="bi bi-arrow-left me-2"></i> Back to Hubs
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-dark text-success border-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="minimal-filter-bar mb-4 p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <form method="get" class="d-flex w-100 gap-3 align-items-center">
            <div class="search-wrapper flex-grow-1">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                       placeholder="Search Archived Hubs...">
            </div>
            <button type="submit" class="btn btn-sm btn-secondary px-4 py-2 border-0 shadow-sm text-white fw-bold">Filter</button>
        </form>
    </div>

    <div class="card border-0 shadow-lg mb-4" style="background: rgba(22, 27, 34, 0.5); border: 1px solid #30363d !important; border-radius: 12px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="background: transparent;">
                <thead class="bg-dark text-secondary small text-uppercase fw-bold" style="border-bottom: 2px solid #30363d;">
                    <tr>
                        <th class="ps-4 py-3">Hub Name</th>
                        <th class="py-3">Last Known Location</th>
                        <th class="py-3">Past Capacity</th>
                        <th class="py-3">Archived On</th>
                        <th class="pe-4 py-3 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var warehouse in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3 flex-shrink-0 d-flex align-items-center justify-content-center" 
                                         style="background: rgba(255, 255, 255, 0.05); width: 40px; height: 40px; border-radius: 8px;">
                                        <i class="bi bi-building-lock text-secondary" style="font-size: 1.1rem;"></i>
                                    </div>
                                    <span class="fw-bold text-white-50">@warehouse.Name</span>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="text-secondary small">@warehouse.Island &bull; @warehouse.Region</span>
                            </td>
                            <td class="py-3">
                                <span class="text-secondary">@warehouse.Capacity.ToString("N0")</span>
                            </td>
                            <td class="py-3">
                                <span class="text-secondary small">@warehouse.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <form asp-action="RestoreHub" method="post" class="d-inline" onsubmit="return confirm('Restore this hub to active status?');">
                                    <input type="hidden" name="id" value="@warehouse.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success border-0 px-3" title="Restore Hub">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i> Restore Hub
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-archive text-secondary" style="font-size: 2.5rem;"></i>
                                <p class="text-secondary mt-3">No archived hubs found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-4">
            <nav>
                <ul class="pagination pagination-sm" style="--bs-pagination-bg: transparent; --bs-pagination-border-color: rgba(255,255,255,0.1); --bs-pagination-color: #fff; --bs-pagination-hover-bg: rgba(255,255,255,0.1); --bs-pagination-hover-color: #fff; --bs-pagination-active-bg: #6c757d; --bs-pagination-active-border-color: #6c757d;">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?search=@ViewBag.Search&page=@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
