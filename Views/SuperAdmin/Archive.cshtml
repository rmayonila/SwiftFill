@model IEnumerable<SwiftFill.Models.Warehouse>
@{
    ViewData["Title"] = "Archived Hubs - SwiftFill";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Top Header Area -->
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-archive text-secondary me-2"></i> Archived Hubs</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">View and restore disabled fulfillment centers.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-dark text-success border-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="minimal-filter-bar mb-4 p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <form method="get" class="d-flex w-100 gap-3 align-items-center">
            <div class="search-wrapper flex-grow-1">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                       placeholder="Search Hub Name, Region, or Island...">
            </div>
            <button type="submit" class="btn btn-sm btn-secondary px-4 py-2 border-0 shadow-sm text-white fw-bold">Filter</button>
        </form>
    </div>

    <div class="row g-3">
        @foreach (var warehouse in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card premium-card border-0 h-100" style="background: linear-gradient(145deg, #111, #0a0a0a); border-radius: 12px; border: 1px solid #222 !important; opacity: 0.8;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-4 gap-2">
                            <div class="d-flex align-items-center" style="min-width: 0;">
                                <div class="icon-box me-3 flex-shrink-0" style="background: rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 10px;">
                                    <i class="bi bi-building" style="color: #666; font-size: 1.3rem;"></i>
                                </div>
                                <div style="min-width: 0;">
                                    <h5 class="fw-bold mb-1 text-white text-truncate" title="@warehouse.Name">@warehouse.Name</h5>
                                    <div class="text-secondary text-truncate" style="font-size: 0.8rem;">@warehouse.Island &bull; @warehouse.Region</div>
                                </div>
                            </div>
                            <span class="badge flex-shrink-0" style="background: rgba(255, 255, 255, 0.1); color:#999; border: 1px solid rgba(255, 255, 255, 0.2); font-size: 0.7rem; padding: 6px 10px;">
                                <i class="bi bi-archive-fill me-1" style="font-size: 0.4rem; vertical-align: middle;"></i> Archived
                            </span>
                        </div>
                        
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="text-secondary mb-1" style="font-size: 0.85rem;">Efficiency</div>
                                <div class="progress" style="height: 6px; background: #222; border-radius: 3px;">
                                    <div class="progress-bar" role="progressbar" style="width: 0%; background: #555;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <div class="text-end mt-1 text-secondary" style="font-size: 0.75rem;">N/A</div>
                            </div>
                            <div class="col-6">
                                <div class="text-secondary mb-1" style="font-size: 0.85rem;">Storage Cap</div>
                                <div class="fw-bold text-secondary fs-5">@warehouse.Capacity.ToString("N0") <span style="font-size: 0.8rem; font-weight: normal; color: #444;">units</span></div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end border-top border-dark pt-3">
                            <form asp-action="RestoreHub" method="post" class="m-0 w-100" onsubmit="return confirm('Are you sure you want to restore this hub?');">
                                <input type="hidden" name="id" value="@warehouse.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-success w-100 fw-semibold" style="font-size: 0.85rem;">
                                    <i class="bi bi-arrow-counterclockwise me-1"></i> Restore Hub
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-archive text-secondary" style="font-size: 3rem; opacity: 0.5;"></i>
                <p class="text-secondary mt-3">No archived hubs found.</p>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-4">
            <nav>
                <ul class="pagination pagination-sm" style="--bs-pagination-bg: transparent; --bs-pagination-border-color: rgba(255,255,255,0.1); --bs-pagination-color: #fff; --bs-pagination-hover-bg: rgba(255,255,255,0.1); --bs-pagination-hover-color: #fff; --bs-pagination-active-bg: #6c757d; --bs-pagination-active-border-color: #6c757d;">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?search=@ViewBag.Search&page=@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
