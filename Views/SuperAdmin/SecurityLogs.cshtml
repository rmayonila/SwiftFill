@model IEnumerable<SwiftFill.Services.AuditLogEntry>
@{
    ViewData["Title"] = "Security Logs";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-shield-lock-fill text-danger me-3"></i> Security Logs</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Login attempts, access events, hub check-ins, and policy changes.</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge" style="background: rgba(220,53,69,0.15); border: 1px solid rgba(220,53,69,0.3); color: #ff6b6b; padding: 8px 14px;">
                @Model.Count() events
            </span>
            <button class="btn btn-outline-secondary px-4 border-secondary text-white" onclick="exportLogs()">
                <i class="bi bi-download me-2"></i>Export CSV
            </button>
        </div>
    </div>

    <div class="card premium-card border-0 shadow-sm" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px; overflow: hidden;">
        <div class="card-header bg-transparent border-bottom border-dark py-3 px-4 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-white d-flex align-items-center">
                <i class="bi bi-shield-lock-fill text-danger me-2"></i> Security Trace
            </h6>
            <form method="get" class="d-flex m-0 gap-2">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm bg-dark border-secondary text-white" 
                       style="max-width: 240px;" placeholder="Search logs...">
                <button type="submit" class="btn btn-sm btn-danger border-0 px-3 fw-bold">Filter</button>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle" id="secTable">
                <thead style="background: rgba(0,0,0,0.3);">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px; width: 170px;">Timestamp</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px; width: 160px;">User / Role</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px; width: 130px;">Action</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Details</th>
                        <th class="pe-4 py-3 text-secondary text-uppercase fw-semibold text-end" style="font-size: 0.75rem; letter-spacing: 1px; width: 100px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary">
                                <i class="bi bi-shield-check" style="font-size: 2.5rem; display:block; margin-bottom: 10px; opacity: 0.3;"></i>
                                No security events recorded yet.<br>
                                <span style="font-size: 0.8rem;">Events appear here when users log in, fail authentication, or select a hub.</span>
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        var isFailure = log.Action.Contains("Failed") || log.Action.Contains("Denied");
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                            <td class="ps-4 py-3">
                                <div class="text-white small fw-semibold">@log.Timestamp.ToString("MMM dd, yyyy")</div>
                                <div class="text-secondary" style="font-size: 0.72rem;">@log.Timestamp.ToString("HH:mm:ss")</div>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-warning small">@log.Actor</div>
                                <div class="text-secondary" style="font-size: 0.7rem;">
                                    @(log.Role == "WarehouseStaff" ? "Staff Account" : (log.Role == "Admin" ? "In-store Manager" : log.Role))
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="badge" style="background: @log.BadgeColor; color: @log.BadgeTextColor; border: 1px solid @log.BadgeBorder; font-size: 0.7rem;">
                                    @log.Action
                                </span>
                            </td>
                            <td class="py-3">
                                <div class="text-secondary small">@log.Detail</div>
                            </td>
                            <td class="py-3 text-end pe-4">
                                <span class="badge" style="background: @(isFailure ? "rgba(220,53,69,0.15)" : "rgba(46,160,67,0.15)"); color: @(isFailure ? "#ff6b6b" : "#6bff72"); border: 1px solid @(isFailure ? "rgba(220,53,69,0.4)" : "rgba(46,160,67,0.4)"); font-size: 0.7rem;">
                                    @(isFailure ? "Alert" : "Logged")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-transparent border-top border-dark py-3">
                <div class="d-flex justify-content-center">
                    <nav>
                        <ul class="pagination pagination-sm m-0" style="--bs-pagination-bg: transparent; --bs-pagination-border-color: rgba(255,255,255,0.1); --bs-pagination-color: #fff; --bs-pagination-hover-bg: rgba(255,255,255,0.1); --bs-pagination-hover-color: #fff; --bs-pagination-active-bg: #dc3545; --bs-pagination-active-border-color: #dc3545;">
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                            </li>
                            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="?search=@ViewBag.Search&page=@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>
</div>

<script>
    function exportLogs() {
        const rows = [["Timestamp", "User", "Role", "Action", "Details", "Status"]];
        document.querySelectorAll('#secTable tbody tr').forEach(tr => {
            if(tr.innerText.includes("No security events")) return;
            const cols = Array.from(tr.querySelectorAll('td')).map(td => `"${td.innerText.replace(/"/g, '""')}"`);
            rows.push(cols);
        });
        const csv = rows.map(r => r.join(',')).join('\n');
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.setAttribute('hidden', '');
        a.setAttribute('href', url);
        a.setAttribute('download', 'security_logs.csv');
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
    }
</script>
<style>.hover-white:hover { color: #fff !important; background: #30363d !important; }</style>
