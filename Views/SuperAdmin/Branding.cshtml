@{
    ViewData["Title"] = "Manage Branding";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-palette text-pink me-3" style="color: #d63384;"></i> Manage Branding</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Edit color themes and redesign the system logo to match your identity.</p>
        </div>
        <div>
            <button class="btn px-4 text-white" style="background-color: #d63384; font-weight: 600;" onclick="saveBranding()">
                <i class="bi bi-save me-2"></i>Save Brand Assets
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Logo Settings -->
        <div class="col-md-6">
            <div class="card premium-card border-0 shadow-sm h-100" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px;">
                <div class="card-header bg-transparent border-bottom border-dark py-4 px-4">
                    <h6 class="mb-0 fw-bold text-white"><i class="bi bi-image me-2 text-secondary"></i> Brand Logo</h6>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <img src="~/images/logo.png" alt="Current Logo" style="height: 120px; border-radius: 12px; border: 1px solid rgba(255,140,0,0.2); padding: 10px; background: rgba(0,0,0,0.5);" />
                    </div>
                    <button class="btn btn-outline-secondary border-secondary text-white hover-white rounded-3 mb-3 w-100" onclick="alert('File browser opening to upload new logo...')">
                        <i class="bi bi-upload me-2"></i>Upload New Logo
                    </button>
                    <!-- Extra logo features -->
                    <div class="text-start mt-3">
                        <label class="form-label text-secondary small">Logo Text / Slogan Overlay</label>
                        <input type="text" class="form-control bg-dark border-secondary text-white mb-3" placeholder="e.g. Driven by Speed">
                        
                        <label class="form-label text-secondary small">Logo Sizing (Height)</label>
                        <input type="range" class="form-range" min="40" max="150" step="5" value="120">
                    </div>
                </div>
            </div>
        </div>

        <!-- Color Scheme -->
        <div class="col-md-6">
            <div class="card premium-card border-0 shadow-sm h-100" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px;">
                <div class="card-header bg-transparent border-bottom border-dark py-4 px-4">
                    <h6 class="mb-0 fw-bold text-white"><i class="bi bi-brush me-2 text-secondary"></i> Color Scheme</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Primary Accent Color</label>
                        <div class="d-flex align-items-center gap-3">
                            <input type="color" class="form-control form-control-color bg-transparent border-secondary w-25 shadow-none" value="#ff8c00" title="Primary Accent" />
                            <span class="text-white fw-bold">#FF8C00 (SwiftFill Orange)</span>
                        </div>
                    </div>
                    <div>
                        <label class="form-label text-secondary small">System Accent Color</label>
                        <div class="d-flex align-items-center gap-3">
                            <input type="color" class="form-control form-control-color bg-transparent border-secondary w-25 shadow-none" value="#161b22" title="System Accent" />
                            <span class="text-white fw-bold">#161B22 (Dark Matter)</span>
                        </div>
                    </div>
                    <!-- Additional Layout Modes -->
                    <div class="mt-4 pt-3 border-top border-dark">
                        <label class="form-label text-secondary small d-block mb-3">Overall Theme Tone</label>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input bg-dark border-secondary" type="checkbox" id="darkModeSwitch" checked>
                            <label class="form-check-label text-white" for="darkModeSwitch">Deep Space Dark Mode</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input bg-dark border-secondary" type="checkbox" id="glassSwitch" checked>
                            <label class="form-check-label text-white" for="glassSwitch">Glassmorphic Effects</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-white:hover {
        color: #ffffff !important;
        background: #30363d !important;
    }
</style>

<script>
    function saveBranding() {
        // Create an overlay to simulate saving
        let backdrop = document.createElement('div');
        backdrop.style.position = 'fixed';
        backdrop.style.top = '0'; backdrop.style.left = '0';
        backdrop.style.width = '100vw'; backdrop.style.height = '100vh';
        backdrop.style.background = 'rgba(0,0,0,0.85)';
        backdrop.style.zIndex = '9999';
        backdrop.style.display = 'flex';
        backdrop.style.flexDirection = 'column';
        backdrop.style.justifyContent = 'center';
        backdrop.style.alignItems = 'center';
        backdrop.innerHTML = `<div class="spinner-border text-pink mb-3" role="status" style="width: 3rem; height: 3rem; color: #d63384;"></div>
                              <h3 class="text-white">Applying New Brand Identity...</h3>
                              <p class="text-secondary">Pushing assets to system cache and modifying variables.</p>`;
        document.body.appendChild(backdrop);
        
        setTimeout(() => {
            backdrop.innerHTML = `<i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                                  <h3 class="text-white mt-3">Saved Successfully!</h3>
                                  <p class="text-secondary">Changes have been applied throughout the ERP.</p>`;
            setTimeout(() => {
                document.body.removeChild(backdrop);
            }, 2000);
        }, 1500);
    }
</script>
