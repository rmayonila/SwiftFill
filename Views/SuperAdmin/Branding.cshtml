@model SwiftFill.Models.BrandingSettings
@{
    ViewData["Title"] = "Manage Branding";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-palette me-3" style="color:#d63384;"></i> Manage Branding</h1>
            <p class="text-secondary mt-1">Configure your company's visual identity across the SwiftFill ERP.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-light px-4 py-2 fw-bold" style="border-radius:10px;" onclick="exportLogo()">
                <i class="bi bi-download me-2"></i>Export Logo
            </button>
            <button type="button" class="btn px-5 py-2 text-white fw-bold" style="background:#d63384; border-radius:10px;" onclick="document.getElementById('brandingForm').submit()">
                <i class="bi bi-save me-2"></i>Save Brand Assets
            </button>
        </div>
    </div>
    <a id="downloadLink" style="display:none;"></a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-dark text-success border-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form id="brandingForm" asp-action="SaveBranding" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="LogoLayout" id="logoLayoutInput" />
        <input type="hidden" asp-for="TintedLogoUrl" id="tintedLogoInput" />
        <input type="hidden" asp-for="IsDarkMode" id="isDarkModeInput" />
        <input type="hidden" asp-for="UseGlassmorphism" id="useGlassInput" />

        <div class="row g-4">
            <!-- Left Column: Logo Settings -->
            <div class="col-lg-7">
                <div class="card mb-4 border-0" style="background:rgba(22,27,34,0.8);border:1px solid #30363d!important;border-radius:14px;">
                    <div class="card-header bg-transparent border-bottom border-dark py-3 px-4">
                        <h6 class="mb-0 fw-bold text-white"><i class="bi bi-image me-2 text-secondary"></i> Brand Logo</h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-4 text-center">
                            <div id="logoPreviewWrap" style="display:inline-flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:14px 24px;gap:12px;">
                                <img id="logoImgPreview" src="@(string.IsNullOrEmpty(Model.LogoUrl) ? "/images/logo.png" : Model.LogoUrl)" alt="Logo" style="height:@(Model.LogoHeight)px;transition:all 0.3s;" />
                                <span id="logoTextPreview" class="fw-bold" style="font-size:@(Model.BrandFontSize)rem;color:@(Model.BrandNameColor);">@Model.BrandName</span>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label text-secondary small">Logo Text / Brand Name Overlay</label>
                                <input type="text" asp-for="BrandName" id="logoText" class="form-control bg-dark border-secondary text-white"
                                       placeholder="e.g. SwiftFill" oninput="updatePreview()">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary small">Logo Height: <span id="logoSizeVal">@Model.LogoHeight</span>px</label>
                                <input type="range" asp-for="LogoHeight" id="logoSize" class="form-range" min="30" max="140" step="5" oninput="updatePreview()">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary small">Brand Name Font Size: <span id="brandFontVal">@Model.BrandFontSize</span>rem</label>
                                <input type="range" asp-for="BrandFontSize" id="brandFontSize" class="form-range" min="0.8" max="2.5" step="0.1" oninput="updatePreview()">
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary small">Logo + Text Layout</label>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary border-secondary text-white layout-btn @(Model.LogoLayout == "row" ? "active-layout" : "")" onclick="setLayout('row', this)">
                                        <i class="bi bi-layout-sidebar me-1"></i> Side by Side
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary border-secondary text-white layout-btn @(Model.LogoLayout == "column" ? "active-layout" : "")" onclick="setLayout('column', this)">
                                        <i class="bi bi-layout-three-rows me-1"></i> Stacked
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary border-secondary text-white layout-btn @(Model.LogoLayout == "logo-only" ? "active-layout" : "")" onclick="setLayout('logo-only', this)">
                                        <i class="bi bi-image me-1"></i> Logo Only
                                    </button>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary small">Upload New Logo</label>
                                <input type="file" name="logoUpload" id="logoUpload" class="form-control bg-dark border-secondary text-white" accept="image/*" onchange="previewUpload(this)">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Color Scheme -->
            <div class="col-lg-5">
                <div class="card mb-4 border-0" style="background:rgba(22,27,34,0.8);border:1px solid #30363d!important;border-radius:14px;">
                    <div class="card-header bg-transparent border-bottom border-dark py-3 px-4">
                        <h6 class="mb-0 fw-bold text-white"><i class="bi bi-brush me-2 text-secondary"></i> Color Scheme</h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label class="form-label text-secondary small">Primary Accent Color</label>
                                <div class="d-flex align-items-center gap-3">
                                    <input type="color" asp-for="PrimaryColor" id="primaryColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                           style="width:50px;height:42px;" oninput="updatePreview()">
                                    <span id="primaryHex" class="text-white fw-bold">@Model.PrimaryColor.ToUpper()</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary small">Background / Secondary Color</label>
                                <div class="d-flex align-items-center gap-3">
                                    <input type="color" asp-for="BackgroundColor" id="bgColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                           style="width:50px;height:42px;" oninput="updatePreview()">
                                    <span id="bgHex" class="text-white fw-bold">@Model.BackgroundColor.ToUpper()</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary small">Brand Name Color</label>
                                <div class="d-flex align-items-center gap-3">
                                    <input type="color" asp-for="BrandNameColor" id="brandNameColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                           style="width:50px;height:42px;" oninput="updatePreview()">
                                    <span class="text-white fw-bold">Text Color</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary small">Sidebar Accent Color</label>
                                <div class="d-flex align-items-center gap-3">
                                    <input type="color" asp-for="SidebarColor" id="sidebarColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                           style="width:50px;height:42px;" oninput="updatePreview()">
                                    <span class="text-white fw-bold">Sidebar BG</span>
                                </div>
                            </div>
                        </div>

                        <!-- Theme toggles -->
                        <div class="border-top border-dark pt-3">
                            <label class="form-label text-secondary small d-block mb-3">Theme Mode</label>
                            <div class="d-flex flex-column gap-2">
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="darkModeSwitch" @(Model.IsDarkMode ? "checked" : "") onchange="updatePreview()">
                                    <label class="form-check-label text-white" for="darkModeSwitch">Dark Mode</label>
                                </div>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="glassSwitch" @(Model.UseGlassmorphism ? "checked" : "") onchange="updatePreview()">
                                    <label class="form-check-label text-white" for="glassSwitch">Glassmorphic Cards</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .layout-btn { transition: all 0.2s; }
    .active-layout { background: rgba(255,140,0,0.12); border-color: #ff8c00; color: #ff8c00; }
</style>

<script>
    var currentLayout = '@Model.LogoLayout';

    function updatePreview() {
        var logoSize    = document.getElementById('logoSize').value;
        var logoText    = (document.getElementById('logoText').value || '').trim();
        var fontSize    = document.getElementById('brandFontSize').value;
        var primary     = document.getElementById('primaryColor').value;
        var bg          = document.getElementById('bgColor').value;
        var nameColor   = document.getElementById('brandNameColor').value;
        var sidebarBg   = document.getElementById('sidebarColor').value;
        var darkMode    = document.getElementById('darkModeSwitch').checked;
        var glass       = document.getElementById('glassSwitch').checked;

        // Sync hidden inputs
        document.getElementById('logoLayoutInput').value = currentLayout;
        document.getElementById('isDarkModeInput').value = darkMode;
        document.getElementById('useGlassInput').value = glass;

        // Update hex labels
        document.getElementById('primaryHex').textContent = primary.toUpperCase();
        document.getElementById('bgHex').textContent = bg.toUpperCase();
        document.getElementById('logoSizeVal').textContent = logoSize;
        document.getElementById('brandFontVal').textContent = parseFloat(fontSize).toFixed(1);

        // -- Logo preview --
        var logoImg = document.getElementById('logoImgPreview');
        var logoTextEl = document.getElementById('logoTextPreview');
        var previewWrap = document.getElementById('logoPreviewWrap');

        logoImg.style.height = logoSize + 'px';
        
        // Tint the logo using Canvas for maximum reliability
        var tempImg = new Image();
        tempImg.crossOrigin = "anonymous";
        tempImg.src = '@(string.IsNullOrEmpty(Model.LogoUrl) ? "/images/logo.png" : Model.LogoUrl)';
        tempImg.onload = function() {
            var canvas = document.createElement('canvas');
            var ctx = canvas.getContext('2d');
            canvas.width = tempImg.width;
            canvas.height = tempImg.height;
            
            // Draw original
            ctx.drawImage(tempImg, 0, 0);
            
            // Tint while preserving 3D depth (luminosity)
            ctx.globalCompositeOperation = 'color';
            ctx.fillStyle = primary;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // Add a subtle multiply layer for richer tones if color is dark
            ctx.globalCompositeOperation = 'multiply';
            ctx.fillStyle = primary;
            ctx.globalAlpha = 0.2;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.globalAlpha = 1.0;
            
            logoImg.src = canvas.toDataURL();
            document.getElementById('tintedLogoInput').value = logoImg.src;
        };

        logoTextEl.style.fontSize = fontSize + 'rem';
        logoTextEl.style.color = nameColor;
        
        // Update container border with primary color
        previewWrap.style.borderColor = primary + '40';
        previewWrap.style.boxShadow = '0 0 20px ' + primary + '15';

        if (currentLayout === 'logo-only') {
            logoTextEl.style.display = 'none';
            previewWrap.style.flexDirection = 'row';
        } else if (currentLayout === 'column') {
            logoTextEl.style.display = logoText ? 'block' : 'none';
            logoTextEl.textContent = logoText;
            previewWrap.style.flexDirection = 'column';
        } else {
            logoTextEl.style.display = logoText ? 'inline' : 'none';
            logoTextEl.textContent = logoText;
            previewWrap.style.flexDirection = 'row';
        }

        // Update active layout button styles
        document.querySelectorAll('.layout-btn').forEach(btn => {
            if (btn.classList.contains('active-layout')) {
                btn.style.background = primary + '18';
                btn.style.borderColor = primary;
                btn.style.color = primary;
            } else {
                btn.style.background = 'transparent';
                btn.style.borderColor = 'rgba(255,255,255,0.1)';
                btn.style.color = '#fff';
            }
        });
    }

    function setLayout(layout, btn) {
        currentLayout = layout;
        document.querySelectorAll('.layout-btn').forEach(b => b.classList.remove('active-layout'));
        btn.classList.add('active-layout');
        updatePreview();
    }

    function previewUpload(input) {
        if (!input.files || !input.files[0]) return;
        var reader = new FileReader();
        reader.onload = function(e) {
            var el = document.getElementById('logoImgPreview');
            el.src = e.target.result;
            // Wait for image to load then re-tint
            setTimeout(updatePreview, 100);
        };
        reader.readAsDataURL(input.files[0]);
    }

    function exportLogo() {
        var logoImg = document.getElementById('logoImgPreview');
        if (!logoImg.src || logoImg.src.startsWith('data:')) {
            var link = document.getElementById('downloadLink');
            link.href = logoImg.src;
            link.download = 'SwiftFill_Branded_Logo.png';
            link.click();
        } else {
            // If still pointing to static URL, run updatePreview one last time
            updatePreview();
            setTimeout(exportLogo, 100);
        }
    }

    // Init preview on page load
    document.addEventListener('DOMContentLoaded', updatePreview);
</script>
