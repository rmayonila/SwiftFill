@{
    ViewData["Title"] = "Manage Branding";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-palette me-3" style="color:#d63384;"></i> Manage Branding</h1>
            <p class="text-secondary mt-1">Configure your company's visual identity across the SwiftFill ERP.</p>
        </div>
        <button class="btn px-5 py-2 text-white fw-bold" style="background:#d63384; border-radius:10px;" onclick="saveBranding()">
            <i class="bi bi-save me-2"></i>Save Brand Assets
        </button>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- ===== CENTERED: Controls ===== -->
        <div class="col-lg-8">

            <!-- Logo Settings -->
            <div class="card mb-4 border-0" style="background:rgba(22,27,34,0.8);border:1px solid #30363d!important;border-radius:14px;">
                <div class="card-header bg-transparent border-bottom border-dark py-3 px-4">
                    <h6 class="mb-0 fw-bold text-white"><i class="bi bi-image me-2 text-secondary"></i> Brand Logo</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 text-center">
                        <div id="logoPreviewWrap" style="display:inline-flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);border:1px solid rgba(255,140,0,0.2);border-radius:12px;padding:14px 24px;gap:12px;">
                            <img id="logoImgPreview" src="~/images/logo.png" alt="Logo" style="height:60px;transition:all 0.3s;" />
                            <span id="logoTextPreview" class="fw-bold" style="font-size:1.4rem;color:#fff;display:none;"></span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label text-secondary small">Logo Text / Brand Name Overlay</label>
                            <input type="text" id="logoText" class="form-control bg-dark border-secondary text-white"
                                   placeholder="e.g. SwiftFill" oninput="updatePreview()">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Logo Height: <span id="logoSizeVal">60</span>px</label>
                            <input type="range" id="logoSize" class="form-range" min="30" max="140" step="5" value="60" oninput="updatePreview()">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Brand Name Font Size: <span id="brandFontVal">1.4</span>rem</label>
                            <input type="range" id="brandFontSize" class="form-range" min="0.8" max="2.5" step="0.1" value="1.4" oninput="updatePreview()">
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small">Logo + Text Layout</label>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary border-secondary text-white layout-btn active-layout" onclick="setLayout('row', this)">
                                    <i class="bi bi-layout-sidebar me-1"></i> Side by Side
                                </button>
                                <button class="btn btn-sm btn-outline-secondary border-secondary text-white layout-btn" onclick="setLayout('column', this)">
                                    <i class="bi bi-layout-three-rows me-1"></i> Stacked
                                </button>
                                <button class="btn btn-sm btn-outline-secondary border-secondary text-white layout-btn" onclick="setLayout('logo-only', this)">
                                    <i class="bi bi-image me-1"></i> Logo Only
                                </button>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small">Upload New Logo</label>
                            <input type="file" id="logoUpload" class="form-control bg-dark border-secondary text-white" accept="image/*" onchange="previewUpload(this)">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Color Scheme -->
            <div class="card mb-4 border-0" style="background:rgba(22,27,34,0.8);border:1px solid #30363d!important;border-radius:14px;">
                <div class="card-header bg-transparent border-bottom border-dark py-3 px-4">
                    <h6 class="mb-0 fw-bold text-white"><i class="bi bi-brush me-2 text-secondary"></i> Color Scheme</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Primary Accent Color</label>
                            <div class="d-flex align-items-center gap-3">
                                <input type="color" id="primaryColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                       value="#ff8c00" style="width:50px;height:42px;" oninput="updatePreview()">
                                <span id="primaryHex" class="text-white fw-bold">#FF8C00</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Background / Secondary Color</label>
                            <div class="d-flex align-items-center gap-3">
                                <input type="color" id="bgColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                       value="#161b22" style="width:50px;height:42px;" oninput="updatePreview()">
                                <span id="bgHex" class="text-white fw-bold">#161B22</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Brand Name Color</label>
                            <div class="d-flex align-items-center gap-3">
                                <input type="color" id="brandNameColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                       value="#ffffff" style="width:50px;height:42px;" oninput="updatePreview()">
                                <span class="text-white fw-bold">Text Color</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Sidebar Accent Color</label>
                            <div class="d-flex align-items-center gap-3">
                                <input type="color" id="sidebarColor" class="form-control form-control-color bg-transparent border-secondary shadow-none" 
                                       value="#0a0a0a" style="width:50px;height:42px;" oninput="updatePreview()">
                                <span class="text-white fw-bold">Sidebar BG</span>
                            </div>
                        </div>
                    </div>

                    <!-- Theme toggles -->
                    <div class="border-top border-dark pt-3">
                        <label class="form-label text-secondary small d-block mb-3">Theme Mode</label>
                        <div class="d-flex gap-3 flex-wrap">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="darkModeSwitch" checked onchange="updatePreview()">
                                <label class="form-check-label text-white" for="darkModeSwitch">Dark Mode</label>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="glassSwitch" checked onchange="updatePreview()">
                                <label class="form-check-label text-white" for="glassSwitch">Glassmorphic Cards</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .layout-btn { transition: all 0.2s; }
    .active-layout { background: rgba(255,140,0,0.12) !important; border-color: #ff8c00 !important; color: #ff8c00 !important; }
</style>

<script>
    var currentLayout = 'row';

    function updatePreview() {
        var logoSize    = document.getElementById('logoSize').value;
        var logoText    = (document.getElementById('logoText').value || '').trim();
        var fontSize    = document.getElementById('brandFontSize').value;
        var primary     = document.getElementById('primaryColor').value;
        var bg          = document.getElementById('bgColor').value;
        var nameColor   = document.getElementById('brandNameColor').value;
        var sidebarBg   = document.getElementById('sidebarColor').value;
        var darkMode    = document.getElementById('darkModeSwitch').checked;
        var glass       = document.getElementById('glassSwitch').checked;

        // Update hex labels
        document.getElementById('primaryHex').textContent = primary.toUpperCase();
        document.getElementById('bgHex').textContent = bg.toUpperCase();
        document.getElementById('logoSizeVal').textContent = logoSize;
        document.getElementById('brandFontVal').textContent = parseFloat(fontSize).toFixed(1);

        // -- Logo preview (in controls section) --
        var logoImg = document.getElementById('logoImgPreview');
        var logoTextEl = document.getElementById('logoTextPreview');
        var previewWrap = document.getElementById('logoPreviewWrap');

        logoImg.style.height = logoSize + 'px';
        logoTextEl.style.fontSize = fontSize + 'rem';
        logoTextEl.style.color = nameColor;

        if (currentLayout === 'logo-only') {
            logoTextEl.style.display = 'none';
            previewWrap.style.flexDirection = 'row';
        } else if (currentLayout === 'column') {
            logoTextEl.style.display = logoText ? 'block' : 'none';
            logoTextEl.textContent = logoText;
            previewWrap.style.flexDirection = 'column';
        } else {
            logoTextEl.style.display = logoText ? 'inline' : 'none';
            logoTextEl.textContent = logoText;
            previewWrap.style.flexDirection = 'row';
        }

        // -- Sidebar preview --
        var sidebar = document.getElementById('previewSidebar');
        var previewNav = document.getElementById('previewNav');
        sidebar.style.background = sidebarBg;
        previewNav.style.background = sidebarBg;
        sidebar.style.borderBottomColor = primary + '40';

        var previewLogoImg = document.getElementById('previewLogoImg');
        var previewBrandName = document.getElementById('previewBrandName');
        previewLogoImg.style.height = Math.min(parseInt(logoSize), 42) + 'px';
        previewBrandName.textContent = logoText;
        previewBrandName.style.color = nameColor;
        previewBrandName.style.display = (currentLayout === 'logo-only' || !logoText) ? 'none' : 'inline';

        // Active nav item uses primary color
        var activeNav = document.getElementById('previewActiveNav');
        activeNav.style.borderLeftColor = primary;
        activeNav.style.color = primary;
        activeNav.style.background = primary + '18';

        // -- Card preview --
        var card = document.getElementById('previewCard');
        var previewBody = document.getElementById('previewBody');
        var previewBadge = document.getElementById('previewBadge');
        var previewBtn = document.getElementById('previewBtn');

        previewBody.style.background = darkMode ? '#000' : '#f4f5f7';
        card.style.background = glass
            ? (darkMode ? 'rgba(22,27,34,0.85)' : 'rgba(255,255,255,0.7)')
            : (darkMode ? '#161b22' : '#ffffff');
        card.style.backdropFilter = glass ? 'blur(8px)' : 'none';
        card.style.borderColor = glass ? bg : (darkMode ? '#30363d' : '#e0e0e0');

        previewBadge.style.background = primary + '22';
        previewBadge.style.color = primary;
        previewBadge.style.borderColor = primary + '55';
        previewBtn.style.background = primary;
        previewBtn.style.color = isLight(primary) ? '#000' : '#fff';
    }

    function setLayout(layout, btn) {
        currentLayout = layout;
        document.querySelectorAll('.layout-btn').forEach(b => b.classList.remove('active-layout'));
        btn.classList.add('active-layout');
        updatePreview();
    }

    function previewUpload(input) {
        if (!input.files || !input.files[0]) return;
        var reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('logoImgPreview').src = e.target.result;
            document.getElementById('previewLogoImg').src = e.target.result;
        };
        reader.readAsDataURL(input.files[0]);
    }

    function isLight(hex) {
        var r = parseInt(hex.slice(1,3),16);
        var g = parseInt(hex.slice(3,5),16);
        var b = parseInt(hex.slice(5,7),16);
        return (r*299 + g*587 + b*114) / 1000 > 128;
    }

    function saveBranding() {
        var backdrop = document.createElement('div');
        Object.assign(backdrop.style, {
            position:'fixed', top:'0', left:'0', width:'100vw', height:'100vh',
            background:'rgba(0,0,0,0.85)', zIndex:'9999',
            display:'flex', flexDirection:'column', justifyContent:'center', alignItems:'center'
        });
        backdrop.innerHTML = `
            <div class="spinner-border mb-3" role="status" style="width:3rem;height:3rem;color:#d63384;"></div>
            <h3 class="text-white">Applying Brand Identity...</h3>
            <p class="text-secondary">Updating color variables and logo assets.</p>`;
        document.body.appendChild(backdrop);

        setTimeout(() => {
            backdrop.innerHTML = `
                <i class="bi bi-check-circle-fill" style="font-size:5rem;color:#6bff72;"></i>
                <h3 class="text-white mt-3">Saved Successfully!</h3>
                <p class="text-secondary">Brand changes applied throughout the ERP.</p>`;
            setTimeout(() => document.body.removeChild(backdrop), 2000);
        }, 1500);
    }

    // Init preview on page load
    document.addEventListener('DOMContentLoaded', updatePreview);
</script>
