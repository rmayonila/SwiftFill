@model IEnumerable<SwiftFill.Models.Warehouse>
@{
    ViewData["Title"] = "Hub Locations - SwiftFill";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">

    <!-- Top Header Area -->
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white"><i class="bi bi-geo-alt-fill text-primary me-3"></i> Hub Locations</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Manage fulfillment centers and logistics networks.</p>
        </div>
    </div>

    <!-- Search & Filter Bar (Reference-Matched) -->
    <div class="d-flex justify-content-between align-items-center mb-4 gap-3 bg-dark-soft p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-items-center flex-grow-1 gap-3">
            <form method="get" class="d-flex align-items-center flex-grow-1">
                <div class="search-wrapper flex-grow-1" style="max-width: 400px;">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="minimal-input w-100" 
                           placeholder="Search Hub Name, Region, or Island...">
                </div>
            </form>
        </div>
        <div class="d-flex align-items-center gap-4">
            <form method="get" class="d-flex align-items-center gap-3">
                <select name="island" class="minimal-input" style="width: 150px; background: transparent; border: none;" onchange="this.form.submit()">
                    <option value="">All Islands</option>
                    <option value="Luzon" selected="@(ViewBag.Island == "Luzon")">Luzon</option>
                    <option value="Visayas" selected="@(ViewBag.Island == "Visayas")">Visayas</option>
                    <option value="Mindanao" selected="@(ViewBag.Island == "Mindanao")">Mindanao</option>
                </select>
            </form>
        </div>
    </div>

    <!-- Hub Locations Table (Glass-Card) -->
    <div class="glass-card p-0 overflow-hidden mb-4" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <div class="card-header bg-transparent border-bottom border-dark py-3 px-4 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-white d-flex align-items-center">
                <i class="bi bi-geo-alt-fill text-primary me-2"></i> All Fulfillment Hubs
            </h6>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="background: transparent;">
                <thead style="background: rgba(255,140,0,0.03);">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Hub Name</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Location</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Daily Capacity</th>
                        <th class="py-3 text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;">Status</th>
                        <th class="pe-4 py-3 text-secondary text-uppercase fw-semibold text-end" style="font-size: 0.75rem; letter-spacing: 1px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var warehouse in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3 flex-shrink-0 d-flex align-items-center justify-content-center" 
                                         style="background: rgba(255, 140, 0, 0.1); width: 40px; height: 40px; border-radius: 8px;">
                                        <i class="bi bi-building" style="color: #ff8c00; font-size: 1.1rem;"></i>
                                    </div>
                                    <span class="fw-bold text-white">@warehouse.Name</span>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="text-secondary small">@warehouse.Island &bull; @warehouse.Region</span>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-white">@warehouse.Capacity.ToString("N0") <span class="text-secondary small fw-normal">parcels</span></div>
                            </td>
                            <td class="py-3">
                                @{
                                    var badgeColor = warehouse.Status switch {
                                        "Operational" => "#6bff72",
                                        "Maintenance" => "#ffb703",
                                        "Limited Capacity" => "#ffb703",
                                        "Closed" => "#ff6b6b",
                                        _ => "#8b949e"
                                    };
                                }
                                <span class="badge" style="background: rgba(0,0,0,0.3); color: @badgeColor; border: 1px solid @(badgeColor)40; font-size: 0.75rem; padding: 6px 12px;">
                                    <i class="bi bi-circle-fill me-1" style="font-size: 0.4rem; vertical-align: middle;"></i> @warehouse.Status
                                </span>
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-secondary border-0" 
                                            onclick="openEditWarehouseModal('@warehouse.Id', '@warehouse.Name', '@warehouse.Region', '@warehouse.Island', '@warehouse.Capacity', '@warehouse.Status')"
                                            title="Edit Hub">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger border-0" title="Archive Hub" 
                                            onclick="confirmArchiveHub('@warehouse.Id', '@warehouse.Name')">
                                        <i class="bi bi-archive"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-buildings text-secondary" style="font-size: 2.5rem;"></i>
                                <p class="text-secondary mt-3">No hub locations found matching your search.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination (Reference-Matched) -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link @(i == ViewBag.CurrentPage ? "bg-orange border-0" : "bg-dark border-0 text-secondary") mx-1 rounded" href="?search=@ViewBag.Search&page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-0 text-secondary px-3" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </div>
    }
</div>

<!-- Register Warehouse Modal -->
<div class="modal fade" id="registerWarehouseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #0f0f0f; border: 1px solid #30363d; border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold">Register New Hub</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-4">
                <form asp-action="RegisterWarehouse" method="post">
                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Hub Name</label>
                        <input type="text" name="Name" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Davao Distribution Hub" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Region</label>
                            <input type="text" name="Region" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Davao Region" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Island Group</label>
                            <select name="Island" class="form-select bg-dark text-white border-secondary" required>
                                <option value="Luzon">Luzon</option>
                                <option value="Visayas">Visayas</option>
                                <option value="Mindanao">Mindanao</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Capacity (Daily Parcels)</label>
                        <input type="number" name="Capacity" class="form-control bg-dark text-white border-secondary" value="5000" required />
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold flex-grow-1" style="padding: 12px;">Register Hub</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="padding: 12px;">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Warehouse Modal -->
<div class="modal fade" id="editWarehouseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #0f0f0f; border: 1px solid #30363d; border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold">Edit Hub Information</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-4">
                <form asp-action="UpdateWarehouse" method="post">
                    <input type="hidden" name="Id" id="edit_hubId" />
                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Hub Name</label>
                        <input type="text" name="Name" id="edit_hubName" class="form-control bg-dark text-white border-secondary" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Region</label>
                            <input type="text" name="Region" id="edit_hubRegion" class="form-control bg-dark text-white border-secondary" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Island Group</label>
                            <select name="Island" id="edit_hubIsland" class="form-select bg-dark text-white border-secondary" required>
                                <option value="Luzon">Luzon</option>
                                <option value="Visayas">Visayas</option>
                                <option value="Mindanao">Mindanao</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Capacity</label>
                            <input type="number" name="Capacity" id="edit_hubCapacity" class="form-control bg-dark text-white border-secondary" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Status</label>
                            <select name="Status" id="edit_hubStatus" class="form-select bg-dark text-white border-secondary" required>
                                <option value="Operational">Operational</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Limited Capacity">Limited Capacity</option>
                                <option value="Closed">Closed</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold flex-grow-1" style="padding: 12px;">Save Changes</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="padding: 12px;">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditWarehouseModal(id, name, region, island, capacity, status) {
            document.getElementById('edit_hubId').value = id;
            document.getElementById('edit_hubName').value = name;
            document.getElementById('edit_hubRegion').value = region;
            document.getElementById('edit_hubIsland').value = island;
            document.getElementById('edit_hubCapacity').value = capacity;
            document.getElementById('edit_hubStatus').value = status;
            
            new bootstrap.Modal(document.getElementById('editWarehouseModal')).show();
        }

        function confirmArchiveHub(id, name) {
            document.getElementById('archiveHubId').value = id;
            document.getElementById('archiveHubName').textContent = name;
            new bootstrap.Modal(document.getElementById('archiveHubModal')).show();
        }
    </script>
}

<!-- Archive Confirmation Modal -->
<div class="modal fade" id="archiveHubModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg" style="background: #0a0a0a; border-radius: 16px; border: 1px solid rgba(220,53,69,0.2) !important;">
            <div class="modal-body text-center p-4">
                <div class="display-4 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></div>
                <h5 class="text-white fw-bold mb-2">Archive Hub?</h5>
                <p class="text-secondary small mb-4">Are you sure you want to archive <strong id="archiveHubName" class="text-white"></strong>? This will remove it from active management.</p>
                <form asp-action="ArchiveHub" method="post" id="archiveHubForm">
                    <input type="hidden" name="id" id="archiveHubId" />
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-dark flex-fill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger flex-fill fw-bold">Yes, Archive</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
