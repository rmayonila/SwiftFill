@model IEnumerable<SwiftFill.Models.Warehouse>
@{
    ViewData["Title"] = "Hub Locations - SwiftFill";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Top Header Area -->
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white">Hub Locations</h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">Manage fulfillment centers and logistics networks.</p>
        </div>
        <div>
            <button class="btn btn-warning fw-bold" style="border-radius: 8px; padding: 10px 24px;" data-bs-toggle="modal" data-bs-target="#registerWarehouseModal">
                <i class="bi bi-building-add me-2"></i> Register Hub
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-dark text-success border-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @foreach (var warehouse in Model)
        {
            <div class="col-md-6">
                <div class="card premium-card border-0 h-100" style="background: linear-gradient(145deg, #161b22, #0d1117); border-radius: 12px; border: 1px solid #30363d !important;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div class="d-flex align-items-center">
                                <div class="icon-box me-3" style="background: rgba(255, 140, 0, 0.1); padding: 15px; border-radius: 12px;">
                                    <i class="bi bi-building" style="color: #ff8c00; font-size: 1.5rem;"></i>
                                </div>
                                <div>
                                    <h4 class="fw-bold mb-1 text-white">@warehouse.Name</h4>
                                    <span class="badge" style="background: rgba(46, 160, 67, 0.2); color:#6bff72; border: 1px solid rgba(46, 160, 67, 0.4);">
                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem; vertical-align: middle;"></i> @warehouse.Status
                                    </span>
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="text-secondary small">@warehouse.Island</div>
                                <div class="text-secondary x-small">@warehouse.Region</div>
                                <button class="btn btn-sm btn-dark border-secondary text-secondary mt-2" 
                                        onclick="openEditWarehouseModal('@warehouse.Id', '@warehouse.Name', '@warehouse.Region', '@warehouse.Island', '@warehouse.Capacity', '@warehouse.Status')">
                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                </button>
                            </div>
                        </div>
                        
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="text-secondary mb-1" style="font-size: 0.85rem;">Efficiency</div>
                                <div class="progress" style="height: 6px; background: #30363d; border-radius: 3px;">
                                    <div class="progress-bar" role="progressbar" style="width: 100%; background: #ff8c00;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <div class="text-end mt-1 text-white" style="font-size: 0.75rem;">100%</div>
                            </div>
                            <div class="col-6">
                                <div class="text-secondary mb-1" style="font-size: 0.85rem;">Storage Cap</div>
                                <div class="fw-bold text-white fs-5">@warehouse.Capacity.ToString("N0") units</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-buildings text-secondary" style="font-size: 3rem;"></i>
                <p class="text-secondary mt-3">No hubs registered yet. Start by adding a new logistics location.</p>
            </div>
        }
    </div>
</div>

<!-- Register Warehouse Modal -->
<div class="modal fade" id="registerWarehouseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #0f0f0f; border: 1px solid #30363d; border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold">Register New Hub</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-4">
                <form asp-action="RegisterWarehouse" method="post">
                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Hub Name</label>
                        <input type="text" name="Name" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Davao Distribution Hub" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Region</label>
                            <input type="text" name="Region" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Davao Region" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Island Group</label>
                            <select name="Island" class="form-select bg-dark text-white border-secondary" required>
                                <option value="Luzon">Luzon</option>
                                <option value="Visayas">Visayas</option>
                                <option value="Mindanao">Mindanao</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Capacity (Daily Parcels)</label>
                        <input type="number" name="Capacity" class="form-control bg-dark text-white border-secondary" value="5000" required />
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold flex-grow-1" style="padding: 12px;">Register Hub</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="padding: 12px;">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Warehouse Modal -->
<div class="modal fade" id="editWarehouseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #0f0f0f; border: 1px solid #30363d; border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold">Edit Hub Information</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-4">
                <form asp-action="UpdateWarehouse" method="post">
                    <input type="hidden" name="Id" id="edit_hubId" />
                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Hub Name</label>
                        <input type="text" name="Name" id="edit_hubName" class="form-control bg-dark text-white border-secondary" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Region</label>
                            <input type="text" name="Region" id="edit_hubRegion" class="form-control bg-dark text-white border-secondary" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Island Group</label>
                            <select name="Island" id="edit_hubIsland" class="form-select bg-dark text-white border-secondary" required>
                                <option value="Luzon">Luzon</option>
                                <option value="Visayas">Visayas</option>
                                <option value="Mindanao">Mindanao</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Capacity</label>
                            <input type="number" name="Capacity" id="edit_hubCapacity" class="form-control bg-dark text-white border-secondary" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small text-uppercase fw-bold">Status</label>
                            <select name="Status" id="edit_hubStatus" class="form-select bg-dark text-white border-secondary" required>
                                <option value="Operational">Operational</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Limited Capacity">Limited Capacity</option>
                                <option value="Closed">Closed</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold flex-grow-1" style="padding: 12px;">Save Changes</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="padding: 12px;">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditWarehouseModal(id, name, region, island, capacity, status) {
            document.getElementById('edit_hubId').value = id;
            document.getElementById('edit_hubName').value = name;
            document.getElementById('edit_hubRegion').value = region;
            document.getElementById('edit_hubIsland').value = island;
            document.getElementById('edit_hubCapacity').value = capacity;
            document.getElementById('edit_hubStatus').value = status;
            
            new bootstrap.Modal(document.getElementById('editWarehouseModal')).show();
        }
    </script>
}
