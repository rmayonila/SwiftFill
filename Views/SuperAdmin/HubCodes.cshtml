@model IEnumerable<SwiftFill.Models.HubAccessCode>
@using SwiftFill.Models
@{
    ViewData["Title"] = "Hub Access Codes";
    Layout = "_AdminLayout";
    var hubs = ViewBag.Hubs as List<string> ?? new List<string>();
    var activeHubs = ViewBag.ActiveHubs as List<string> ?? new List<string>();
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark pb-3">
        <div>
            <h1 class="fw-bold fs-3 mt-2 mb-0 text-white">
                <i class="bi bi-key-fill me-3 text-warning"></i>Hub Access Codes
            </h1>
            <p class="text-secondary mt-1" style="font-size: 1rem;">
                Assign unique verification codes to each hub branch. Warehouse staff must enter their hub's code to access the system.
            </p>
        </div>
        <button class="btn btn-warning fw-bold px-4" data-bs-toggle="modal" data-bs-target="#createCodeModal">
            <i class="bi bi-plus-circle me-2"></i>Create New Code
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert border-success border-opacity-50 text-success bg-transparent rounded-3 mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert border-danger border-opacity-50 text-danger bg-transparent rounded-3 mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        </div>
    }

    <!-- Hub Status Grid -->
    <div class="row g-3 mb-5">
        @foreach (var hub in HubRegistry.All)
        {
            var activeCode = Model.FirstOrDefault(c => c.HubName == hub.Name && c.IsActive);
            var hasCode = activeCode != null;
            <div class="col-md-3">
                <div class="card border-0 h-100" style="background: @(hasCode ? "rgba(25,135,84,0.06)" : "rgba(220,53,69,0.06)"); border: 1px solid @(hasCode ? "rgba(25,135,84,0.25)" : "rgba(220,53,69,0.2)") !important; border-radius: 12px;">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="badge" style="background: @(hasCode ? "rgba(25,135,84,0.15)" : "rgba(220,53,69,0.1)"); color: @(hasCode ? "#198754" : "#dc3545"); border: 1px solid @(hasCode ? "rgba(25,135,84,0.3)" : "rgba(220,53,69,0.3)"); font-size:0.65rem;">
                                @(hasCode ? "✓ SECURED" : "⚠ NO CODE")
                            </span>
                            <i class="bi @(hasCode ? "bi-shield-check text-success" : "bi-shield-x text-danger")"></i>
                        </div>
                        <div class="fw-bold text-white mb-1" style="font-size:0.9rem;">@hub.Name</div>
                        <div class="text-secondary" style="font-size:0.72rem;">@hub.Region</div>
                        @if (hasCode)
                        {
                            <div class="mt-2 p-2 rounded" style="background: rgba(0,0,0,0.3);">
                                <div class="text-secondary" style="font-size:0.62rem; text-transform:uppercase; letter-spacing:1px;">Active Code</div>
                                <div class="font-monospace fw-bold text-warning" style="font-size:1rem; letter-spacing:3px;">@activeCode!.Code</div>
                                <div class="text-secondary mt-1" style="font-size:0.62rem;">Set by: @(activeCode.CreatedBy ?? "System")</div>
                            </div>
                            <form asp-action="DeleteHubCode" method="post" class="mt-2"
                                  onsubmit="return confirm('Revoke the code for @hub.Name? Staff will be locked out until a new code is set.');">
                                <input type="hidden" name="id" value="@activeCode.Id" />
                                <button type="submit" class="btn btn-sm w-100 fw-semibold"
                                        style="border:1px solid rgba(220,53,69,0.35);color:rgba(220,53,69,0.8);background:rgba(220,53,69,0.04);font-size:0.75rem;padding:5px;">
                                    <i class="bi bi-x-circle me-1"></i>Revoke Code
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-sm w-100 mt-2 fw-semibold"
                                    style="border:1px solid rgba(255,140,0,0.35);color:#ff8c00;background:rgba(255,140,0,0.05);font-size:0.75rem;padding:5px;"
                                    onclick="prefillHub('@hub.Name')" data-bs-toggle="modal" data-bs-target="#createCodeModal">
                                <i class="bi bi-plus-circle me-1"></i>Assign Code
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Code History Table -->
    <h5 class="text-white fw-bold mb-3"><i class="bi bi-clock-history me-2 text-secondary"></i>Code History</h5>
    <div class="table-container">
        <table class="table" id="codeHistoryTable">
            <thead>
                <tr>
                    <th>Hub</th>
                    <th>Code</th>
                    <th>Status</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var code in Model.OrderByDescending(c => c.CreatedAt))
                {
                    <tr>
                        <td class="fw-semibold text-black">
                            <i class="bi bi-geo-alt me-1 text-warning"></i>@code.HubName
                        </td>
                        <td>
                            <span class="font-monospace fw-bold @(code.IsActive ? "text-warning" : "text-secondary")"
                                  style="letter-spacing: 2px; font-size: 1rem;">@code.Code</span>
                        </td>
                        <td>
                            @if (code.IsActive)
                            {
                                <span class="badge" style="background:rgba(25,135,84,0.12);color:#198754;border:1px solid rgba(25,135,84,0.3);">
                                    <i class="bi bi-circle-fill me-1" style="font-size:6px;"></i>Active
                                </span>
                            }
                            else
                            {
                                <span class="badge" style="background:rgba(108,117,125,0.1);color:#6c757d;border:1px solid rgba(108,117,125,0.25);">
                                    Revoked
                                </span>
                            }
                        </td>
                        <td class="text-secondary">@(code.CreatedBy ?? "—")</td>
                        <td class="text-secondary small">@code.CreatedAt.ToLocalTime().ToString("MMM dd yyyy, HH:mm")</td>
                        <td>
                            @if (code.IsActive)
                            {
                                <form asp-action="DeleteHubCode" method="post" class="d-inline"
                                      onsubmit="return confirm('Revoke this code for @code.HubName?');">
                                    <input type="hidden" name="id" value="@code.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-danger border-opacity-50" style="font-size:0.78rem;">
                                        <i class="bi bi-x-circle"></i> Revoke
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-secondary small">—</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-secondary">
                            <i class="bi bi-key" style="font-size:2rem; display:block; margin-bottom:8px;"></i>
                            No access codes created yet. Start by assigning codes to each hub.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Code Modal -->
<div class="modal fade" id="createCodeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #0f0f0f; border: 1px solid rgba(255,140,0,0.2); border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold">
                    <i class="bi bi-key-fill text-warning me-2"></i>Create Hub Access Code
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <p class="text-secondary small mb-4">
                    This code will be shared with all warehouse staff at the selected hub. Any existing active code for that hub will be automatically revoked.
                </p>
                <form asp-action="CreateHubCode" method="post">
                    <div class="mb-3">
                        <label class="text-secondary small mb-1 text-uppercase" style="letter-spacing:1px;">Select Hub</label>
                        <select name="hubName" id="hubNameSelect" class="form-select bg-dark text-white border-secondary" required>
                            <option value="">— Choose a Hub Branch —</option>
                            @foreach (var hub in HubRegistry.All)
                            {
                                <option value="@hub.Name">@hub.Name (@hub.Region)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="text-secondary small mb-1 text-uppercase" style="letter-spacing:1px;">Access Code</label>
                        <div class="input-group">
                            <input type="text" name="code" id="codeInput"
                                   class="form-control bg-dark text-white border-secondary font-monospace fw-bold"
                                   style="letter-spacing:3px; font-size:1.1rem; text-transform:uppercase;"
                                   placeholder="E.g. DVO2024A" maxlength="16" required />
                            <button type="button" class="btn btn-outline-secondary border-secondary" id="generateBtn"
                                    title="Auto-generate a random code">
                                <i class="bi bi-shuffle"></i>
                            </button>
                        </div>
                        <div class="text-secondary mt-1" style="font-size:0.72rem;">
                            <i class="bi bi-info-circle me-1"></i>Use 6–16 alphanumeric characters. No spaces. This code is case-insensitive.
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold flex-fill">
                            <i class="bi bi-shield-check me-2"></i>Set Code
                        </button>
                        <button type="button" class="btn btn-outline-secondary border-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th { color: rgba(255,255,255,0.45); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.8px; border-bottom: 1px solid rgba(255,255,255,0.07); padding: 10px 16px; }
    .table tbody td { color: rgba(255,255,255,0.7); border-bottom: 1px solid rgba(255,255,255,0.04); padding: 14px 16px; vertical-align: middle; }
    .table tbody tr:hover { background: rgba(255,140,0,0.03); }
    .table-container { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 15px; padding: 20px; }
    .animate-fade-up { animation: fadeUp 0.3s ease forwards; }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
</style>

@section Scripts {
    <script>
        function prefillHub(hubName) {
            document.getElementById('hubNameSelect').value = hubName;
        }

        document.getElementById('generateBtn').addEventListener('click', function () {
            fetch('/SuperAdmin/GenerateCodeSuggestion')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('codeInput').value = data.code;
                });
        });

        // Auto-uppercase code input
        document.getElementById('codeInput').addEventListener('input', function () {
            this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        });
    </script>
}
