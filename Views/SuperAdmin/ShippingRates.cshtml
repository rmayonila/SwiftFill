@{
    ViewData["Title"] = "Shipping Rates Matrix";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom border-dark">
        <div>
            <h1 class="fw-bold display-6 mt-2 mb-0 text-white"><i class="bi bi-currency-dollar text-success me-3"></i> Shipping Rates Matrix</h1>
            <p class="text-secondary mt-2 mb-0" style="font-size: 1.1rem;">Configure the pricing matrix based on package weight and destination regions.</p>
        </div>
        <div>
            <button class="btn btn-success px-4" style="font-weight: 600;"><i class="bi bi-plus-circle me-2"></i>Add New Region</button>
        </div>
    </div>

    <!-- Placeholder Content -->
    <div class="card premium-card border-0 shadow-sm" style="background: rgba(22, 27, 34, 0.7); border: 1px solid #30363d !important; border-radius: 12px;">
        <div class="card-body text-center p-5">
            <i class="bi bi-currency-exchange text-success mb-3" style="font-size: 4rem; opacity: 0.8;"></i>
            <h4 class="text-white fw-bold">No Custom Rates Configured</h4>
            <p class="text-secondary mx-auto" style="max-width: 500px;">The system is currently using standard baseline computing formulas. Click 'Add New Region' to set specific overrides.</p>
        </div>
    </div>
</div>
