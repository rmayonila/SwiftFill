@model SwiftFill.Models.Order
@{
    ViewData["Title"] = "Track Shipment";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-white"><i class="bi bi-search text-orange me-2"></i> Track Your Order</h2>
    </div>

    <div class="glass-card mb-4" style="max-width: 800px; background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05);">
        <form asp-action="Track" method="get" class="d-flex gap-2 p-1 bg-dark-soft rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
            <div class="search-wrapper flex-grow-1 border-0 bg-transparent">
                <i class="bi bi-upc-scan ms-2 text-white-50"></i>
                <input type="text" name="trackingId" class="minimal-input w-100 text-white ps-2 fs-5" placeholder="Enter 10-digit Tracking ID" required style="letter-spacing: 2px;" autocomplete="off" />
            </div>
            <button class="btn btn-primary px-5 py-2 fw-bold rounded-2 btn-orange-glow border-0" type="submit" style="background: #FF8C00;">Locate</button>
        </form>
    </div>

    @if (Model != null)
    {
        <div class="glass-card border-0 p-4" style="max-width: 800px; background: rgba(255, 140, 0, 0.03); border: 1px solid rgba(255, 140, 0, 0.1) !important;">
            <div class="d-flex justify-content-between align-items-center border-bottom border-warning border-opacity-25 pb-3 mb-4">
                <div>
                    <span class="text-secondary small text-uppercase ls-1 d-block mb-1">Live Tracking Record</span>
                    <h4 class="mb-0 text-white font-monospace">@Model.TrackingId</h4>
                </div>
                <span class="badge border bg-dark-soft px-4 py-2 fs-6 shadow-sm @(Model.Status == "Delivered" ? "border-success text-success" : (Model.Status.Contains("Return") ? "border-danger text-danger" : "border-orange text-orange"))">
                    @Model.Status
                </span>
            </div>

            <div class="position-relative mb-5 mt-4">
                <div class="progress" style="height: 4px; background-color: rgba(255,255,255,0.1);">
                    <div class="progress-bar bg-orange" role="progressbar" style="width: @(Model.Status == "Delivered" || Model.Status.Contains("Return") ? "100%" : (Model.Status == "OutForDelivery" ? "75%" : (Model.Status.Contains("Transit") || Model.Status.Contains("Arrived") ? "50%" : "15%")))" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                
                <div class="d-flex justify-content-between position-relative" style="top: -24px;">
                    <div class="text-center" style="width: 50px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 @(Model.Status == "Pending" || Model.Status == "Packed" || Model.Status.Contains("Transit") || Model.Status.Contains("Arrived") || Model.Status == "OutForDelivery" || Model.Status == "Delivered" || Model.Status.Contains("Return") ? "bg-orange text-black" : "bg-dark border border-secondary text-secondary")" style="width: 44px; height: 44px; transition: all 0.3s ease;">
                            <i class="bi bi-box-seam fs-5"></i>
                        </div>
                        <div class="x-small text-white-50 fw-semibold text-uppercase">Accepted</div>
                    </div>

                    <div class="text-center" style="width: 50px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 @(Model.Status.Contains("Transit") || Model.Status.Contains("Arrived") || Model.Status == "OutForDelivery" || Model.Status == "Delivered" || Model.Status.Contains("Return") ? "bg-orange text-black" : "bg-dark border border-secondary text-secondary")" style="width: 44px; height: 44px; transition: all 0.3s ease;">
                            <i class="bi bi-truck fs-5"></i>
                        </div>
                        <div class="x-small text-white-50 fw-semibold text-uppercase">Transit</div>
                    </div>

                    <div class="text-center" style="width: 50px;">
                        @if (Model.DeliveryType == "BranchPickup")
                        {
                            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 @(Model.Status.Contains("Arrived") || Model.Status == "Delivered" || Model.Status.Contains("Return") ? "bg-orange text-black" : "bg-dark border border-secondary text-secondary")" style="width: 44px; height: 44px; transition: all 0.3s ease;">
                                <i class="bi bi-shop fs-5"></i>
                            </div>
                            <div class="x-small text-white-50 fw-semibold text-uppercase">Branch</div>
                        }
                        else
                        {
                            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 @(Model.Status == "OutForDelivery" || Model.Status == "Delivered" || Model.Status.Contains("Return") ? "bg-orange text-black" : "bg-dark border border-secondary text-secondary")" style="width: 44px; height: 44px; transition: all 0.3s ease;">
                                <i class="bi bi-bicycle fs-5"></i>
                            </div>
                            <div class="x-small text-white-50 fw-semibold text-uppercase">Dispatch</div>
                        }
                    </div>

                    <div class="text-center" style="width: 50px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 @(Model.Status == "Delivered" ? "bg-success text-black" : (Model.Status.Contains("Return") ? "bg-danger text-white" : "bg-dark border border-secondary text-secondary"))" style="width: 44px; height: 44px; transition: all 0.3s ease;">
                            <i class="bi @(Model.Status.Contains("Return") ? "bi-x-circle" : "bi-check2-all") fs-5"></i>
                        </div>
                        <div class="x-small text-white-50 fw-semibold text-uppercase">@(Model.Status.Contains("Return") ? "Returned" : "Arrived")</div>
                    </div>
                </div>
            </div>

            <div class="row g-4 pt-3">
                <div class="col-12">
                    <div class="p-3 bg-dark-soft rounded-3" style="background: rgba(0,0,0,0.3);">
                        <div class="d-flex align-items-center">
                            <div class="p-3 bg-orange bg-opacity-10 rounded-circle text-orange me-3">
                                <i class="bi bi-geo-alt-fill fs-4"></i>
                            </div>
                            <div>
                                @if (Model.DeliveryType == "BranchPickup" && Model.Status.Contains("Arrived"))
                                {
                                    <div class="text-secondary x-small text-uppercase ls-1 mb-1">Pick Up Location</div>
                                    <h5 class="text-warning mb-0 fw-bold">Ready for Pickup at @Model.PickupBranchAddress</h5>
                                    <p class="text-secondary x-small mt-1 mb-0">Please present valid ID and Tracking ID upon claiming.</p>
                                }
                                else
                                {
                                    <div class="text-secondary x-small text-uppercase ls-1 mb-1">Current Scan Location</div>
                                    <h5 class="text-white mb-0 fw-bold">@Model.CurrentLocation</h5>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 rounded-3" style="background: rgba(255,255,255,0.02)">
                        <div class="text-secondary x-small mb-1"><i class="bi bi-circle-fill text-secondary me-2" style="font-size: 6px;"></i>Origin</div>
                        <div class="text-white-50 small">@Model.SenderAddress</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 rounded-3" style="background: rgba(255,255,255,0.02)">
                        <div class="text-secondary x-small mb-1"><i class="bi bi-geo-fill text-orange me-2" style="font-size: 10px;"></i>Destination</div>
                        <div class="text-white-50 small">@Model.ReceiverAddress</div>
                    </div>
                </div>
                <div class="col-12 text-end">
                    <span class="text-secondary x-small ls-1">SYSTEM TIMESTAMP SECURED: @Model.UpdatedAt.ToLocalTime().ToString("MMM dd yyyy, HH:mm")</span>
                </div>
            </div>
        </div>
    }
    else if (Context.Request.Query.ContainsKey("trackingId"))
    {
        <div class="alert alert-danger bg-transparent border-danger border-opacity-50 text-white rounded-3 mt-4" style="max-width: 800px;">
            <i class="bi bi-x-octagon-fill text-danger me-2"></i> Signal lost. No valid payload found mapped to that Tracking Sequence. Verify the ID and re-transmit.
        </div>
    }
</div>

<style>
    .text-orange { color: #ff8c00 !important; }
    .bg-orange { background-color: #ff8c00 !important; }
    .border-orange { border-color: #ff8c00 !important; }
    .ls-1 { letter-spacing: 1px; }
    .btn-orange-glow { box-shadow: 0 0 15px rgba(255,140,0,0.3); transition: all 0.3s; }
    .btn-orange-glow:hover { box-shadow: 0 0 25px rgba(255,140,0,0.6); transform: translateY(-1px); }
</style>
