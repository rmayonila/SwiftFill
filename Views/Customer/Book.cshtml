@model SwiftFill.Models.Order
@{
    ViewData["Title"] = "Book Shipment";
    Layout = "_AdminLayout";
}

<div class="animate-fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-white"><i class="bi bi-box-seam text-orange me-2"></i> Book New Shipment</h2>
    </div>

    <div class="glass-card p-4 border-0" style="background: rgba(255, 255, 255, 0.01); backdrop-filter: none;">
        <form asp-action="Book" method="post">
            <div class="row g-5">
                <div class="col-md-6">
                    <h6 class="text-white-50 x-small text-uppercase ls-1 mb-4">Sender Logistics Info</h6>
                    <div class="mb-4">
                        <label class="text-secondary x-small mb-1">Full Name</label>
                        <input asp-for="SenderName" class="minimal-input w-100" placeholder="e.g. Juan Luna" required />
                    </div>
                    <div class="mb-4">
                        <label class="text-secondary x-small mb-1">Sender Address (Drop-off)</label>
                        <input asp-for="SenderAddress" class="minimal-input w-100 mb-2" placeholder="Street, City, Province" required />
                    </div>
                    <div class="mb-4">
                        <label class="text-secondary x-small mb-1">Contact Number</label>
                        <input asp-for="SenderPhone" class="minimal-input w-100" placeholder="09123456789" required maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);" title="Phone number must be exactly 11 digits" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="text-white-50 x-small text-uppercase ls-1 mb-4">Receiver Destination</h6>
                    <div class="mb-4">
                        <label class="text-secondary x-small mb-1">Full Name</label>
                        <input asp-for="ReceiverName" class="minimal-input w-100" placeholder="e.g. Maria Clara" required />
                    </div>
                    <div class="mb-4">
                        <label class="text-secondary x-small mb-1">Delivery Address</label>
                        <input asp-for="ReceiverAddress" class="minimal-input w-100 mb-2" placeholder="Bldg, Lot, District" required />
                        <input type="text" name="ReceiverLandmark" class="minimal-input w-100 text-white-50" placeholder="Nearest Landmark / Instructions" required />
                    </div>
                    <div class="mb-4">
                        <label class="text-secondary x-small mb-1">Contact Number</label>
                        <input asp-for="ReceiverPhone" class="minimal-input w-100" placeholder="09123456789" required maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);" title="Phone number must be exactly 11 digits" />
                    </div>
                </div>
            </div>

            <div class="row g-4 align-items-start mb-2">
                <div class="col-md-3">
                    <label class="text-secondary x-small mb-1">Estimated Weight (kg)</label>
                    <input asp-for="Weight" class="minimal-input w-100 est-trigger" placeholder="0.0" required step="0.1" />
                </div>
                <div class="col-md-3">
                    <label class="text-secondary x-small mb-1">Item Category</label>
                    <select asp-for="ItemCategory" class="minimal-input w-100 est-trigger" required>
                        <option value="">Select Type</option>
                        @foreach (var cat in (List<SwiftFill.Models.ItemCategory>)(ViewBag.ItemCategories ?? new List<SwiftFill.Models.ItemCategory>()))
                        {
                            <option value="@cat.Name">@cat.Name</option>
                        }
                        @if (!(ViewBag.ItemCategories as List<SwiftFill.Models.ItemCategory>)?.Any() ?? true)
                        {
                            <option value="Documents">Documents</option>
                            <option value="General">General Goods</option>
                            <option value="Electronics">Electronics</option>
                            <option value="Apparel">Apparel / Clothing</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="text-secondary x-small mb-1">Destination Region</label>
                    <select asp-for="DestinationRegion" class="minimal-input w-100 est-trigger" required>
                        <option value="">Select Destination</option>
                        <option value="NCR">Metro Manila</option>
                        <option value="Luzon">Luzon</option>
                        <option value="Visayas">Visayas</option>
                        <option value="Mindanao">Mindanao</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="text-secondary x-small mb-1">Delivery Type</label>
                    <select asp-for="DeliveryType" class="minimal-input w-100" id="DeliveryType" required>
                        <option value="DoorToDoor">Door-to-Door</option>
                        <option value="BranchPickup">Branch Pickup</option>
                    </select>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-3 offset-md-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" asp-for="IsFragile" id="isFragileCheck">
                        <label class="form-check-label text-warning small" for="isFragileCheck">
                            <i class="bi bi-exclamation-triangle me-1"></i> Fragile Item
                        </label>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-12">
                    <label class="text-white-50 x-small text-uppercase ls-1 mb-3 d-block">Packing Requirements</label>
                    <div class="d-flex gap-4">
                        <div class="form-check custom-radio">
                            <input class="form-check-input est-trigger-radio" type="radio" asp-for="AvailPacking" value="false" id="packSelf" checked>
                            <label class="form-check-label text-white small" for="packSelf">
                                <i class="bi bi-person-check me-1 text-orange"></i> I have already packed this item
                            </label>
                        </div>
                        <div class="form-check custom-radio">
                            <input class="form-check-input est-trigger-radio" type="radio" asp-for="AvailPacking" value="true" id="packService">
                            <label class="form-check-label text-white small" for="packService">
                                <i class="bi bi-box-seam me-1 text-orange"></i> I need SwiftFill Professional Packing (₱50.00 Fee)
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4 d-none" id="branchPickupSection">
                <div class="col-md-12">
                    <label class="text-secondary x-small mb-1">Nearest SwiftFill Branch for Pickup</label>
                    <select asp-for="PickupBranchAddress" class="minimal-input w-100">
                        <option value="">— Select Branch Location —</option>
                        @foreach (var hub in SwiftFill.Models.HubRegistry.Names)
                        {
                            <option value="@hub">@hub</option>
                        }
                    </select>
                    <p class="text-secondary x-small mt-2"><i class="bi bi-info-circle me-1"></i> Receiver will be notified once the parcel arrives at this specific branch.</p>
                </div>
            </div>

            <div class="row g-4 align-items-end mb-4">
                <div class="col-md-12">
                    <button type="submit" class="btn btn-primary w-100 py-3 shadow-sm border-0" style="background: linear-gradient(45deg, #ff8c00, #ff4500);">
                        <i class="bi bi-shield-check me-2"></i> Register Shipment
                    </button>
                </div>
            </div>

            <!-- Dynamic Pricing Estimator UI -->
            <div id="priceEstimatorBlock" class="d-none bg-dark-soft p-4 rounded-3 border border-orange border-opacity-50 mt-4 position-relative overflow-hidden" style="background: rgba(255,140,0,0.03);">
                <div class="position-absolute" style="right: -20px; top: -20px; opacity: 0.1;"><i class="bi bi-calculator" style="font-size: 8rem;"></i></div>
                <div class="row align-items-center position-relative z-index-1">
                     <div class="col-md-8">
                         <div class="d-flex align-items-center mb-2">
                             <h6 class="text-white mb-0 ls-1 font-monospace">ESTIMATED PRICE</h6>
                         </div>
                         <p class="text-secondary x-small mb-0">This is an estimated routing and weight quotation. The final balance will be physically verified and stamped at the drop-off branch.</p>
                     </div>
                     <div class="col-md-4 text-end">
                         <div class="text-secondary x-small text-uppercase ls-1 mb-1 border-bottom border-secondary border-opacity-25 pb-1 d-inline-block">Total Due</div>
                         <h2 class="text-orange fw-bold mb-0">₱<span id="estTotal">0.00</span></h2>
                         <div class="text-white-50 x-small mt-1"><i class="bi bi-tag-fill me-1"></i> Base (<span id="estBase"></span>) + Wgt (<span id="estWgt"></span>) + Zone (<span id="estZone"></span>) <span id="estPackFeeLabel" class="d-none">+ Pack (₱50)</span></div>
                     </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const weightInput = document.getElementById('Weight');
            const regionSelect = document.getElementById('DestinationRegion');
            const categorySelect = document.getElementById('ItemCategory');
            const deliveryTypeSelect = document.getElementById('DeliveryType');
            const branchSection = document.getElementById('branchPickupSection');
            const estimatorBlock = document.getElementById('priceEstimatorBlock');

            const packServiceRadio = document.getElementById('packService');

            const estTotal = document.getElementById('estTotal');
            const estBase = document.getElementById('estBase');
            const estWgt = document.getElementById('estWgt');
            const estZone = document.getElementById('estZone');
            const estPackFeeLabel = document.getElementById('estPackFeeLabel');

            let ratesData = [];

            async function fetchRates() {
                try {
                    const response = await fetch('/Customer/GetRates');
                    ratesData = await response.json();
                } catch (e) {
                    console.error("Failed to load rates", e);
                }
            }

            function calculateEstimate() {
                const wInput = parseFloat(weightInput.value);
                const region = regionSelect.value;
                const cat = categorySelect.value;
                const needsPacking = packServiceRadio.checked;

                if (!isNaN(wInput) && wInput > 0 && region !== "" && cat !== "") {
                    let base = 100;
                    let wgtFee = wInput * 45;
                    let zoneFee = 0;
                    let packingFee = needsPacking ? 50 : 0;

                    // Try to find matching rate in server data
                    const rate = ratesData.find(r => r.destinationRegion === region);
                    if (rate) {
                        base = rate.baseRate;
                        wgtFee = wInput * rate.pricePerKg;
                        zoneFee = rate.zoneSurcharge;
                    } else {
                        // Fallback logic
                        if (region === 'NCR') zoneFee = 50;
                        else if (region === 'Luzon') zoneFee = 100;
                        else if (region === 'Visayas') zoneFee = 150;
                        else if (region === 'Mindanao') zoneFee = 200;
                    }

                    let total = base + wgtFee + zoneFee + packingFee;

                    estBase.textContent = '₱' + base;
                    estWgt.textContent = '₱' + wgtFee.toFixed(2);
                    estZone.textContent = '₱' + zoneFee;
                    
                    if (needsPacking) {
                        estPackFeeLabel.classList.remove('d-none');
                    } else {
                        estPackFeeLabel.classList.add('d-none');
                    }
                    
                    estTotal.textContent = total.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                    estimatorBlock.classList.remove('d-none');
                } else {
                    estimatorBlock.classList.add('d-none');
                }
            }

            deliveryTypeSelect.addEventListener('change', () => {
                if (deliveryTypeSelect.value === 'BranchPickup') {
                    branchSection.classList.remove('d-none');
                    document.getElementById('PickupBranchAddress').required = true;
                } else {
                    branchSection.classList.add('d-none');
                    document.getElementById('PickupBranchAddress').required = false;
                }
            });

            fetchRates().then(() => {
                document.querySelectorAll('.est-trigger').forEach(el => {
                    el.addEventListener('input', calculateEstimate);
                    el.addEventListener('change', calculateEstimate);
                });
                
                document.querySelectorAll('.est-trigger-radio').forEach(el => {
                    el.addEventListener('change', calculateEstimate);
                });
            });
        });
    </script>
}
